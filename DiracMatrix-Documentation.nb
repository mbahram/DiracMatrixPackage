Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
        "\[Eta]", ",", " ", "\[CapitalGamma]u", ",", " ", 
         "\[CapitalGamma]d"}], "}"}], ",", "\n", "    ", 
       RowBox[{
        RowBox[{"\[Eta]", "   ", "=", " ", 
