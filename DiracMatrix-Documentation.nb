     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[CapitalGamma]", ",", " ", "\[CapitalGamma]c"}], "}"}], ",",
        "\n", "    ", 
       RowBox[{
        RowBox[{"\[CapitalGamma]", "  ", "=", " ", 
         RowBox[{"GammaMatrices", "[", 
          RowBox[{"FlatMetric", "[", 
           RowBox[{"p", ",", " ", 
            RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ";", "\n", 
        "    ", 
        RowBox[{"\[CapitalGamma]c", " ", "=", " ", 
         RowBox[{
          RowBox[{"I", "^", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"n", " ", "-", " ", 
               RowBox[{"2", " ", "p"}]}], ")"}], "/", "2"}], ")"}]}], " ", 
          RowBox[{"Dot", " ", "@@", " ", "\[CapitalGamma]"}]}]}], ";", "\n", 
        "    ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"HermitianMatrixQ", "[", "\[CapitalGamma]c", "]"}], ",", 
          "\n", "     ", 
          RowBox[{
           RowBox[{"\[CapitalGamma]c", " ", ".", " ", "\[CapitalGamma]c"}], 
           " ", "==", " ", 
           RowBox[{"IdentityMatrix", "[", 
            RowBox[{"2", "^", 
             RowBox[{"Floor", "[", 
              RowBox[{"n", "/", "2"}], "]"}]}], "]"}]}], ",", "\n", "     ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"Anticommutator", "[", 
               RowBox[{"\[CapitalGamma]c", ",", " ", "#", ",", " ", "Dot"}], 
               "]"}], " ", "&"}], " ", "/@", " ", "\[CapitalGamma]"}], ")"}], 
           " ", "==", "\n", "        ", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{"0", ",", " ", 
             RowBox[{"{", 
              RowBox[{"n", ",", " ", 
               RowBox[{"2", "^", 
                RowBox[{"Floor", "[", 
                 RowBox[{"n", "/", "2"}], "]"}]}], ",", " ", 
               RowBox[{"2", "^", 
                RowBox[{"Floor", "[", 
                 RowBox[{"n", "/", "2"}], "]"}]}]}], "}"}]}], "]"}]}]}], 
         "}"}]}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "8", ",", " ", "2"}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"n", " ", "-", " ", "1"}]}], "}"}]}], "]"}], " ", "//", " ", 
   "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellChangeTimes->{{3.9865861049444103`*^9, 3.98658610494447*^9}},
 CellLabel->"In[39]:=",ExpressionUUID->"98d95889-c267-4d3d-a0a1-a1eacd6a5e29"],

