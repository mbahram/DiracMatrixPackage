Cell[CellGroupData[{

Cell["Commutator identity", "Subsection",ExpressionUUID->"4b9273fe-e8e6-445d-9e94-7649a029806e"],

Cell[BoxData[
 FormBox[
  RowBox[{
   FractionBox["1", "4"], "[", "[", 
   SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
   SuperscriptBox["\[Gamma]", "\[Nu]"], "]", ",", 
   SuperscriptBox["\[Gamma]", "\[Rho]"], "]", "=", 
   SuperscriptBox["\[Eta]", 
    RowBox[{"\[Nu]", "\[Rho]"}]], 
   SuperscriptBox["\[Gamma]", "\[Mu]"], "-", 
   SuperscriptBox["\[Eta]", 
    RowBox[{"\[Mu]", "\[Rho]"}]], 
   SuperscriptBox["\[Gamma]", "\[Nu]"]}], TraditionalForm]], "DisplayFormula",\
ExpressionUUID->"fe97aaec-5f1e-4834-9d63-7980fb0f918e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[CapitalGamma]", ",", " ", "\[Eta]", ",", " ", "A"}], "}"}],
        ",", "\n", "    ", 
       RowBox[{
        RowBox[{"\[Eta]", " ", "=", " ", 
         RowBox[{"FlatMetric", "[", 
          RowBox[{"p", ",", " ", 
           RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], ";", "\n", "    ", 
        RowBox[{"\[CapitalGamma]", " ", "=", " ", 
         RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "    ", 
        RowBox[{"A", " ", "=", " ", 
         RowBox[{"TensorProduct", "[", 
          RowBox[{"\[Eta]", ",", " ", "\[CapitalGamma]"}], "]"}]}], ";", "\n",
         "    ", 
        RowBox[{
         RowBox[{
          RowBox[{"1", "/", "4"}], " ", 
          RowBox[{"Outer", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Commutator", "[", 
              RowBox[{
               RowBox[{"Commutator", "[", 
                RowBox[{"#1", ",", " ", "#2", ",", " ", "Dot"}], "]"}], ",", 
               " ", "#3", ",", " ", "Dot"}], "]"}], " ", "&"}], ",", " ", 
            "\[CapitalGamma]", ",", " ", "\[CapitalGamma]", ",", " ", 
            "\[CapitalGamma]", ",", " ", "1"}], "]"}]}], " ", "==", "\n", 
         "      ", 
         RowBox[{
          RowBox[{"Transpose", "[", 
           RowBox[{"A", ",", " ", 
            RowBox[{"{", 
             RowBox[{"2", ",", " ", "3", ",", " ", "1"}], "}"}]}], "]"}], " ",
           "-", " ", 
          RowBox[{"Transpose", "[", 
           RowBox[{"A", ",", " ", 
            RowBox[{"{", 
             RowBox[{"1", ",", " ", "3", ",", " ", "2"}], "}"}]}], 
           "]"}]}]}]}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"n", " ", "-", " ", "1"}]}], "}"}]}], "]"}], " ", "//", " ", 
   "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellChangeTimes->{{3.986586094730331*^9, 3.986586094730414*^9}},
