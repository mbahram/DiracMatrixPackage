             BaseStyle -> None],
            FrameMargins->{{4, 0}, {-1, 1}}],
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationTitleBackground",
           StripOnInput->False]},
         {
          ItemBox[
           PaneBox[
            
            StyleBox["\<\"RandomCurvedMetric[p, q] (or RandomCurvedMetric[p, \
q, a, s]) returns a random real symmetric non-diagonal metric of signature \
(p,q) constructed as \\!\\(\\*SuperscriptBox[\\(Q\\), \\(T\\)]\\) . \
\[CapitalLambda] . Q with Q \[Element] O(n) a random orthogonal matrix and \
\[CapitalLambda] a diagonal matrix whose first p eigenvalues are \
\\!\\(\\*SuperscriptBox[\\(s\\), \\(2\\)]\\) \
\\!\\(\\*SuperscriptBox[\\(10\\), \\(r\\)]\\) and last q eigenvalues are -\\!\
\\(\\*SuperscriptBox[\\(s\\), \\(2\\)]\\) \\!\\(\\*SuperscriptBox[\\(10\\), \
\\(r\\)]\\) for independent r drawn uniformly from [-a, a]. The default a = 2 \
gives a condition number \[Kappa] ~ \\!\\(\\*SuperscriptBox[\\(10\\), \\\"2 a\
\\\"]\\); s = 1 sets the typical magnitude of the metric components.\"\>", 
             "InformationUsageText",
             StripOnInput->False,
             LineSpacing->{1.5, 1.5, 3.}],
            FrameMargins->{{10, 10}, {8, 10}}],
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False], 
          ItemBox["\<\"\"\>",
           BaseStyle->"InformationUsageSubtitleBackground",
           StripOnInput->False]},
         {
          PaneBox[
           TagBox[GridBox[{
              {
               StyleBox[
                TagBox[
                 TooltipBox[
                  StyleBox["\<\" Definitions\"\>", "InformationRowLabel",
                   StripOnInput->False],
                  "\"Definitions\"",
                  TooltipStyle->"TextStyling"],
                 Annotation[#, "Definitions", "Tooltip"]& ], "DialogStyle",
                StripOnInput->False]},
              {
               TemplateBox[{"\"\[ThinSpace]\"", 
                 GridBox[{{
                    RowBox[{
                    RowBox[{"RandomCurvedMetric", "[", 
                    RowBox[{
                    
                    RowBox[{
                    "DiracMatrix`Private`p_Integer", "?", "NonNegative"}], 
                    ",", 
                    
                    RowBox[{
                    "DiracMatrix`Private`q_Integer", "?", "NonNegative"}], 
                    ",", 
                    RowBox[{"DiracMatrix`Private`a", ":", 
                    RowBox[{"_", "?", "NumericQ"}], ":", "2"}], ",", 
                    RowBox[{"DiracMatrix`Private`s", ":", 
                    RowBox[{"_", "?", "NumericQ"}], ":", "1"}]}], "]"}], ":=", 
                    RowBox[{"Module", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"DiracMatrix`Private`n", ",", 
                    "DiracMatrix`Private`Q", ",", 
                    "DiracMatrix`Private`\[CapitalLambda]"}], "}"}], ",", 
                    RowBox[{
                    RowBox[{"DiracMatrix`Private`n", "=", 
                    
                    RowBox[{"DiracMatrix`Private`p", "+", 
                    "DiracMatrix`Private`q"}]}], ";", 
                    RowBox[{"DiracMatrix`Private`Q", "=", 
                    RowBox[{"RandomVariate", "[", 
                    
                    RowBox[{"CircularRealMatrixDistribution", "[", 
                    "DiracMatrix`Private`n", "]"}], "]"}]}], ";", 
                    RowBox[{"DiracMatrix`Private`\[CapitalLambda]", "=", 
                    RowBox[{"DiagonalMatrix", "[", 
                    RowBox[{
                    SuperscriptBox["DiracMatrix`Private`s", "2"], " ", 
                    RowBox[{"Join", "[", 
                    RowBox[{
                    SuperscriptBox["10", 
                    RowBox[{"RandomReal", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "DiracMatrix`Private`a"}], ",", 
                    "DiracMatrix`Private`a"}], "}"}], ",", 
                    "DiracMatrix`Private`p"}], "]"}]], ",", 
                    RowBox[{"-", 
                    SuperscriptBox["10", 
                    RowBox[{"RandomReal", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"-", "DiracMatrix`Private`a"}], ",", 
                    "DiracMatrix`Private`a"}], "}"}], ",", 
                    "DiracMatrix`Private`q"}], "]"}]]}]}], "]"}]}], "]"}]}], 
                    ";", 
                    RowBox[{
                    RowBox[{"Transpose", "[", "DiracMatrix`Private`Q", "]"}], 
                    ".", "DiracMatrix`Private`\[CapitalLambda]", ".", 
                    "DiracMatrix`Private`Q"}]}]}], "]"}]}]}, {" "}}, 
