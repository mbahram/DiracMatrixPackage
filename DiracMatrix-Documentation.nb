    "CliffordBasis[\[Eta]] returns the canonical graded Clifford operator \
basis using the antisymmetrised recursion \
\!\(\*SubscriptBox[\(\[CapitalGamma]\), \"\[ScriptCapitalI] \[Union] \
{\[Mu]}\"]\) = \!\(\*SubscriptBox[\(\[CapitalGamma]\), \(\[ScriptCapitalI]\)]\
\) \[CenterDot] \!\(\*SubscriptBox[\(\[CapitalGamma]\), \(\[Mu]\)]\) - \
\!\(\*SubsuperscriptBox[\(\[Sum]\), \"j = 1\", \"|\[ScriptCapitalI]|\"]\) \
\!\(\*SuperscriptBox[\((\(-1\))\), \"j - 1\"]\) \
\!\(\*SubscriptBox[\(\[Eta]\), \"\[Mu], i_j\"]\) \!\(\*SubscriptBox[\(\
\[CapitalGamma]\), \"\[ScriptCapitalI] \[Backslash] {i_j}\"]\). Much faster \
than CliffordCanonicalBasis and numerically stable; agrees with it on flat \
metrics at all grades.", "Documentation" -> None, "OwnValues" -> None, 
    "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, DiracMatrix`CliffordBasis, {DiracMatrix`CliffordBasis[
         Condition[
          Pattern[DiracMatrix`Private`\[Eta], 
           Blank[]], 
          SymmetricMatrixQ[
          DiracMatrix`Private`\[Eta], Tolerance -> 10^(-12)]]] :> 
       Module[{DiracMatrix`Private`n, DiracMatrix`Private`\[Gamma], 
          DiracMatrix`Private`d, DiracMatrix`Private`\[CapitalGamma]}, 
         DiracMatrix`Private`n = Length[DiracMatrix`Private`\[Eta]]; 
         DiracMatrix`Private`\[Gamma] = 
          DiracMatrix`GammaMatrices[DiracMatrix`Private`\[Eta]]; 
         DiracMatrix`Private`d = Length[
            Part[DiracMatrix`Private`\[Gamma], 1]]; 
         DiracMatrix`Private`\[CapitalGamma] = <|{} -> 
            IdentityMatrix[DiracMatrix`Private`d]|>; 
         Do[DiracMatrix`Private`\[CapitalGamma][{DiracMatrix`Private`\[Mu]}] = 
           Part[DiracMatrix`Private`\[Gamma], DiracMatrix`Private`\[Mu]], {
           DiracMatrix`Private`\[Mu], DiracMatrix`Private`n}]; Do[
           Do[
            
            With[{DiracMatrix`Private`is = DiracMatrix`Private`sub}, 
             DiracMatrix`Private`\[CapitalGamma][DiracMatrix`Private`is] = 
             DiracMatrix`Private`gammaAppendAntisym[
              DiracMatrix`Private`\[Eta], DiracMatrix`Private`\[Gamma], 
               DiracMatrix`Private`\[CapitalGamma], 
               Most[DiracMatrix`Private`is], 
               Last[DiracMatrix`Private`is]]], {DiracMatrix`Private`sub, 
             Subsets[
              Range[DiracMatrix`Private`n], {DiracMatrix`Private`k}]}], {
           DiracMatrix`Private`k, 2, DiracMatrix`Private`n}]; Table[
           Map[DiracMatrix`Private`\[CapitalGamma], 
            Subsets[
             Range[DiracMatrix`Private`n], {DiracMatrix`Private`k}]], {
           DiracMatrix`Private`k, 0, DiracMatrix`Private`n}]]}], "SubValues" -> 
