 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Dimensions", " ", "@", " ", 
       RowBox[{"GammaMatrices", "[", 
        RowBox[{"FlatMetric", "[", 
         RowBox[{"p", ",", " ", 
          RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], " ", "==", 
      "\n", "    ", 
      RowBox[{"{", 
       RowBox[{"n", ",", " ", 
