Cell[CellGroupData[{

Cell["Verification of standard identities", "Section",ExpressionUUID->"b33c49bf-a0f9-48e7-abd1-285b107275c1"],

Cell["\<\
Each test below evaluates to True if the identity is satisfied for the listed \
range. For non-flat metrics, equality is checked numerically with \
NumericZeroQ.\
\>", "Text",ExpressionUUID->"a4721a17-60aa-49e6-a116-c7a9526d3429"],

Cell[CellGroupData[{

Cell["Number of matrices and spinor dimension", "Subsection",ExpressionUUID->"c5aa5973-7c22-40ca-b886-4b23e4d385a6"],

Cell["\<\
There are n gamma matrices, each of size 2^Floor[n/2] x 2^Floor[n/2].\
\>", "Text",ExpressionUUID->"6c937a57-0d70-4753-a423-279631de2e04"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"Length", " ", "@", " ", 
      RowBox[{"GammaMatrices", "[", "n", "]"}]}], " ", "==", " ", "n"}], ",", 
    " ", 
    RowBox[{"{", 
     RowBox[{"n", ",", " ", "2", ",", " ", "10"}], "}"}]}], "]"}], " ", "//", 
  " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellChangeTimes->{{3.9865865038714333`*^9, 3.9865865038714943`*^9}},
 CellLabel->"In[92]:=",ExpressionUUID->"062c9927-c6d3-421d-aedb-245e940c056d"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.986586504204699*^9},
 CellLabel->"Out[92]=",ExpressionUUID->"038ccb48-4b75-42b1-b475-280dddc69c7d"]
}, Open  ]],

Cell[CellGroupData[{

