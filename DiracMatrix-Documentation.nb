Notebook[{

Cell[CellGroupData[{
Cell["DiracMatrix", "Title",ExpressionUUID->"d8e192d7-f218-49ea-b8f0-92986e7ad168"],

Cell["Mads Bahrami", "Author",ExpressionUUID->"90c8abab-6260-4908-80ab-21821b7bb9ed"],

Cell[CellGroupData[{

Cell["\<\
Documentation, examples, and verification of standard identities\
\>", "Subtitle",ExpressionUUID->"a21331c8-203e-4f4b-a36f-0649869a1aa0"],

Cell[CellGroupData[{

Cell["Overview", "Section",ExpressionUUID->"a055ee1f-51fa-4ad9-98d2-e7b02a2205ac"],

Cell["\<\
The DiracMatrix package constructs Dirac gamma matrices that satisfy the \
Clifford anticommutation relation for an arbitrary real symmetric metric in \
any dimension. It uses the Brauer\[Dash]Weyl (Pauli\[Dash]Kronecker) \
construction in flat space and extends to curved/non-flat metrics through a \
vielbein decomposition. It also exposes basis transformations into the Dirac \
and Weyl/chiral representations and two implementations of the canonical \
graded Clifford operator basis.\
\>", "Text",ExpressionUUID->"28ac3077-c898-48ea-b38a-766d48d08985"],

Cell["\<\
The package source lives at Kernel/DiracMatrix.wl. The exported public \
symbols are GammaMatrices, EuclideanGammaMatrices, FlatMetric, \
RandomCurvedMetric, MetricVielbein, ToDiracBasis, ToWeylBasis, NumericZeroQ, \
CliffordCanonicalBasis, and CliffordBasis.\
\>", "Text",ExpressionUUID->"c0739296-7dc3-43c2-aa09-b4232225dfe6"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Mathematical background", "Section",ExpressionUUID->"d828cd90-149e-44df-86e0-3b660aafb62f"],

Cell[CellGroupData[{

Cell["Clifford relation", "Subsection",ExpressionUUID->"0f71a802-d9b3-4b1b-b16a-9827f28617f6"],

Cell["\<\
The defining property of the Dirac gamma matrices is the Clifford \
anticommutation relation:\
\>", "Text",ExpressionUUID->"03330b6f-cde0-417c-8aeb-5db20bae610a"],

Cell[BoxData[
 FormBox[
  RowBox[{"{", 
   SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
   SuperscriptBox["\[Gamma]", "\[Nu]"], "}", "=", 
   SuperscriptBox["\[Gamma]", "\[Mu]"], 
   SuperscriptBox["\[Gamma]", "\[Nu]"], "+", 
   SuperscriptBox["\[Gamma]", "\[Nu]"], 
   SuperscriptBox["\[Gamma]", "\[Mu]"], "=", "2", 
   SuperscriptBox["\[Eta]", 
    RowBox[{"\[Mu]", "\[Nu]"}]], 
   SubscriptBox["\[DoubleStruckCapitalI]", "N"]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"4ae67eb6-53cb-4674-\
93dd-ff7aa62d0424"],

Cell["\<\
where N = 2^Floor[n/2] is the spinor dimension for an n-dimensional spacetime.\
\>", "Text",ExpressionUUID->"1df4bdf7-166f-462d-8951-d568689b091b"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Brauer-Weyl (Pauli-Kronecker) representation", "Subsection",ExpressionUUID->"ba5ec709-7e71-48a1-9997-58190fc778d6"],

Cell["\<\
For n = 2m or n = 2m + 1, a flat-space realisation in terms of Pauli matrices \
\[Sigma]_j is:\
\>", "Text",ExpressionUUID->"269032d8-b88f-487b-8ea0-94f9c6e953ac"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["\[CapitalGamma]", 
    RowBox[{"2", "k", "-", "1"}]], "=", 
   SuperscriptBox["\[DoubleStruckCapitalI]", 
    RowBox[{"\[CircleTimes]", 
     RowBox[{"(", "k", "-", "1", ")"}]}]], "\[CircleTimes]", 
   SubscriptBox["\[Sigma]", "1"], "\[CircleTimes]", 
   SuperscriptBox[
    SubscriptBox["\[Sigma]", "3"], 
    RowBox[{"\[CircleTimes]", 
     RowBox[{"(", "m", "-", "k", ")"}]}]]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"47caf46e-ecc6-4011-\
9888-32f7892f00ba"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["\[CapitalGamma]", 
    RowBox[{"2", "k"}]], "=", 
   SuperscriptBox["\[DoubleStruckCapitalI]", 
    RowBox[{"\[CircleTimes]", 
     RowBox[{"(", "k", "-", "1", ")"}]}]], "\[CircleTimes]", 
   SubscriptBox["\[Sigma]", "2"], "\[CircleTimes]", 
   SuperscriptBox[
    SubscriptBox["\[Sigma]", "3"], 
    RowBox[{"\[CircleTimes]", 
     RowBox[{"(", "m", "-", "k", ")"}]}]]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"cef65c9f-9470-4a3a-\
8142-c571f9f91cea"],

Cell["and, for odd n, an additional", "Text",ExpressionUUID->"3113eae1-8e01-4972-9adf-ae94fa507c9c"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["\[CapitalGamma]", 
    RowBox[{"2", "m", "+", "1"}]], "=", 
   SuperscriptBox[
    SubscriptBox["\[Sigma]", "3"], 
    RowBox[{"\[CircleTimes]", "m"}]]}], TraditionalForm]], "DisplayFormula",Ex\
pressionUUID->"580ae0ae-f057-462f-8d3e-d29a36667a40"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Signed-diagonal metric", "Subsection",ExpressionUUID->"4805c940-e2ab-491d-a510-cde2941caeb1"],

Cell["\<\
For a flat metric \[Eta]_(\[Mu]\[Nu]) = diag(+1, ..., +1, -1, ..., -1) with p \
positive entries and q negative entries, the gamma matrices are:\
\>", "Text",ExpressionUUID->"b984577f-6d04-4e19-93e7-e7a6dffa0539"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["\[Gamma]", "\[Mu]"], "=", 
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], 
   RowBox[{"  ", "if", "  "}], 
   SuperscriptBox["\[Eta]", 
    RowBox[{"\[Mu]", "\[Mu]"}]], "=", 
   RowBox[{"+", "1"}]}], TraditionalForm]], "DisplayFormula",ExpressionUUID->\
"0b310c55-865b-401a-b8f4-5def6843d987"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["\[Gamma]", "\[Mu]"], "=", 
   RowBox[{"\[ImaginaryI]", "\[ThinSpace]"}], 
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], 
   RowBox[{"  ", "if", "  "}], 
   SuperscriptBox["\[Eta]", 
    RowBox[{"\[Mu]", "\[Mu]"}]], "=", 
   RowBox[{"-", "1"}]}], TraditionalForm]], "DisplayFormula",ExpressionUUID->\
"fbe44b3c-8e71-4bd2-b187-8fc21baf45f3"],

Cell["The resulting algebra is Cl(p, q).", "Text",ExpressionUUID->"30ae9cc2-d38a-4cac-8f0a-c8f04f873803"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Vielbein construction for general metrics", "Subsection",ExpressionUUID->"8ed99c7f-4a61-4c8e-8a1d-80ca456c2793"],

Cell["\<\
For a general real symmetric metric g, a vielbein e^a_\[Mu](x) is computed \
such that g_(\[Mu]\[Nu]) = e^a_\[Mu] e^b_\[Nu] \[Eta]_(ab) (equivalently g = \
e^T \[CenterDot] \[Eta] \[CenterDot] e), and:\
\>", "Text",ExpressionUUID->"439df784-3659-4989-ae4c-497e1c7b1ccd"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SuperscriptBox["\[Gamma]", "\[Mu]"], "(", "x", ")", "=", 
   SubsuperscriptBox["e", "a", "\[Mu]"], 
   SuperscriptBox["\[CapitalGamma]", "a"]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"52e94b97-d083-468d-\
84e7-5d0dae8e6824"],

Cell["\<\
where \[Eta] is the signature matrix and \[CapitalGamma]^a are the flat-space \
gamma matrices in the orthonormal frame.\
\>", "Text",ExpressionUUID->"1be17091-a36b-48d2-ba58-fcd3b182587c"]
}, Open  ]]
}, Open  ]],

