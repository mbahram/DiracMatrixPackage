    "MetricVielbein[\[Eta]] returns {signature, vielbein} for the real \
symmetric metric \[Eta], where signature = DiagonalMatrix[Sign[eigenvalues]] \
and the vielbein e satisfies \!\(\*SuperscriptBox[\(e\), \(T\)]\) . signature \
. e = \[Eta].", "Documentation" -> None, "OwnValues" -> None, "UpValues" -> 
    None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, DiracMatrix`MetricVielbein, {DiracMatrix`MetricVielbein[
         Condition[
          Pattern[DiracMatrix`Private`\[Eta], 
           Blank[]], 
          SymmetricMatrixQ[
          DiracMatrix`Private`\[Eta], Tolerance -> 10^(-12)]]] :> 
       Module[{DiracMatrix`Private`vals, DiracMatrix`Private`vecs, 
          DiracMatrix`Private`signature, DiracMatrix`Private`scale, 
          DiracMatrix`Private`vielbein}, {
           DiracMatrix`Private`vals, DiracMatrix`Private`vecs} = 
          Eigensystem[DiracMatrix`Private`\[Eta]]; 
         DiracMatrix`Private`signature = DiagonalMatrix[
            Sign[DiracMatrix`Private`vals]]; 
         DiracMatrix`Private`scale = DiagonalMatrix[
            Sqrt[
             Abs[DiracMatrix`Private`vals]]]; 
         DiracMatrix`Private`vielbein = 
          Dot[DiracMatrix`Private`scale, DiracMatrix`Private`vecs]; {
          DiracMatrix`Private`signature, DiracMatrix`Private`vielbein}]}], 
    "SubValues" -> None, "DefaultValues" -> None, "NValues" -> None, 
    "FormatValues" -> None, "Options" -> None, "Attributes" -> {}, "FullName" -> 
