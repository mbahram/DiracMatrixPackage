                    "\[LeftDoubleBracket]", "1", "\[RightDoubleBracket]"}], 
                    "]"}]}], ";", 
                    RowBox[{"DiracMatrix`Private`\[CapitalGamma]", "=", 
                    RowBox[{"Association", "[", 
                    RowBox[{
                    RowBox[{"{", "}"}], "\[Rule]", 
                    
                    RowBox[{"IdentityMatrix", "[", "DiracMatrix`Private`d", 
                    "]"}]}], "]"}]}], ";", 
                    RowBox[{"Do", "[", 
                    RowBox[{
                    RowBox[{
                    RowBox[{"DiracMatrix`Private`\[CapitalGamma]", "[", 
                    RowBox[{"{", "DiracMatrix`Private`\[Mu]", "}"}], "]"}], 
                    "=", 
                    
                    RowBox[{"DiracMatrix`Private`\[Gamma]", 
                    "\[LeftDoubleBracket]", "DiracMatrix`Private`\[Mu]", 
                    "\[RightDoubleBracket]"}]}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"DiracMatrix`Private`\[Mu]", ",", 
                    "DiracMatrix`Private`n"}], "}"}]}], "]"}], ";", 
                    RowBox[{"Do", "[", 
                    RowBox[{
                    RowBox[{"Do", "[", 
                    RowBox[{
                    RowBox[{"With", "[", 
                    RowBox[{
                    RowBox[{"{", 
                    
                    RowBox[{"DiracMatrix`Private`is", "=", 
                    "DiracMatrix`Private`sub"}], "}"}], ",", 
                    RowBox[{
                    
                    RowBox[{"DiracMatrix`Private`\[CapitalGamma]", "[", 
                    "DiracMatrix`Private`is", "]"}], "=", 
                    RowBox[{"DiracMatrix`Private`gammaAppendAntisym", "[", 
                    
                    RowBox[{"DiracMatrix`Private`\[Eta]", ",", 
                    "DiracMatrix`Private`\[Gamma]", ",", 
                    "DiracMatrix`Private`\[CapitalGamma]", ",", 
                    RowBox[{"Most", "[", "DiracMatrix`Private`is", "]"}], ",", 
                    RowBox[{"Last", "[", "DiracMatrix`Private`is", "]"}]}], 
                    "]"}]}]}], "]"}], ",", 
                    RowBox[{"{", 
                    RowBox[{"DiracMatrix`Private`sub", ",", 
                    RowBox[{"Subsets", "[", 
                    RowBox[{
                    RowBox[{"Range", "[", "DiracMatrix`Private`n", "]"}], ",", 
                    RowBox[{"{", "DiracMatrix`Private`k", "}"}]}], "]"}]}], 
                    "}"}]}], "]"}], ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"DiracMatrix`Private`k", ",", "2", ",", 
                    "DiracMatrix`Private`n"}], "}"}]}], "]"}], ";", 
                    RowBox[{"Table", "[", 
                    RowBox[{
                    RowBox[{"DiracMatrix`Private`\[CapitalGamma]", "/@", 
                    RowBox[{"Subsets", "[", 
                    RowBox[{
                    RowBox[{"Range", "[", "DiracMatrix`Private`n", "]"}], ",", 
                    RowBox[{"{", "DiracMatrix`Private`k", "}"}]}], "]"}]}], 
                    ",", 
                    RowBox[{"{", 
                    
                    RowBox[{"DiracMatrix`Private`k", ",", "0", ",", 
                    "DiracMatrix`Private`n"}], "}"}]}], "]"}]}]}], "]"}]}]}, {
