Cell[CellGroupData[{

Cell["Antisymmetric recursion (production-ready)", "Subsection",ExpressionUUID->"1727f0a1-a38e-4c6a-b632-70dacbf0e0a2"],

Cell["\<\
CliffordBasis grows the basis grade-by-grade using the recursion\
\>", "Text",ExpressionUUID->"8f1dd2f2-4580-4450-a140-2f3084fd711f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[CapitalGamma]", 
    RowBox[{"[", "\[ScriptCapitalI]", "\[Union]", "{", "\[Mu]", "}", "]"}]], "=", 
   SubscriptBox["\[CapitalGamma]", 
    RowBox[{"[", "\[ScriptCapitalI]", "]"}]], "\[CenterDot]", 
   SubscriptBox["\[CapitalGamma]", "\[Mu]"], "-", 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"j", "=", "1"}], 
    RowBox[{"|", "\[ScriptCapitalI]", "|"}]], 
   SuperscriptBox[
    RowBox[{"(", "-", "1", ")"}], 
    RowBox[{"j", "-", "1"}]], 
   SubscriptBox["\[Eta]", 
    RowBox[{"\[Mu]", ",", 
     SubscriptBox["i", "j"]}]], 
   SubscriptBox["\[CapitalGamma]", 
    RowBox[{"[", "\[ScriptCapitalI]", "\\\\", "{", 
     SubscriptBox["i", "j"], "}", "]"}]]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"d16a2954-cf77-4ab5-\
8c0b-12d9a892bc3d"],

Cell["\<\
This avoids the explicit antisymmetrisation sum and is much more numerically \
stable. For flat metrics it agrees with CliffordCanonicalBasis at all grades.\
\
\>", "Text",ExpressionUUID->"9eb304c8-8998-465e-8061-c975c5521433"],

