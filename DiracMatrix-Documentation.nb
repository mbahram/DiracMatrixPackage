Cell[CellGroupData[{

Cell["Antisymmetric recursion (production-ready)", "Subsection",ExpressionUUID->"1727f0a1-a38e-4c6a-b632-70dacbf0e0a2"],

Cell["\<\
CliffordBasis grows the basis grade-by-grade using the recursion\
\>", "Text",ExpressionUUID->"8f1dd2f2-4580-4450-a140-2f3084fd711f"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[CapitalGamma]", 
    RowBox[{"[", "\[ScriptCapitalI]", "\[Union]", "{", "\[Mu]", "}", "]"}]], "=", 
   SubscriptBox["\[CapitalGamma]", 
    RowBox[{"[", "\[ScriptCapitalI]", "]"}]], "\[CenterDot]", 
   SubscriptBox["\[CapitalGamma]", "\[Mu]"], "-", 
   UnderoverscriptBox["\[Sum]", 
    RowBox[{"j", "=", "1"}], 
    RowBox[{"|", "\[ScriptCapitalI]", "|"}]], 
   SuperscriptBox[
    RowBox[{"(", "-", "1", ")"}], 
    RowBox[{"j", "-", "1"}]], 
   SubscriptBox["\[Eta]", 
    RowBox[{"\[Mu]", ",", 
     SubscriptBox["i", "j"]}]], 
   SubscriptBox["\[CapitalGamma]", 
    RowBox[{"[", "\[ScriptCapitalI]", "\\\\", "{", 
     SubscriptBox["i", "j"], "}", "]"}]]}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"d16a2954-cf77-4ab5-\
8c0b-12d9a892bc3d"],

Cell["\<\
This avoids the explicit antisymmetrisation sum and is much more numerically \
stable. For flat metrics it agrees with CliffordCanonicalBasis at all grades.\
\
\>", "Text",ExpressionUUID->"9eb304c8-8998-465e-8061-c975c5521433"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"CliffordBasis", "[", 
   RowBox[{"FlatMetric", "[", 
    RowBox[{"1", ",", " ", "3"}], "]"}], "]"}], " ", "//", " ", 
  RowBox[{"Map", "[", "Length", "]"}]}]], "Input",
 CellChangeTimes->{{3.986586588596821*^9, 3.9865865885968723`*^9}},
 CellLabel->
  "In[102]:=",ExpressionUUID->"ee097e97-8380-4c10-bfe4-6d5657ea2293"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "4", ",", "6", ",", "4", ",", "1"}], "}"}]], "Output",
 CellChangeTimes->{3.986586589846862*^9},
 CellLabel->
  "Out[102]=",ExpressionUUID->"665209ca-2619-4b4a-8bfa-95e056df6be7"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Eta]", " ", "=", " ", 
         RowBox[{"FlatMetric", "[", 
          RowBox[{"p", ",", " ", 
           RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], "}"}], ",", "\n", 
       "    ", 
       RowBox[{
        RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}], " ", "===", 
        " ", 
        RowBox[{"CliffordBasis", "[", "\[Eta]", "]"}]}]}], "]"}], ",", "\n", 
     "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"n", " ", "-", " ", "1"}]}], "}"}]}], "]"}], " ", "//", " ", 
   "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellChangeTimes->{{3.98658659494697*^9, 3.986586594947014*^9}},
 CellLabel->
  "In[103]:=",ExpressionUUID->"8f38fdf1-91cf-4867-bbb6-622cb60c803d"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.986586595760147*^9},
 CellLabel->
  "Out[103]=",ExpressionUUID->"01bc1b3c-d0aa-4f69-a30b-e407f16f532d"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Drift on non-flat metrics at high grade", "Subsection",ExpressionUUID->"b192c633-dd01-45d5-9cb8-8cbd9e320a76"],

Cell["\<\
For random non-flat metrics the two implementations agree at low grades but \
the explicit antisymmetrisation accumulates error at grades \[GreaterEqual] 4.\
\>", "Text",ExpressionUUID->"314e0dd5-c92c-4096-b5d5-477a0b10bc1a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Eta]", " ", "=", " ", 
         RowBox[{"RandomCurvedMetric", "[", 
          RowBox[{"p", ",", " ", 
           RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], "}"}], ",", "\n", 
       "    ", 
       RowBox[{"NumericZeroQ", "[", "\n", "      ", 
        RowBox[{
         RowBox[{
          RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}], "[", 
          RowBox[{"[", 
           RowBox[{";;", " ", "3"}], "]"}], "]"}], " ", "-", "\n", "      ", 
         RowBox[{
          RowBox[{"CliffordBasis", "[", "\[Eta]", "]"}], "[", 
          RowBox[{"[", 
           RowBox[{";;", " ", "3"}], "]"}], "]"}]}], "]"}]}], "]"}], ",", 
     "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "3", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"n", " ", "-", " ", "1"}]}], "}"}]}], "]"}], " ", "//", " ", 
   "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]}], "Input",
 CellChangeTimes->{{3.9865866040896063`*^9, 3.986586604089674*^9}},
 CellLabel->
  "In[104]:=",ExpressionUUID->"58ffa245-1dc7-4271-9af6-8e64c6012f03"],

Cell[BoxData["True"], "Output",
 CellChangeTimes->{3.986586606206098*^9},
 CellLabel->
  "Out[105]=",ExpressionUUID->"0af38acf-18e8-4027-b8b7-14878edf91f5"]
}, Open  ]],

Cell["\<\
The mismatch at higher grades reflects numerical cancellation in the \
explicit-sum implementation, not an algebraic disagreement; prefer \
CliffordBasis in production.\
\>", "Text",ExpressionUUID->"af55e7d6-0a39-422d-8c54-f11a68dfd222"]
}, Open  ]]
}, Open  ]]
}, Open  ]]
}, Open  ]]
