Cell[CellGroupData[{

Cell["Chirality (even dimension)", "Subsection",ExpressionUUID->"440862d7-dc5c-4a3f-b1c7-f46ff7c2bca3"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[Gamma]", "c"], "=", 
   SuperscriptBox["\[ImaginaryI]", 
    RowBox[{"(", "q", "-", "p", ")", "/", "2"}]], "\[ThinSpace]", 
   SubscriptBox["\[Gamma]", "0"], 
   SubscriptBox["\[Gamma]", "1"], 
   RowBox[{"\[CenterDot]", "\[CenterDot]", "\[CenterDot]"}], 
   SubscriptBox["\[Gamma]", 
    RowBox[{"2", "m"}]]}], TraditionalForm]], "DisplayFormula",ExpressionUUID->\
"f412eef9-c7ff-44bd-933b-92258c015b80"],

Cell["\<\
It is Hermitian, squares to the identity, and anticommutes with every gamma.\
\>", "Text",ExpressionUUID->"b7545a95-3819-4304-9c94-0939cad84d27"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[CapitalGamma]", ",", " ", "\[CapitalGamma]c"}], "}"}], ",",
        "\n", "    ", 
       RowBox[{
        RowBox[{"\[CapitalGamma]", "  ", "=", " ", 
         RowBox[{"GammaMatrices", "[", 
          RowBox[{"FlatMetric", "[", 
           RowBox[{"p", ",", " ", 
            RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ";", "\n", 
        "    ", 
        RowBox[{"\[CapitalGamma]c", " ", "=", " ", 
         RowBox[{
          RowBox[{"I", "^", 
           RowBox[{"(", 
            RowBox[{
             RowBox[{"(", 
              RowBox[{"n", " ", "-", " ", 
               RowBox[{"2", " ", "p"}]}], ")"}], "/", "2"}], ")"}]}], " ", 
          RowBox[{"Dot", " ", "@@", " ", "\[CapitalGamma]"}]}]}], ";", "\n", 
        "    ", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"HermitianMatrixQ", "[", "\[CapitalGamma]c", "]"}], ",", 
          "\n", "     ", 
          RowBox[{
           RowBox[{"\[CapitalGamma]c", " ", ".", " ", "\[CapitalGamma]c"}], 
           " ", "==", " ", 
           RowBox[{"IdentityMatrix", "[", 
            RowBox[{"2", "^", 
             RowBox[{"Floor", "[", 
              RowBox[{"n", "/", "2"}], "]"}]}], "]"}]}], ",", "\n", "     ", 
          RowBox[{
           RowBox[{"(", 
            RowBox[{
             RowBox[{
              RowBox[{"Anticommutator", "[", 
               RowBox[{"\[CapitalGamma]c", ",", " ", "#", ",", " ", "Dot"}], 
               "]"}], " ", "&"}], " ", "/@", " ", "\[CapitalGamma]"}], ")"}], 
           " ", "==", "\n", "        ", 
           RowBox[{"ConstantArray", "[", 
            RowBox[{"0", ",", " ", 
             RowBox[{"{", 
              RowBox[{"n", ",", " ", 
               RowBox[{"2", "^", 
                RowBox[{"Floor", "[", 
                 RowBox[{"n", "/", "2"}], "]"}]}], ",", " ", 
               RowBox[{"2", "^", 
                RowBox[{"Floor", "[", 
                 RowBox[{"n", "/", "2"}], "]"}]}]}], "}"}]}], "]"}]}]}], 
         "}"}]}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "8", ",", " ", "2"}], "}"}], ",", 
     " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"n", " ", "-", " ", "1"}]}], "}"}]}], "]"}], " ", "//", " ", 
   "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellChangeTimes->{{3.9865861049444103`*^9, 3.98658610494447*^9}},
 CellLabel->"In[62]:=",ExpressionUUID->"98d95889-c267-4d3d-a0a1-a1eacd6a5e29"],

