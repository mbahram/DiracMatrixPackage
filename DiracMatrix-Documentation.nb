    Information`InformationValueForm[
     DownValues, DiracMatrix`EuclideanGammaMatrices, {
      DiracMatrix`EuclideanGammaMatrices[1] :> {
         PauliMatrix[3]}, DiracMatrix`EuclideanGammaMatrices[2] :> {
         PauliMatrix[1], 
         PauliMatrix[2]}, DiracMatrix`EuclideanGammaMatrices[3] :> Append[
         DiracMatrix`EuclideanGammaMatrices[2], 
         PauliMatrix[3]], Condition[
         DiracMatrix`EuclideanGammaMatrices[
          Pattern[DiracMatrix`Private`n, 
           Blank[Integer]]], DiracMatrix`Private`n >= 4] :> 
       Module[{DiracMatrix`Private`m = Floor[DiracMatrix`Private`n/2], 
          DiracMatrix`Private`\[CapitalGamma]}, 
         DiracMatrix`Private`\[CapitalGamma] = Apply[Join, 
            Table[{
              Apply[KroneckerProduct, 
               Join[
                ConstantArray[
                 IdentityMatrix[2], DiracMatrix`Private`k - 1], {
                 PauliMatrix[1]}, 
                ConstantArray[
                 PauliMatrix[3], DiracMatrix`Private`m - 
                 DiracMatrix`Private`k]]], 
              Apply[KroneckerProduct, 
               Join[
                ConstantArray[
                 IdentityMatrix[2], DiracMatrix`Private`k - 1], {
                 PauliMatrix[2]}, 
                ConstantArray[
                 PauliMatrix[3], DiracMatrix`Private`m - 
                 DiracMatrix`Private`k]]]}, {
             DiracMatrix`Private`k, DiracMatrix`Private`m}]]; If[
           EvenQ[DiracMatrix`Private`n], DiracMatrix`Private`\[CapitalGamma], 
           
           Append[DiracMatrix`Private`\[CapitalGamma], 
            Apply[KroneckerProduct, 
             ConstantArray[
              PauliMatrix[3], DiracMatrix`Private`m]]]]]}], "SubValues" -> 
    None, "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> None, "Attributes" -> {}, "FullName" -> 
    "DiracMatrix`EuclideanGammaMatrices"|>, False]]], "Output",
