Cell[CellGroupData[{

Cell["Non-flat metrics", "Subsection",ExpressionUUID->"9b8fc237-e04c-43ae-8879-56bbf8e1e3cf"],

Cell["\<\
The same identities hold for arbitrary real symmetric metrics; numerical \
equality is checked with NumericZeroQ.\
\>", "Text",ExpressionUUID->"bfcb65b1-c283-46b0-be40-a83eb436e0a0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[Eta]", ",", " ", "\[CapitalGamma]"}], "}"}], ",", "\n", 
       "    ", 
       RowBox[{
        RowBox[{"\[Eta]", " ", "=", " ", 
         RowBox[{"RandomCurvedMetric", "[", 
          RowBox[{"p", ",", " ", 
           RowBox[{"n", " ", "-", " ", "p"}], ",", " ", "0.5", ",", " ", 
           "1"}], "]"}]}], ";", "\n", "    ", 
        RowBox[{"\[CapitalGamma]", " ", "=", " ", 
         RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "    ", 
        RowBox[{"NumericZeroQ", "[", "\n", "      ", 
         RowBox[{
          RowBox[{"Outer", "[", 
           RowBox[{
            RowBox[{
             RowBox[{
              RowBox[{"#1", ".", "#2"}], " ", "+", " ", 
              RowBox[{"#2", ".", "#1"}]}], " ", "&"}], ",", " ", 
            "\[CapitalGamma]", ",", " ", "\[CapitalGamma]", ",", " ", "1"}], 
           "]"}], " ", "-", "\n", "        ", 
          RowBox[{"2", " ", 
           RowBox[{"TensorProduct", "[", 
            RowBox[{"\[Eta]", ",", " ", 
             RowBox[{"IdentityMatrix", "[", 
              RowBox[{"2", "^", 
               RowBox[{"Floor", "[", 
                RowBox[{"n", "/", "2"}], "]"}]}], "]"}]}], "]"}]}]}], 
         "]"}]}]}], "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", 
       RowBox[{"n", " ", "-", " ", "1"}]}], "}"}]}], "]"}], " ", "//", " ", 
   "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]}], "Input",
 CellChangeTimes->{{3.986586113918915*^9, 3.986586113918982*^9}},
 CellLabel->"In[40]:=",ExpressionUUID->"e826c016-f158-4d11-8da2-c97a83647867"],

