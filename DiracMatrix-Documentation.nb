       RowBox[{"{", 
        RowBox[{
        "\[Eta]", ",", " ", "\[CapitalGamma]u", ",", " ", 
         "\[CapitalGamma]d"}], "}"}], ",", "\n", "    ", 
       RowBox[{
        RowBox[{"\[Eta]", "   ", "=", " ", 
