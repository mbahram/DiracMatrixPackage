 FormBox[
  RowBox[{"Tr", "(", 
   SuperscriptBox["\[Gamma]", "\[Mu]"], ")", "=", "0"}], 
  TraditionalForm]], "DisplayFormula",ExpressionUUID->"1eb23505-92f4-4db7-\
ac3f-9da8c42e3c0d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{"With", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"\[CapitalGamma]", "=", 
         RowBox[{"GammaMatrices", "[", 
          RowBox[{"FlatMetric", "[", 
           RowBox[{"p", ",", 
            RowBox[{"n", "-", "p"}]}], "]"}], "]"}]}], "}"}], ",", 
       RowBox[{
        RowBox[{"Tr", "/@", "\[CapitalGamma]"}], "==", 
        RowBox[{"ConstantArray", "[", 
         RowBox[{"0", ",", "n"}], "]"}]}]}], "]"}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "2", ",", "10"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"p", ",", 
       RowBox[{"n", "-", "1"}]}], "}"}]}], "]"}], "//", "Flatten"}], "//", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellChangeTimes->{{3.986586522441174*^9, 3.986586522780558*^9}},
 CellLabel->"In[31]:=",ExpressionUUID->"15db2fd3-0629-403f-b2c1-6997188d837c"],

