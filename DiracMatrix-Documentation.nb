Cell[CellGroupData[{

Cell["Canonical Clifford operator basis", "Section",ExpressionUUID->"fb806096-7506-42c3-bcbc-4bb6c47b860b"],

Cell["\<\
The grade-k element of the canonical Clifford operator basis is the \
antisymmetrised product\
\>", "Text",ExpressionUUID->"75c16b4c-7694-4192-b8d5-f65fcc6d4056"],

Cell[BoxData[
 FormBox[
  RowBox[{
   SubscriptBox["\[CapitalGamma]", 
    RowBox[{"[", 
     SubscriptBox["i", "1"], ",", "\[Ellipsis]", ",", 
     SubscriptBox["i", "k"], "]"}]], "=", 
   FractionBox["1", 
    RowBox[{"k", "!"}]], 
   UnderscriptBox["\[Sum]", 
    RowBox[{"\[Sigma]", "\[Element]", 
     SubscriptBox["\[ScriptCapitalS]", "k"]}]], "sgn", "(", "\[Sigma]", ")", 
   SubscriptBox["\[CapitalGamma]", 
    SubscriptBox["i", 
     SubscriptBox["\[Sigma]", "1"]]], 
   RowBox[{"\[CenterDot]", "\[CenterDot]", "\[CenterDot]"}], 
   SubscriptBox["\[CapitalGamma]", 
    SubscriptBox["i", 
     SubscriptBox["\[Sigma]", "k"]]]}], TraditionalForm]], "DisplayFormula",Ex\
pressionUUID->"91ddb341-4c5f-42b7-b668-05300a7127eb"],

Cell[TextData[{
 "where ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[ScriptCapitalS]", "k"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "47c33807-7115-45cb-9c20-68a56e2471e8"],
 " is the symmetric group on k indices."
}], "Text",
 CellChangeTimes->{{3.986586121915483*^9, 
  3.986586124264964*^9}},ExpressionUUID->"a75e3324-3387-469b-85bb-\
29b5ea174e5e"],

Cell[CellGroupData[{

Cell["Direct evaluation", "Subsection",ExpressionUUID->"3c89af18-538e-4e83-9f20-4ab3d78becfa"],

Cell["\<\
CliffordCanonicalBasis is a literal transcription of the formula above. It is \
pedagogically transparent but combinatorially expensive, and on non-flat \
metrics it can lose precision at high grades because of cancellations between \
terms of widely different magnitudes.\
\>", "Text",ExpressionUUID->"724636e6-3542-4c92-befa-a00633a3e67b"],

