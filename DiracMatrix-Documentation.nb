   "ObjectType" -> "Symbol", "Usage" -> 
    "ToDiracBasis[\[Gamma]] takes a list of gamma matrices in the Brauer\
\[Dash]Weyl basis and returns them in the Dirac basis (where \
\!\(\*SuperscriptBox[\(\[Gamma]\), \(0\)]\) is diagonal).", "Documentation" -> 
    None, "OwnValues" -> None, "UpValues" -> None, "DownValues" -> 
    Information`InformationValueForm[
     DownValues, DiracMatrix`ToDiracBasis, {DiracMatrix`ToDiracBasis[
         Pattern[DiracMatrix`Private`\[Gamma], 
          Blank[List]]] :> 
       Module[{DiracMatrix`Private`\[Gamma]0, DiracMatrix`Private`vals, 
          DiracMatrix`Private`vecs, DiracMatrix`Private`order, 
          DiracMatrix`Private`S}, 
         DiracMatrix`Private`\[Gamma]0 = 
          First[DiracMatrix`Private`\[Gamma]]; {
           DiracMatrix`Private`vals, DiracMatrix`Private`vecs} = Chop[
            Eigensystem[DiracMatrix`Private`\[Gamma]0]]; 
         DiracMatrix`Private`order = 
          Ordering[DiracMatrix`Private`vals, All, Im[#] > Im[#2]& ]; 
         DiracMatrix`Private`S = Transpose[
            Part[DiracMatrix`Private`vecs, DiracMatrix`Private`order]]; 
         Map[Dot[
            Inverse[DiracMatrix`Private`S], #, DiracMatrix`Private`S]& , 
           DiracMatrix`Private`\[Gamma]]]}], "SubValues" -> None, 
    "DefaultValues" -> None, "NValues" -> None, "FormatValues" -> None, 
    "Options" -> None, "Attributes" -> {}, "FullName" -> 
