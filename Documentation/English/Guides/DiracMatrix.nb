    "paclet:WolframQuantumComputation/DiracMatrix/ref/MetricVielbein"]], 
  "InlineGuideFunction",ExpressionUUID->
  "885fbf5d-2dcc-41d1-ba76-4ae4fa6d9472"],
 " \[LongDash] vielbein decomposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     StyleBox["T", "MR"]], "\[CenterDot]", "\[Eta]", "\[CenterDot]", "e"}], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "2bd99a5b-8d97-427a-b2c5-bc6cbcb4b821"],
 " of a real symmetric metric"
}], "GuideText",
 CellID->1191325641,ExpressionUUID->"f553bf98-29e4-453b-8110-844ab423aa21"]
}, Open  ]],

Cell[CellGroupData[{

Cell["Basis transformations", "GuideFunctionsSubsection",
