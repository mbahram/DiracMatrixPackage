Cell[CellGroupData[{
Cell["DiracMatrix", "GuideTitle",
 CellID->799826245, ExpressionUUID->"87b2c46c-4c45-4f85-bcc6-e92fdc3f9b39"],
Cell[TextData[{
  "The DiracMatrix paclet constructs Dirac gamma matrices ",
  Cell[BoxData[FormBox[
  SuperscriptBox["\[Gamma]", "\[Mu]"],
  TraditionalForm
]], "InlineFormula"],
  " that satisfy the Clifford anticommutation relation ",
  Cell[BoxData[FormBox[
  RowBox[{"{", " ", SuperscriptBox["\[Gamma]", "\[Mu]"], ",", SuperscriptBox["\[Gamma]", "\[Nu]"], " ", "}", "=", "2", " ", SuperscriptBox["\[Eta]", RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", StyleBox["I", FontFamily->"DoubleStruck"]}],
  TraditionalForm
]], "InlineFormula"],
  " for an arbitrary real symmetric metric ",
  Cell[BoxData[FormBox[
  "\[Eta]",
  TraditionalForm
]], "InlineFormula"],
  " in any dimension. The flat case uses the Brauer\[Dash]Weyl (Pauli\[Dash]Kronecker) construction; non-flat metrics are reached through a vielbein decomposition ",
  Cell[BoxData[FormBox[
  RowBox[{"g", "=", SuperscriptBox["\[ExponentialE]", StyleBox["T", "MR"]], "\[CenterDot]", "\[Eta]", "\[CenterDot]", "e"}],
  TraditionalForm
]], "InlineFormula"],
  ". The package also provides basis transformations into the Dirac and Weyl (chiral) representations, and two implementations of the canonical graded Clifford operator basis: an explicit antisymmetrisation sum (pedagogically transparent) and an antisymmetric recursion (numerically stable, production-ready)."
}], "GuideAbstract",
 CellID->2121490076, ExpressionUUID->"6cd18568-f426-45d7-8bc9-7b39f88bb627"]
}, Open]],

