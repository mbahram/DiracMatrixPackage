Notebook[{

Cell[CellGroupData[{
Cell["CliffordCanonicalBasis", "ObjectName",
 CellID->1465370967,ExpressionUUID->"e8149505-dea3-4ff1-90fd-cadcd63fc40e"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}]], "InlineFormula",
  ExpressionUUID->"f967d63e-a9e3-49a7-a3a3-7cf5cbdf6857"],
 "\[LineSeparator]returns the canonical graded operator basis of the Clifford \
algebra ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["Cl", "MR"], "(", "\[Eta]", ")"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"428016b1-f783-4722-b49f-81df5dfc2ea0"],
 " as a list grouped by grade ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"(", "0", ")"}]], ",", 
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"(", "1", ")"}]], ",", "\[Ellipsis]", ",", 
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"(", "n", ")"}]], " ", "}"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"6ff0a840-302a-406c-a4ac-d8cd39d5c7e0"],
 " via explicit antisymmetrisation."
}], "Usage",
 CellID->1323187828,ExpressionUUID->"fa0fcb65-1e41-4262-a345-60a1c3112f54"],

Cell[TextData[{
 "Each grade-k element on indices ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["i", "1"], "<", "\[CenterEllipsis]", "<", 
    SubscriptBox["i", "k"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"1bdf227d-77c9-4f84-b065-773d81667463"],
 " is the antisymmetrised product ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"[", 
      SubscriptBox["i", "1"], " ", "\[CenterEllipsis]", " ", 
      SubscriptBox["i", "k"], "]"}]], "=", 
    FractionBox["1", 
     RowBox[{"k", " ", "!"}]], " ", 
    UnderscriptBox["\[Sum]", 
     RowBox[{"\[Sigma]", "\[Element]", 
      SubscriptBox["S", "k"]}]], " ", 
    StyleBox["sgn", "MR"], "(", "\[Sigma]", ")", "\[ThinSpace]", " ", 
    SubscriptBox["\[CapitalGamma]", 
     SubscriptBox["i", 
      RowBox[{"\[Sigma]", "(", "1", ")"}]]], " ", "\[CenterEllipsis]", " ", 
    SubscriptBox["\[CapitalGamma]", 
     SubscriptBox["i", 
      RowBox[{"\[Sigma]", "(", "k", ")"}]]]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"db1ae3b8-bf54-4ce6-aa91-d835e3fc57c8"],
 "."
}], "Notes",
 CellID->662126735,ExpressionUUID->"9a3d343f-226d-4d63-b846-43dce9bfe1d3"],

Cell[TextData[{
 "This is a literal transcription of the formula; it is pedagogically \
transparent but combinatorially expensive \[LongDash] for n indices it \
evaluates ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", " ", "!"}], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "bacd9670-f1a2-4b31-971c-25f09a090797"],
 " permutations."
}], "Notes",
 CellID->1765949777,ExpressionUUID->"a283e9c5-de88-4e50-9c9d-803397144758"],

Cell["\<\
For non-flat metrics with widely scaled eigenvalues, precision can degrade at \
high grade because of cancellations. Prefer CliffordBasis for production use; \
CliffordCanonicalBasis is best for pedagogy and as a flat-metric reference.\
\>", "Notes",
 CellID->1563894946,ExpressionUUID->"cbe1aa30-29cf-4a7f-8584-26e3ec6c61b0"],

Cell[TextData[{
 "Number of grade-k elements is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"binom", " ", "n", " ", "k"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"f7aa7ab9-690d-4021-bb00-997c84f6503f"],
 ", and the total basis size is ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"45517073-aabe-4abb-ad39-6bc4ba7124f0"],
 "."
}], "Notes",
 CellID->2033432512,ExpressionUUID->"c5ec0fae-9ab9-423b-abc2-4ead5f7a6d8f"]
}, Open  ]],

