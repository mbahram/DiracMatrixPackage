Cell["\<\
On the four-dimensional Minkowski signature the basis has 1 + 4 + 6 + 4 + 1 = \
16 elements:\
\>", "ExampleText",
 CellID->1698116891,ExpressionUUID->"3b5f3754-bc55-4466-be1f-16b0ec45e6ac"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Length", " ", "/@", " ", 
  RowBox[{"CliffordCanonicalBasis", "[", 
   RowBox[{"FlatMetric", "[", 
    RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}]], "Input",
 CellID->1055816631,ExpressionUUID->"ad1acb6b-d00b-4e66-94ab-b38e7ce9e181"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "4", ",", "6", ",", "4", ",", "1"}], "}"}]], "Output",
 CellID->1485509758,ExpressionUUID->"5e8aa52a-d581-4bb4-98f9-38731898f7a7"]
}, Open  ]],

