Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"Total", " ", "@", " ", 
       RowBox[{"Map", "[", 
        RowBox[{"Length", ",", " ", 
         RowBox[{"CliffordCanonicalBasis", "[", 
          RowBox[{"FlatMetric", "[", 
