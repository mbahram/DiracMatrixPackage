Cell["\<\
Higher grade on a random curved metric loses precision due to cancellations \
in the explicit sum \[LongDash] prefer CliffordBasis (production-ready \
alternative):\
\>", "ExampleText",
 CellID->1700122579,ExpressionUUID->"4738cf4d-a1dd-4b2d-a170-d501fdca0a57"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"3", ",", " ", "3"}], "]"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"NumericZeroQ", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"Last", " ", "@", " ", 
      RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}]}], " ", "-", " ",
      "\n", "    ", 
     RowBox[{"Last", " ", "@", " ", 
      RowBox[{"CliffordBasis", "[", "\[Eta]", "]"}]}]}], "]"}]}], 
  "]"}]}], "Input",
 CellID->268660303,ExpressionUUID->"b144195d-4926-48f4-b55c-a523f3522134"],

Cell[BoxData["False"], "Output",
 CellID->1308855079,ExpressionUUID->"c94c3e34-4dfe-468f-82b5-bd28558d1392"]
}, Open  ]],

