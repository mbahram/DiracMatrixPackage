Cell["Agreement with CliffordBasis on flat metrics", "ExampleSubsection",
 CellID->1726976931,ExpressionUUID->"4f122b3c-5711-40e9-b237-045b690fa41e"],

Cell["\<\
On any flat signature the two implementations produce the same basis at every \
grade:\
\>", "ExampleText",
 CellID->322972638,ExpressionUUID->"f937d63b-7755-43ba-a06f-79b3e88f62d8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"CliffordCanonicalBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}], " ", "===", " ", 
      "\n", "    ", 
      RowBox[{"CliffordBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "5"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellID->1828388548,ExpressionUUID->"9275ce6d-b3b9-4ea5-821f-3e245dd0233b"],

Cell[BoxData["True"], "Output",
 CellID->2082447997,ExpressionUUID->"84889111-a84c-4eac-b803-d50def1e5895"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

