Cell[CellGroupData[{
Cell["FlatMetric", "ObjectName",
 CellID->1816852463,ExpressionUUID->"1bee4ad8-4df0-40ea-bd4c-5887be49fcf6"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"FlatMetric", "[", 
   RowBox[{"p", ",", " ", "q"}], "]"}]], "InlineFormula",ExpressionUUID->
  "f24e10b2-140e-4bd6-b7fd-cc0c873fcb0e"],
 "\[LineSeparator]returns the diagonal flat metric of signature ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "p", ",", "q", ")"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"38485be5-a243-4dd2-bac0-db5a10239e8b"],
 " with ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "4f213bd4-4ac2-44ad-9267-020c98ade42b"],
 " positive (+1) and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "4981b338-d420-4b9e-8274-f25933921391"],
 " negative (-1) diagonal entries."
}], "Usage",
 CellID->80817669,ExpressionUUID->"35513849-5e17-4f04-9dd2-4ab0dcd39f9e"],

Cell["\<\
The returned matrix is dense; for an explicit sparse form wrap the result \
with SparseArray.\
\>", "Notes",
 CellID->806105380,ExpressionUUID->"278de457-6495-4c80-ac4c-2c2a66f909bb"],

Cell["\<\
FlatMetric is a thin convenience over DiagonalMatrix[Join[ConstantArray[1, \
p], ConstantArray[-1, q]]]; it is most useful as the input metric to \
GammaMatrices, CliffordBasis, and CliffordCanonicalBasis.\
\>", "Notes",
 CellID->209222405,ExpressionUUID->"cfd51770-f1af-4294-851d-0246611a45b0"]
}, Open  ]],

