  $Line = 0; Null]], "ExampleSection",
 CellID->1810605378, ExpressionUUID->"b757785e-6441-4c75-bc74-ee2a814a789a"],
Cell["Verify that FlatMetric is its own inverse for any signature, since its diagonal entries square to 1:", "ExampleText",
 CellID->1976506792, ExpressionUUID->"a2fc7d11-dc79-47b8-b84f-fabde3f54d2d"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{RowBox[{RowBox[{"Table", "[", RowBox[{RowBox[{RowBox[{RowBox[{"FlatMetric", "[", RowBox[{"p", ",", " ", RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], " ", ".", " ", RowBox[{"FlatMetric", "[", RowBox[{"p", ",", " ", RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], " ", "==", " ", RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ",", " ", RowBox[{"{", RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", RowBox[{"{", RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", " ", "Flatten"}], " ", "//", " ", RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellID->1197772505, ExpressionUUID->"ef694e2d-7679-4f0a-a988-236d39b44833"],
Cell[BoxData["True"], "Output",
 CellID->1352556635, ExpressionUUID->"fd399854-1967-4803-9c1b-83721c60b1d3"]
}, Open]]
}, Open]],

