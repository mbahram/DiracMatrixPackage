Cell["\<\
Verify that FlatMetric is its own inverse for any signature, since its \
diagonal entries square to 1:\
\>", "ExampleText",
 CellID->1976506792,ExpressionUUID->"a2fc7d11-dc79-47b8-b84f-fabde3f54d2d"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], " ", ".", " ", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], " ", "==", " ", 
      RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
