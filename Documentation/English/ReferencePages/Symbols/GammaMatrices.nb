Notebook[{

Cell[CellGroupData[{
Cell["GammaMatrices", "ObjectName",
 CellID->1911468451,ExpressionUUID->"6acf6b8d-e94b-46dc-8959-866210e65033"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"GammaMatrices", "[", "n", "]"}]], "InlineFormula",ExpressionUUID->
  "ed640b13-f16d-46e9-966e-7819b6d538c5"],
 "\[LineSeparator]returns the n Euclidean gamma matrices of dimension ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", 
    RowBox[{"\[LeftFloor]", " ", "n", "/", "2", " ", "\[RightFloor]"}]], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "f6cd2e96-192a-4446-9792-ef97b7636554"],
 " (equivalent to EuclideanGammaMatrices[n]).\n",
 Cell[BoxData[
  RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]], "InlineFormula",
  ExpressionUUID->"b5ddfbc2-a8fe-41e8-8b53-46b081b9a456"],
 "\[LineSeparator]returns gamma matrices satisfying the Clifford relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[Gamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Eta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"6f4702b6-86a8-4a6d-b443-cfb409d720a1"],
 " for any real symmetric metric ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "82091d1a-e8e7-44a7-a9c4-affe3410b21b"],
 "; for a flat signed-diagonal metric the result is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["i", "MR"], " ", "\[ThinSpace]", " ", 
    SuperscriptBox["\[CapitalGamma]", "\[Mu]"]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"a0d928c3-6538-4e4b-89cb-a0367ed58dfa"],
 " on time-like indices and ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"ed4253c9-292c-4ea2-ad85-11f009926d6d"],
 " on space-like indices; for a general metric a vielbein decomposition is \
used."
}], "Usage",
 CellChangeTimes->{{3.987525188220747*^9, 3.987525198298839*^9}},
 CellID->373034705,ExpressionUUID->"d410da41-1f76-418b-a055-d147705ac319"],

Cell[TextData[{
 "The Clifford anticommutation relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[Gamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Eta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"e148ab33-e98e-4248-9e4d-49de2dbf6486"],
 " is satisfied for any real symmetric metric ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "1c8258d0-1c95-45ec-8e10-571f1154cbc1"],
 ", including non-flat curved metrics."
}], "Notes",
 CellID->753940963,ExpressionUUID->"e937f04b-b599-40bb-8757-cb8df915e31f"],

Cell[TextData[{
 "Three call signatures are recognised: an integer (Euclidean case), a \
signed-diagonal metric ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["diag", "MR"], "(", "\[PlusMinus]", " ", "1", ",", "\[Ellipsis]",
     ")"}], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "1b583606-56b0-4c23-aee0-e4d48defd88c"],
 " (flat case with explicit ",
 Cell[BoxData[
  FormBox[
   StyleBox["i", "MR"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "c44d5fa6-3ab7-4e07-83cd-e6dd47c98739"],
 " on time-like indices), and a general real symmetric matrix (uses \
MetricVielbein to pull back the flat-space \[CapitalGamma] matrices into the \
curved frame)."
}], "Notes",
 CellID->738953165,ExpressionUUID->"eb62d4f5-d26d-4422-88e9-770110f11f6a"],

Cell["\<\
The result is in the Brauer-Weyl basis. Use ToDiracBasis or ToWeylBasis to \
transform to the Dirac or Weyl/chiral basis.\
\>", "Notes",
 CellID->1382496451,ExpressionUUID->"b71386a2-3466-4edc-af10-7c9878043d37"],

Cell[TextData[{
 "Inputs must satisfy SymmetricMatrixQ[\[Eta], Tolerance -> ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "9c0639e1-4a2c-413e-945a-52fc7bd8b958"],
 "]."
}], "Notes",
 CellID->1476303496,ExpressionUUID->"5c255141-51cf-4c01-851f-60fe751a4d01"]
}, Open  ]],

