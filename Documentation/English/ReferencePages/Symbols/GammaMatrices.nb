   RowBox[{"FlatMetric", "[", 
    RowBox[{"1", ",", " ", "3"}], "]"}], "]"}], " ", "//", " ", 
  RowBox[{"Map", "[", "MatrixForm", "]"}]}]], "Input",
 CellID->1338170334,ExpressionUUID->"0ffd6dca-ba72-4048-98b1-87845583c6aa"],

