Cell["Diagonal non-flat metrics", "ExampleSubsection",
 CellID->1286677166, ExpressionUUID->"7c7bf0ab-2736-40b9-a591-12707120ff3e"],

Cell[TextData[{"Schwarzschild components on the equatorial plane at ", Cell[BoxData[FormBox[
  RowBox[{"r", "=", "3", " ", "M"}],
  TraditionalForm
]], "InlineFormula"], ", ", Cell[BoxData[FormBox[
