Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Eta]", " ", "=", " ", 
          RowBox[{"FlatMetric", "[", 
           RowBox[{"p", ",", " ", 
            RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], ",", " ", 
         "\[Gamma]"}], "}"}], ",", "\n", "    ", 
       RowBox[{
        RowBox[{"\[Gamma]", " ", "=", " ", 
         RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "    ", 
        RowBox[{
         RowBox[{"Outer", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
             RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
           "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "==",
          " ", "\n", "      ", 
         RowBox[{"2", " ", 
          RowBox[{"TensorProduct", "[", 
           RowBox[{"\[Eta]", ",", " ", 
            RowBox[{"IdentityMatrix", "[", 
             RowBox[{"2", "^", 
              RowBox[{"Floor", "[", 
               RowBox[{"n", "/", "2"}], "]"}]}], "]"}]}], "]"}]}]}]}]}], 
      "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
