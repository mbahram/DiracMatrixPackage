Cell[CellGroupData[{

Cell["Chirality operator in even dimension", "ExampleSubsection",
 CellID->854144097,ExpressionUUID->"78986945-386e-42f5-bd80-63394012f86b"],

Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Gamma]", "c"], "=", 
    SuperscriptBox[
     StyleBox["i", "MR"], 
     RowBox[{"(", "n", "-", "2", " ", "p", ")", "/", "2"}]], " ", 
    "\[ThinSpace]", " ", 
    SuperscriptBox["\[Gamma]", "0"], " ", 
    SuperscriptBox["\[Gamma]", "1"], " ", "\[CenterEllipsis]", " ", 
    SuperscriptBox["\[Gamma]", 
     RowBox[{"n", "-", "1"}]]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"1e075bd1-8059-4184-982b-7b24374468c5"],
 " is Hermitian, squares to the identity, and anticommutes with every \
\[Gamma]:"
}], "ExampleText",
 CellID->405330878,ExpressionUUID->"6be6cb59-3da6-496a-abdd-09aed6813d6a"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", " ", "=", " ", "4"}], ",", " ", 
     RowBox[{"p", " ", "=", " ", "1"}], ",", " ", "\[CapitalGamma]", ",", " ",
      "\[CapitalGamma]c"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"\[CapitalGamma]", "  ", "=", " ", 
     RowBox[{"GammaMatrices", "[", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"p", ",", " ", 
        RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ";", "\n", "  ", 
    
    RowBox[{"\[CapitalGamma]c", " ", "=", " ", 
     RowBox[{
      RowBox[{"I", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", " ", "-", " ", 
           RowBox[{"2", " ", "p"}]}], ")"}], "/", "2"}], ")"}]}], " ", 
      RowBox[{"Dot", " ", "@@", " ", "\[CapitalGamma]"}]}]}], ";", "\n", "  ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"HermitianMatrixQ", "[", "\[CapitalGamma]c", "]"}], ",", "\n", 
      "   ", 
      RowBox[{
       RowBox[{"\[CapitalGamma]c", " ", ".", " ", "\[CapitalGamma]c"}], " ", "==",
        " ", 
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"2", "^", 
         RowBox[{"Floor", "[", 
          RowBox[{"n", "/", "2"}], "]"}]}], "]"}]}]}], "}"}]}]}], 
  "]"}]], "Input",
 CellID->142328987,ExpressionUUID->"1051749e-9ac9-4230-bfd7-f0fe3af26533"],

