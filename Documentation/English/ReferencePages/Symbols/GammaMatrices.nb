Cell["\<\
A random real symmetric metric is handled via the vielbein decomposition; the \
Clifford relation holds within numerical tolerance:\
\>", "ExampleText",
 CellID->1918602442,ExpressionUUID->"788d4ec6-d4de-45be-bd09-7223946e2165"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", ",", " ", "\[Gamma]"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"2", ",", " ", "2", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ";",
     "\n", "  ", 
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"NumericZeroQ", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Outer", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
          RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
        "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "-", 
      " ", "\n", "      ", 
      RowBox[{"2", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"\[Eta]", ",", " ", 
         RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}], "]"}]}]}], 
  "]"}]}], "Input",
 CellID->135892483,ExpressionUUID->"2e20616b-94f1-426f-8f01-c31e3011ab0f"],

Cell[BoxData["True"], "Output",
 CellID->53011097,ExpressionUUID->"c55ce426-a1f5-49e3-b4ce-432a091da796"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

