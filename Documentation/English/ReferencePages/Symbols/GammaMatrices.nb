Cell["Verify the Clifford anticommutation relation:", "ExampleText",
 CellID->229196106,ExpressionUUID->"32ddb031-6555-473f-b2e5-8fe22c821674"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"1", ",", " ", "3"}], "]"}]}], ",", " ", "\[Gamma]"}], "}"}], ",",
    "\n", "  ", 
   RowBox[{
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
         RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
       "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "==", 
     " ", "\n", "    ", 
     RowBox[{"2", " ", 
      RowBox[{"TensorProduct", "[", 
       RowBox[{"\[Eta]", ",", " ", 
        RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}]}]}], 
  "]"}]], "Input",
 CellID->1071576873,ExpressionUUID->"fef0498f-8f69-44e4-8c5f-f248b347cc42"],

Cell[BoxData["True"], "Output",
 CellID->809719558,ExpressionUUID->"9e4a04f9-9e65-4ccd-8943-aca4824a3ca9"]
}, Open  ]]
}, Open  ]],

