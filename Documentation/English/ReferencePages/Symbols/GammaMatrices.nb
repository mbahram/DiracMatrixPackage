Cell["The four-dimensional Minkowski (1, 3) gamma matrices:", "ExampleText",
 CellID->1165813671,ExpressionUUID->"d5ed070e-71ff-4472-98b1-e0de1de8a581"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
