Cell["A non-numeric symbolic 2x2 metric does not produce a usable Eigensystem and the construction hangs in recursive evaluation. Always provide a numeric (or exact rational) metric; if your metric is symbolic, substitute numeric values for the parameters before passing it to GammaMatrices. Below we show the safe approach by substituting a, b, c with concrete numerical values:", "ExampleText",
 CellID->1071719734, ExpressionUUID->"a7451c40-34c0-4424-8ee6-bba86855fcc7"],

Cell[CellGroupData[{

Cell[BoxData[RowBox[{RowBox[{"GammaMatrices", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"a", ",", " ", "b"}], "}"}], ",", " ", RowBox[{"{", RowBox[{"b", ",", " ", "c"}], "}"}]}], "}"}], " ", "/.", " ", RowBox[{"{", RowBox[{RowBox[{"a", " ", "->", " ", "1"}], ",", " ", RowBox[{"b", " ", "->", " ", "0"}], ",", " ", RowBox[{"c", " ", "->", " ", RowBox[{"-", "1"}]}]}], "}"}]}], "]"}], " ", "//", " ", RowBox[{"Map", "[", "MatrixForm", "]"}]}]], "Input",
 CellID->1413873461, ExpressionUUID->"5a43210d-d603-46f4-9baf-f3fee8040ce8"],

Cell[BoxData[RowBox[{"{", RowBox[{TagBox[RowBox[{"(", "\[NoBreak]", GridBox[{{"0", "1"}, {"1", "0"}}, RowSpacings -> 1, ColumnSpacings -> 1, RowAlignments -> Baseline, ColumnAlignments -> Center], "\[NoBreak]", ")"}], Function[BoxForm`e$, MatrixForm[BoxForm`e$]]], ",", TagBox[RowBox[{"(", "\[NoBreak]", GridBox[{{"0", "1"}, {RowBox[{"-", "1"}], "0"}}, RowSpacings -> 1, ColumnSpacings -> 1, RowAlignments -> Baseline, ColumnAlignments -> Center], "\[NoBreak]", ")"}], Function[BoxForm`e$, MatrixForm[BoxForm`e$]]]}], "}"}]], "Output",
 CellID->772564794, ExpressionUUID->"087d7145-04f5-4a65-879d-d7744e7e3a79"]
}, Open  ]]
}, Open  ]],

