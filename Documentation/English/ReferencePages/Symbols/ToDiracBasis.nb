Cell[TextData[{
 "The standard Dirac matrices in dimension 4: ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Gamma]", "0"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"da903e64-9190-4ba3-8101-811fb70bf024"],
 " is diagonal ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["diag", "MR"], "(", "1", ",", "1", ",", "-", "1", ",", "-", "1", 
    ")"}], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "5c243381-ee8b-4685-ac75-65912448a458"],
 ":"
}], "ExampleText",
 CellID->2064367655,ExpressionUUID->"1c2d9da5-06a9-4400-80af-4d65bc74164b"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"ToDiracBasis", "[", 
