    RowBox[{"FlatMetric", "[", 
     RowBox[{"1", ",", " ", "3"}], "]"}], "]"}], "]"}], " ", "//", " ", 
  RowBox[{"Map", "[", "MatrixForm", "]"}]}]], "Input",
 CellID->1057623977,ExpressionUUID->"626f133a-5c27-4e20-b9bc-6d70255f4b3e"],

