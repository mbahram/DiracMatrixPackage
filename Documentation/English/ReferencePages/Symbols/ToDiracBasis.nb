Cell["The Clifford relation is preserved by the basis change:", "ExampleText",
 CellID->1907032240,ExpressionUUID->"4b129800-50f8-45e6-9303-074abf966eff"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"1", ",", " ", "3"}], "]"}]}], ",", " ", "\[Gamma]"}], "}"}], ",",
    "\n", "  ", 
   RowBox[{
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"ToDiracBasis", " ", "@", " ", 
      RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
         RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
       "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "==", 
     " ", "\n", "    ", 
     RowBox[{"2", " ", 
      RowBox[{"TensorProduct", "[", 
       RowBox[{"\[Eta]", ",", " ", 
        RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}]}]}], 
  "]"}]], "Input",
 CellID->419543837,ExpressionUUID->"4418dc3a-4510-48d1-be85-d9ad786e0f97"],

Cell[BoxData["True"], "Output",
 CellID->273708467,ExpressionUUID->"8286b750-374f-4d8e-b87e-eb9124645847"]
}, Open  ]]
}, Open  ]],

