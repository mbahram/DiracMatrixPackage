Notebook[{

Cell[CellGroupData[{
Cell["ToDiracBasis", "ObjectName",
 CellID->1790734718, ExpressionUUID->"4bed612e-72b4-47ad-a7cf-90c45c860c0c"],
Cell[TextData[{
Cell[BoxData[RowBox[{"ToDiracBasis", "[", "\[Gamma]", "]"}]], "InlineFormula",
 ExpressionUUID->"eb83860f-f04e-43ec-8b56-f5fe91f011da"], "\[LineSeparator]takes a list of gamma matrices in the Brauer-Weyl basis and returns them in the Dirac basis (where ", Cell[BoxData[FormBox[
  SuperscriptBox["\[Gamma]", "0"],
  TraditionalForm
]], "InlineFormula"], " is diagonal)."
}], "Usage",
 CellID->1182664638, ExpressionUUID->"fb5ef18f-2a84-476e-bbf9-1e6c424ea4e2"],
Cell[TextData[{"The transform is the similarity ", Cell[BoxData[FormBox[
  RowBox[{SuperscriptBox["\[Gamma]", "\[Mu]"], "\[RightArrow]", SuperscriptBox["S", RowBox[{"-", "1"}]], " ", SuperscriptBox["\[Gamma]", "\[Mu]"], " ", "S"}],
  TraditionalForm
]], "InlineFormula"], ", where ", Cell[BoxData[FormBox[
  "S",
  TraditionalForm
]], "InlineFormula"], " is built from the eigenvectors of ", Cell[BoxData[FormBox[
  SuperscriptBox["\[Gamma]", "0"],
  TraditionalForm
]], "InlineFormula"], " reordered so the imaginary eigenvalues with ", Cell[BoxData[FormBox[
  RowBox[{StyleBox["Im", "MR"], ">", "0"}],
  TraditionalForm
]], "InlineFormula"], " come first (mostly-plus convention)."}], "Notes",
 CellID->606637287, ExpressionUUID->"54f22c27-1f19-461c-ab6e-60afcde44283"],
Cell["Since the transform is a similarity, all Clifford-algebra identities (anticommutator, traces, contractions) are preserved.", "Notes",
 CellID->332032168, ExpressionUUID->"5ad26b56-c2e0-4789-ad4f-dc85fb82e70a"],
Cell[TextData[{"Use this for example to obtain the textbook Dirac matrices with diagonal ", Cell[BoxData[FormBox[
  SuperscriptBox["\[Gamma]", "0"],
  TraditionalForm
]], "InlineFormula"], " on the (1, 3) signature."}], "Notes",
 CellID->1968313742, ExpressionUUID->"af4bd35f-f25d-4de1-9b44-0080bc1290d7"]
}, Open]],

