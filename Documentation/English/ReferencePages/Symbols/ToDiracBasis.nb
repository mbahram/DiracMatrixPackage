Cell[CellGroupData[{

Cell["\<\
Round-trip: Dirac \[RightArrow] Brauer-Weyl is invertible by another \
similarity\
\>", "ExampleSubsection",
 CellID->1917273707,ExpressionUUID->"ed75658a-bf8b-4b76-970b-a78707df853c"],

Cell["\<\
The function is a similarity transform; applying another similarity that \
diagonalises the result's first matrix in the Brauer-Weyl-ordered eigensystem \
returns the original up to a unitary rotation. The simplest check is that \
both bases share the same anticommutator structure:\
\>", "ExampleText",
 CellID->1107934855,ExpressionUUID->"652ed87f-5c88-418d-8270-6fa98e72a2b3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"bw", ",", " ", "dirac", ",", " ", 
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"1", ",", " ", "3"}], "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"bw", " ", "=", " ", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"dirac", " ", "=", " ", 
     RowBox[{"ToDiracBasis", "[", "bw", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
         RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", "bw", ",",
        " ", "bw", ",", " ", "1"}], "]"}], " ", "===", " ", "\n", "    ", 
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
         RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", "dirac",
        ",", " ", "dirac", ",", " ", "1"}], "]"}]}]}]}], "]"}]], "Input",
 CellID->975641058,ExpressionUUID->"f507201f-12df-4640-bdbb-28c5c13b4a99"],

Cell[BoxData["True"], "Output",
 CellID->172022029,ExpressionUUID->"e95da761-1e63-47e9-9a06-c65f91e61a6e"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

