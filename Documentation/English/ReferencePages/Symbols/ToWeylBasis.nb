Notebook[{

Cell[CellGroupData[{
Cell["ToWeylBasis", "ObjectName",
 CellID->1854827923,ExpressionUUID->"a2e1463f-2e3a-4f2c-a1a6-5a58b1791393"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"ToWeylBasis", "[", "\[Gamma]", "]"}]], "InlineFormula",
  ExpressionUUID->"8d04922e-cbdf-4cd3-aa4c-d7a3b594a5bc"],
 "\[LineSeparator]takes a list of gamma matrices in the Brauer-Weyl basis and \
returns them in the Weyl/chiral basis, in which the chirality operator is \
block-diagonal. For odd dimension there is no chiral decomposition and the \
Dirac basis is returned along with a ToWeylBasis::oddDim message."
}], "Usage",
 CellID->1075869774,ExpressionUUID->"dbbe7106-d9df-40b3-8f6e-536777e3df0b"],

Cell[TextData[{
 "The Weyl/chiral basis is produced by first applying ToDiracBasis and then a \
final block-rotation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "=", 
    FractionBox["1", 
     SqrtBox["2"]], " ", "\[ThinSpace]", "(", 
    SubscriptBox["\[Sigma]", "x"], " ", "\[CircleTimes]", " ", 
    SubscriptBox[
     StyleBox["I",
      FontFamily->"DoubleStruck"], 
     RowBox[{"n", "/", "2"}]], ")"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"0e76f225-92ca-4341-afad-ce43a3e7b729"],
 " that pairs the upper and lower components."
}], "Notes",
 CellID->2086077606,ExpressionUUID->"fa15059e-212f-4056-992d-e288208acf16"],

Cell["\<\
All Clifford-algebra identities are preserved under the basis change.\
\>", "Notes",
 CellID->93979076,ExpressionUUID->"4ba827a6-61ea-4eda-b0f6-d4ed6c383e41"],

Cell["\<\
For odd dimension the function emits ToWeylBasis::oddDim and falls back to \
the Dirac basis \[LongDash] there is no genuine Weyl decomposition in odd \
dimension.\
\>", "Notes",
 CellID->2050109612,ExpressionUUID->"1022f903-4d0c-4253-b0c4-531ba78ed5f0"]
}, Open  ]],

