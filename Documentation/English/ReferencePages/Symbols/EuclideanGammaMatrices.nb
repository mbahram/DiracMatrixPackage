Notebook[{

Cell[CellGroupData[{
Cell["EuclideanGammaMatrices", "ObjectName",
 CellID->2131975744, ExpressionUUID->"0bd07e15-ebfb-4e77-9373-346e71117af4"],
Cell[TextData[{
Cell[BoxData[RowBox[{"EuclideanGammaMatrices", "[", "n", "]"}]], "InlineFormula",
 ExpressionUUID->"46c58140-ccea-42ec-be7e-304e62e13edd"], "\[LineSeparator]returns the n Euclidean gamma matrices of dimension ", Cell[BoxData[FormBox[
  SuperscriptBox["2", RowBox[{"\[LeftFloor]", " ", "n", "/", "2", " ", "\[RightFloor]"}]],
  TraditionalForm
]], "InlineFormula"], " in the Brauer-Weyl (Pauli-Kronecker) representation."
}], "Usage",
 CellID->13913766, ExpressionUUID->"31ee4d91-ec51-4e3b-9d33-e6a9931029ca"],
Cell[TextData[{"For even ", Cell[BoxData[FormBox[
  RowBox[{"n", "=", "2", " ", "m"}],
  TraditionalForm
]], "InlineFormula"], ", the construction is ", Cell[BoxData[FormBox[
  RowBox[{SuperscriptBox["\[CapitalGamma]", RowBox[{"2", " ", "k", "-", "1"}]], "=", SuperscriptBox[StyleBox["I", FontFamily->"DoubleStruck"], RowBox[{"\[CircleTimes]", "(", "k", "-", "1", ")"}]], " ", "\[CircleTimes]", " ", SubscriptBox["\[Sigma]", "1"], " ", "\[CircleTimes]", " ", SubsuperscriptBox["\[Sigma]", "3", RowBox[{"\[CircleTimes]", "(", "m", "-", "k", ")"}]]}],
  TraditionalForm
]], "InlineFormula"], " and ", Cell[BoxData[FormBox[
  RowBox[{SuperscriptBox["\[CapitalGamma]", RowBox[{"2", " ", "k"}]], "=", SuperscriptBox[StyleBox["I", FontFamily->"DoubleStruck"], RowBox[{"\[CircleTimes]", "(", "k", "-", "1", ")"}]], " ", "\[CircleTimes]", " ", SubscriptBox["\[Sigma]", "2"], " ", "\[CircleTimes]", " ", SubsuperscriptBox["\[Sigma]", "3", RowBox[{"\[CircleTimes]", "(", "m", "-", "k", ")"}]]}],
  TraditionalForm
]], "InlineFormula"], " for ", Cell[BoxData[FormBox[
  RowBox[{"k", "=", "1", ",", "\[Ellipsis]", ",", "m"}],
  TraditionalForm
]], "InlineFormula"], ". For odd ", Cell[BoxData[FormBox[
  RowBox[{"n", "=", "2", " ", "m", "+", "1"}],
  TraditionalForm
]], "InlineFormula"], ", an additional ", Cell[BoxData[FormBox[
  RowBox[{SuperscriptBox["\[CapitalGamma]", RowBox[{"2", " ", "m", "+", "1"}]], "=", SubsuperscriptBox["\[Sigma]", "3", RowBox[{"\[CircleTimes]", " ", "m"}]]}],
  TraditionalForm
]], "InlineFormula"], " is appended."}], "Notes",
 CellID->302387906, ExpressionUUID->"6cb32913-2a5a-4e6f-a692-c22e73f2b9a3"],
Cell[TextData[{"The returned matrices satisfy the Euclidean Clifford relation ", Cell[BoxData[FormBox[
  RowBox[{"{", " ", SuperscriptBox["\[CapitalGamma]", "\[Mu]"], ",", SuperscriptBox["\[CapitalGamma]", "\[Nu]"], " ", "}", "=", "2", " ", SuperscriptBox["\[Delta]", RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", StyleBox["I", FontFamily->"DoubleStruck"]}],
  TraditionalForm
]], "InlineFormula"], ". For other signatures use GammaMatrices."}], "Notes",
 CellID->400310068, ExpressionUUID->"a2de3896-30db-41df-8c83-dc7ec358a74d"],
Cell["Special cases n = 1, 2, 3 are handled by explicit base cases using PauliMatrix.", "Notes",
 CellID->914096972, ExpressionUUID->"83e6e340-ef24-46bf-ae67-173fcdec5d49"]
}, Open]],

