Notebook[{

Cell[CellGroupData[{
Cell["EuclideanGammaMatrices", "ObjectName",
 CellID->2131975744,ExpressionUUID->"0bd07e15-ebfb-4e77-9373-346e71117af4"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"EuclideanGammaMatrices", "[", "n", "]"}]], "InlineFormula",
  ExpressionUUID->"46c58140-ccea-42ec-be7e-304e62e13edd"],
 "\[LineSeparator]returns the n Euclidean gamma matrices of dimension ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", 
    RowBox[{"\[LeftFloor]", " ", "n", "/", "2", " ", "\[RightFloor]"}]], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "b50b40dc-0b48-4908-a468-332677833501"],
 " in the Brauer-Weyl (Pauli-Kronecker) representation."
}], "Usage",
 CellID->13913766,ExpressionUUID->"31ee4d91-ec51-4e3b-9d33-e6a9931029ca"],

Cell[TextData[{
 "For even ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "2", " ", "m"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"3e0b11e0-0d79-4638-8909-67f86f100d73"],
 ", the construction is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "k", "-", "1"}]], "=", 
    SuperscriptBox[
     StyleBox["I",
      FontFamily->"DoubleStruck"], 
     RowBox[{"\[CircleTimes]", "(", "k", "-", "1", ")"}]], " ", "\[CircleTimes]",
     " ", 
    SubscriptBox["\[Sigma]", "1"], " ", "\[CircleTimes]", " ", 
    SubsuperscriptBox["\[Sigma]", "3", 
     RowBox[{"\[CircleTimes]", "(", "m", "-", "k", ")"}]]}], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "58a94681-34b7-4167-9071-a7af3911eef3"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "k"}]], "=", 
    SuperscriptBox[
     StyleBox["I",
      FontFamily->"DoubleStruck"], 
     RowBox[{"\[CircleTimes]", "(", "k", "-", "1", ")"}]], " ", "\[CircleTimes]",
     " ", 
    SubscriptBox["\[Sigma]", "2"], " ", "\[CircleTimes]", " ", 
    SubsuperscriptBox["\[Sigma]", "3", 
     RowBox[{"\[CircleTimes]", "(", "m", "-", "k", ")"}]]}], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "de518bd1-1287-4409-970c-873f58018345"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "=", "1", ",", "\[Ellipsis]", ",", "m"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"481ef4ba-4fd7-49e7-96d5-20c98a4c7372"],
 ". For odd ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "2", " ", "m", "+", "1"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"a44a8343-f208-4c13-b7f5-534da364eb1d"],
 ", an additional ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "m", "+", "1"}]], "=", 
    SubsuperscriptBox["\[Sigma]", "3", 
     RowBox[{"\[CircleTimes]", " ", "m"}]]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"7cad9adb-e750-4fac-9410-ddb1c3d0be2d"],
 " is appended."
}], "Notes",
 CellID->302387906,ExpressionUUID->"6cb32913-2a5a-4e6f-a692-c22e73f2b9a3"],

Cell[TextData[{
 "The returned matrices satisfy the Euclidean Clifford relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[CapitalGamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[CapitalGamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Delta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"9598fb5c-3a82-47d5-8d77-1e6c27ab63be"],
 ". For other signatures use GammaMatrices."
}], "Notes",
 CellID->400310068,ExpressionUUID->"a2de3896-30db-41df-8c83-dc7ec358a74d"],

Cell["\<\
Special cases n = 1, 2, 3 are handled by explicit base cases using \
PauliMatrix.\
\>", "Notes",
 CellID->914096972,ExpressionUUID->"83e6e340-ef24-46bf-ae67-173fcdec5d49"]
}, Open  ]],

