Cell[TextData[{
 "Verify the Euclidean Clifford relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[CapitalGamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[CapitalGamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Delta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"23df3412-4fe0-42c5-911b-8698df34f41f"],
 " in dimension 4:"
}], "ExampleText",
 CellID->1582498561,ExpressionUUID->"7f6add7d-f38c-4b8f-b1d2-ebe47f712024"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[CapitalGamma]", " ", "=", " ", 
     RowBox[{"EuclideanGammaMatrices", "[", "4", "]"}]}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
        RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
      "\[CapitalGamma]", ",", " ", "\[CapitalGamma]", ",", " ", "1"}], "]"}], 
    " ", "==", " ", "\n", "    ", 
    RowBox[{"2", " ", 
     RowBox[{"TensorProduct", "[", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "4", "]"}], ",", " ", 
       RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellID->656532056,ExpressionUUID->"882520fe-e7ae-43d1-9eed-d0478ffcfb06"],

Cell[BoxData["True"], "Output",
 CellID->382805143,ExpressionUUID->"79a82de5-8b1f-4bfd-a514-51f1387f60f7"]
}, Open  ]]
}, Open  ]],

