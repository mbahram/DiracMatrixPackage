Cell["Building block for GammaMatrices on flat metrics", "ExampleSubsection",
 CellID->755362757, ExpressionUUID->"8fb0f312-b523-433e-a9a7-fa74fb0a1650"],
Cell[TextData[{"For a flat signature ", Cell[BoxData[FormBox[
  RowBox[{"(", "p", ",", "q", ")"}],
  TraditionalForm
]], "InlineFormula"], ", GammaMatrices multiplies the Euclidean Γ matrices by ", Cell[BoxData[FormBox[
  StyleBox["i", "MR"],
  TraditionalForm
]], "InlineFormula"], " on time-like indices:"}], "ExampleText",
 CellID->847483819, ExpressionUUID->"921da2f9-3d17-4e81-950d-eb1a6be59c5e"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{RowBox[{"GammaMatrices", "[", RowBox[{"FlatMetric", "[", RowBox[{"1", ",", " ", "3"}], "]"}], "]"}], " ", "===", " ", "\n", "  ", RowBox[{RowBox[{"Diagonal", "[", RowBox[{RowBox[{"FlatMetric", "[", RowBox[{"1", ",", " ", "3"}], "]"}], " ", "/.", " ", RowBox[{"{", RowBox[{RowBox[{"-", "1"}], " ", "->", " ", "I"}], "}"}]}], "]"}], " ", "*", " ", RowBox[{"EuclideanGammaMatrices", "[", "4", "]"}]}]}]], "Input",
 CellID->1633960629, ExpressionUUID->"e5380db9-a371-4ae7-979c-70ea1443a919"],
Cell[BoxData["True"], "Output",
 CellID->287829232, ExpressionUUID->"0bdf1321-cae9-49fd-a482-29f9d39e48da"]
}, Open]],
