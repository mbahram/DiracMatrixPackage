Cell[TextData[{"The dimension count follows the rule ", Cell[BoxData[FormBox[
  SuperscriptBox["2", RowBox[{"\[LeftFloor]", " ", "n", "/", "2", " ", "\[RightFloor]"}]],
  TraditionalForm
]], "InlineFormula"], " for any n:"}], "ExampleText",
 CellID->111237719, ExpressionUUID->"d7889667-a4b4-4c7b-aad8-35359414dd2f"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{RowBox[{"Table", "[", "\n", "  ", RowBox[{RowBox[{RowBox[{RowBox[{"Length", " ", "@", " ", RowBox[{"EuclideanGammaMatrices", "[", "n", "]"}]}], " ", "==", " ", "n"}], " ", "&&", " ", RowBox[{RowBox[{"First", " ", "@", " ", RowBox[{"Dimensions", " ", "@", " ", RowBox[{"First", " ", "@", " ", RowBox[{"EuclideanGammaMatrices", "[", "n", "]"}]}]}]}], " ", "==", " ", RowBox[{"2", "^", RowBox[{"Floor", "[", RowBox[{"n", "/", "2"}], "]"}]}]}]}], ",", "\n", "  ", RowBox[{"{", RowBox[{"n", ",", " ", "1", ",", " ", "8"}], "}"}]}], "]"}], " ", "//", " ", RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellID->1525505484, ExpressionUUID->"88bf4526-ec13-43be-9411-c2cddce2571b"],
