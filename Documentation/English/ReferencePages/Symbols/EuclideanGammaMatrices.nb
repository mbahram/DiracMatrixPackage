Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[Cell[
  "Neat Examples", "ExampleSection",ExpressionUUID->
   "d892f47e-e47f-4cff-b961-9aec80d91479"],
  $Line = 0; Null]], "ExampleSection",
 CellID->133491128,ExpressionUUID->"ad9afc10-564b-4016-b9ef-43a122509866"],

Cell[TextData[{
 "The chirality operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "m", "+", "1"}]], "=", 
    SuperscriptBox["\[CapitalGamma]", "1"], " ", 
    SuperscriptBox["\[CapitalGamma]", "2"], " ", "\[CenterEllipsis]", " ", 
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "m"}]]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"eb65e49e-c7b7-44f0-88fc-2a9a27b938eb"],
 " in even dimension equals the last basis element of the odd-dimensional \
construction:"
}], "ExampleText",
 CellID->1899443217,ExpressionUUID->"5ffdb4e4-c7cb-45c6-bd1b-d3c77879feaf"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", " ", "=", " ", "3"}], ",", " ", "even", ",", " ", "odd"}], 
    "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"even", " ", "=", " ", 
     RowBox[{"EuclideanGammaMatrices", "[", 
      RowBox[{"2", " ", "m"}], "]"}]}], ";", "\n", "  ", 
    RowBox[{"odd", "  ", "=", " ", 
     RowBox[{"EuclideanGammaMatrices", "[", 
      RowBox[{
       RowBox[{"2", " ", "m"}], " ", "+", " ", "1"}], "]"}]}], ";", "\n", 
    "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"I", "^", "m"}], " ", 
      RowBox[{"Dot", " ", "@@", " ", "even"}]}], " ", "==", " ", 
     RowBox[{"Last", "[", "odd", "]"}]}]}]}], "]"}]], "Input",
 CellID->755355542,ExpressionUUID->"e411562a-9e60-46ba-929c-0c233eec9f65"],

Cell[BoxData["False"], "Output",
 CellID->537703543,ExpressionUUID->"9947cb86-5964-4a5e-8f4f-877b109c4582"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

