Cell[CellGroupData[{

Cell["Agreement with CliffordCanonicalBasis on flat metrics", \
"ExampleSubsection",
 CellID->1517739832,ExpressionUUID->"f1a1d6f4-9854-440a-bbdd-3423a48dbed2"],

Cell["\<\
The two implementations produce the same basis at every grade on flat metrics:\
\>", "ExampleText",
 CellID->439734258,ExpressionUUID->"aa86292c-d4af-4450-9b17-287eb1e77f70"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"CliffordBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}], " ", "===", " ", 
      "\n", "    ", 
      RowBox[{"CliffordCanonicalBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "5"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellID->1966108165,ExpressionUUID->"259a59c3-116d-4a35-88fc-f16cafde4461"],

Cell[BoxData["True"], "Output",
 CellID->218645348,ExpressionUUID->"1394ee8d-70f0-4ddb-8a50-c0ce434dd650"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Numerical stability for curved metrics", "ExampleSubsection",
 CellID->1001025705,ExpressionUUID->"4dc6b07c-0bc4-40c3-9a87-a6cb391c23ce"],

Cell["\<\
At low grade, CliffordBasis and CliffordCanonicalBasis agree on a random \
curved metric:\
\>", "ExampleText",
 CellID->463889840,ExpressionUUID->"5c754bb7-be74-4d50-8f87-d9e4be43bd7f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"3", ",", " ", "3"}], "]"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"NumericZeroQ", "[", "\n", "    ", 
    RowBox[{
     RowBox[{
      RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}], "[", 
      RowBox[{"[", 
       RowBox[{";;", " ", "3"}], "]"}], "]"}], " ", "-", " ", "\n", "    ", 
     RowBox[{
      RowBox[{"CliffordBasis", "[", "\[Eta]", "]"}], "[", 
      RowBox[{"[", 
       RowBox[{";;", " ", "3"}], "]"}], "]"}]}], "]"}]}], "]"}]}], "Input",
 CellID->2134448630,ExpressionUUID->"c1ceae88-4b81-42f9-801a-a1e6ca69ecd4"],

Cell[BoxData["True"], "Output",
 CellID->1371694318,ExpressionUUID->"abe3a50e-3a00-446a-8152-338183d91396"]
}, Open  ]]
}, Open  ]],

