Notebook[{

Cell[CellGroupData[{
Cell["CliffordBasis", "ObjectName",
 CellID->1984350833,ExpressionUUID->"d1bf4bee-3b31-4c9b-a126-b9776da3fe78"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"CliffordBasis", "[", "\[Eta]", "]"}]], "InlineFormula",
  ExpressionUUID->"2d583421-b198-444f-a819-001f733fc38b"],
 "\[LineSeparator]returns the canonical graded Clifford operator basis \
computed via an antisymmetrised recursion; same shape as \
CliffordCanonicalBasis but much faster and numerically stable."
}], "Usage",
 CellID->1439590348,ExpressionUUID->"c214dbba-64c9-42e5-b96a-985aff465a35"],

Cell[TextData[{
 "The recursion is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{
      StyleBox["I",
       FontFamily->"Script"], " ", "\[Union]", " ", "{", " ", "\[Mu]", " ", 
      "}"}]], "=", 
    SubscriptBox["\[CapitalGamma]", 
     StyleBox["I",
      FontFamily->"Script"]], "\[CenterDot]", 
    SubscriptBox["\[CapitalGamma]", "\[Mu]"], "-", 
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"j", "=", "1"}], 
     RowBox[{"\[VerticalSeparator]", " ", 
      StyleBox["I",
       FontFamily->"Script"], " ", "\[VerticalSeparator]"}]], "(", "-", "1", " ", 
    SuperscriptBox[")", 
     RowBox[{"j", "-", "1"}]], " ", 
    SubscriptBox["\[Eta]", 
     RowBox[{"\[Mu]", ",", 
      SubscriptBox["i", "j"]}]], " ", "\[ThinSpace]", " ", 
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{
      StyleBox["I",
       FontFamily->"Script"], " ", "setminus", " ", "{", " ", 
      SubscriptBox["i", "j"], " ", "}"}]]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"5a6f78b9-9207-426a-8708-44f3a2a3c223"],
 ", building each grade from the previous one without recomputing permutation \
sums."
}], "Notes",
 CellID->1604166617,ExpressionUUID->"e20d93fa-cca4-496e-8c51-a57476489a77"],

Cell[TextData[{
 "CliffordBasis is the production-ready implementation: O(",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"a45ced83-29bc-48ad-805f-4f46899cf360"],
 " n\.b2) operations versus O(",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"de6bb3da-fb4f-42c3-9a94-6f2d024023d7"],
 " n!) for CliffordCanonicalBasis, and numerically stable for curved metrics \
with widely scaled eigenvalues."
}], "Notes",
 CellID->717894389,ExpressionUUID->"6c50023d-9737-44c4-840a-b04f0220e1d0"],

Cell["\<\
On flat metrics it agrees with CliffordCanonicalBasis at every grade.\
\>", "Notes",
 CellID->1939221786,ExpressionUUID->"78f1fd19-f82c-4a42-885a-c4d4a4c46f69"]
}, Open  ]],

