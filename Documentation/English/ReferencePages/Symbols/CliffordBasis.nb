   RowBox[{"FlatMetric", "[", 
    RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}]], "Input",
 CellID->263144154,ExpressionUUID->"9777b6c8-f635-480d-93aa-656fe2b72d4a"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{"1", ",", "4", ",", "6", ",", "4", ",", "1"}], "}"}]], "Output",
 CellID->2118288361,ExpressionUUID->"aa35b3e0-aeab-458c-b3e3-43eedfdc9549"]
}, Open  ]],

Cell["The grade-1 elements are the gamma matrices:", "ExampleText",
 CellID->996142012,ExpressionUUID->"1aa40f33-0ad5-4d0a-94f0-18c3befe0a52"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"CliffordBasis", "[", 
    RowBox[{"FlatMetric", "[", 
     RowBox[{"1", ",", " ", "3"}], "]"}], "]"}], "[", 
   RowBox[{"[", "2", "]"}], "]"}], " ", "===", " ", 
  RowBox[{"GammaMatrices", "[", 
   RowBox[{"FlatMetric", "[", 
    RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}]], "Input",
