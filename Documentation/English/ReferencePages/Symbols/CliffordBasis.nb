Cell[CellGroupData[{

Cell["Grade-2 elements are antisymmetric products", "ExampleSubsection",
 CellID->1986488575,ExpressionUUID->"0196d8a0-d151-4597-9ed1-96a56bf63a20"],

Cell[TextData[{
 "The grade-2 elements satisfy ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], "=", 
    FractionBox["1", "2"], "[", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[Gamma]", "\[Nu]"], "]"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"466edfcf-9cd6-4d53-a91c-3dabaa61ccbf"],
 ":"
}], "ExampleText",
 CellID->791923102,ExpressionUUID->"c9f24a2c-28f4-4b1a-8b1c-351e98a3a370"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Gamma]", " ", "=", " ", 
      RowBox[{"GammaMatrices", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}], ",", " ", 
     "\[CapitalGamma]2"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"\[CapitalGamma]2", " ", "=", " ", 
     RowBox[{
      RowBox[{"CliffordBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"1", ",", " ", "3"}], "]"}], "]"}], "[", 
      RowBox[{"[", "3", "]"}], "]"}]}], ";", "\n", "  ", 
    RowBox[{"\[CapitalGamma]2", " ", "===", " ", 
     RowBox[{"Table", "[", "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Subsets", "[", 
               RowBox[{
                RowBox[{"Range", "[", "4", "]"}], ",", " ", 
                RowBox[{"{", "2", "}"}]}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", " ", "1"}], "]"}], "]"}], "]"}], "]"}], " ", 
           ".", " ", 
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Subsets", "[", 
               RowBox[{
                RowBox[{"Range", "[", "4", "]"}], ",", " ", 
                RowBox[{"{", "2", "}"}]}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", " ", "2"}], "]"}], "]"}], "]"}], "]"}]}], 
          " ", "-", " ", "\n", "     ", 
          RowBox[{
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Subsets", "[", 
               RowBox[{
                RowBox[{"Range", "[", "4", "]"}], ",", " ", 
                RowBox[{"{", "2", "}"}]}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", " ", "2"}], "]"}], "]"}], "]"}], "]"}], " ", 
           ".", " ", 
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Subsets", "[", 
               RowBox[{
                RowBox[{"Range", "[", "4", "]"}], ",", " ", 
                RowBox[{"{", "2", "}"}]}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", " ", "1"}], "]"}], "]"}], "]"}], "]"}]}]}], 
         ")"}], "/", "2"}], ",", "\n", "    ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", " ", "@", " ", 
          RowBox[{"Subsets", "[", 
           RowBox[{
            RowBox[{"Range", "[", "4", "]"}], ",", " ", 
            RowBox[{"{", "2", "}"}]}], "]"}]}]}], "}"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellID->749916917,ExpressionUUID->"dae4a9f6-a52e-4aaa-a4b6-a7d1f3f8fb00"],

Cell[BoxData["True"], "Output",
 CellID->1731475739,ExpressionUUID->"498496f8-7199-476f-a4a8-50921f17341b"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

