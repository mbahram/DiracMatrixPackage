Cell[CellGroupData[{

Cell["Test GammaMatrices against the Clifford relation for random metrics", "ExampleSubsection",
 CellID->158362022, ExpressionUUID->"8d54970c-c0b5-4d71-bfd5-5bc1b87beac3"],

Cell["The vielbein construction in GammaMatrices handles arbitrary symmetric metrics; the Clifford relation still holds within numerical tolerance:", "ExampleText",
 CellID->367015316, ExpressionUUID->"2cd86798-3bd4-48e9-8144-183dac4cf930"],

Cell[CellGroupData[{

Cell[BoxData[{RowBox[{RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", RowBox[{"Module", "[", RowBox[{RowBox[{"{", RowBox[{"\[Eta]", ",", " ", "\[Gamma]"}], "}"}], ",", "\n", "  ", RowBox[{RowBox[{"\[Eta]", " ", "=", " ", RowBox[{"RandomCurvedMetric", "[", RowBox[{"2", ",", " ", "2", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ";", "\n", "  ", RowBox[{"\[Gamma]", " ", "=", " ", RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", RowBox[{"NumericZeroQ", "[", "\n", "    ", RowBox[{RowBox[{"Outer", "[", RowBox[{RowBox[{RowBox[{RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "-", " ", "\n", "      ", RowBox[{"2", " ", RowBox[{"TensorProduct", "[", RowBox[{"\[Eta]", ",", " ", RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}], "]"}]}]}], "]"}]}], "Input",
 CellID->1136776274, ExpressionUUID->"fe497c5c-7e46-4e6a-aac9-cb20087f0ea5"],

Cell[BoxData["True"], "Output",
 CellID->1265801863, ExpressionUUID->"12cd72f6-d1f8-4769-b557-3c6d2879db33"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

