Cell["Default arguments", "ExampleSubsection",
 CellID->926865497, ExpressionUUID->"1df7fffb-8e8a-4332-95fd-b92334a96d12"],

Cell[TextData[{"With only p and q, the default spread ", Cell[BoxData[FormBox[
  RowBox[{"a", "=", "2"}],
  TraditionalForm
]], "InlineFormula"], " produces a more poorly conditioned matrix (κ ~ ", Cell[BoxData[FormBox[
  SuperscriptBox["10", "4"],
  TraditionalForm
]], "InlineFormula"], "):"}], "ExampleText",
 CellID->584073011, ExpressionUUID->"05849175-aa8c-4e9b-8380-120ee5962286"],

Cell[CellGroupData[{

Cell[BoxData[RowBox[{RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", RowBox[{RowBox[{"Chop", " ", "@", " ", RowBox[{"RandomCurvedMetric", "[", RowBox[{"2", ",", " ", "2"}], "]"}]}], " ", "//", " ", "MatrixForm"}]}]], "Input",
 CellID->1264699044, ExpressionUUID->"0f354d0c-d02c-4073-8826-a8cd9048e013"],

Cell[BoxData[TagBox[RowBox[{"(", "\[NoBreak]", GridBox[{{"5.982661317257084`", "0.4295557676669287`", "12.750921483715102`", "4.25576579784643`"}, {"0.4295557676669286`", "0.13765442771201253`", "2.616902685826895`", "1.003895620059409`"}, {"12.750921483715102`", "2.6169026858268953`", "40.46781096890382`", "14.962947333147568`"}, {"4.255765797846429`", "1.0038956200594091`", "14.962947333147566`", "5.493649100147286`"}}, RowSpacings -> 1, ColumnSpacings -> 1, RowAlignments -> Baseline, ColumnAlignments -> Center], "\[NoBreak]", ")"}], Function[BoxForm`e$, MatrixForm[BoxForm`e$]]]], "Output",
 CellID->653654620, ExpressionUUID->"ea81aaac-406b-420e-a616-d5cbe4943856"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Controlling the spread parameter", "ExampleSubsection",
 CellID->979612390, ExpressionUUID->"01b35e52-f4b5-4b65-bd72-60a202bfd6c0"],

Cell[TextData[{"Smaller ", Cell[BoxData[FormBox[
  "a",
  TraditionalForm
]], "InlineFormula"], " means a better-conditioned metric:"}], "ExampleText",
 CellID->1638654143, ExpressionUUID->"d82fa904-4e17-448d-bc3d-45aac0219d27"],

Cell[CellGroupData[{

Cell[BoxData[RowBox[{RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", RowBox[{"Through", " ", "@", " ", RowBox[{RowBox[{"{", RowBox[{"Min", ",", " ", "Max"}], "}"}], " ", "@", " ", RowBox[{"Abs", " ", "@", " ", RowBox[{"Eigenvalues", " ", "@", " ", RowBox[{"RandomCurvedMetric", "[", RowBox[{"3", ",", " ", "3", ",", " ", "0.1"}], "]"}]}]}]}]}]}]], "Input",
 CellID->1623707618, ExpressionUUID->"3e189b13-8778-48bc-80a5-264d22775add"],

Cell[BoxData[RowBox[{"{", RowBox[{"0.8967137270967201`", ",", "1.1431764150092556`"}], "}"}]], "Output",
 CellID->253553092, ExpressionUUID->"977b8b4e-f42e-4591-b5a3-b88d42db1bf5"]
}, Open  ]],

Cell[TextData[{"Larger ", Cell[BoxData[FormBox[
  "a",
  TraditionalForm
]], "InlineFormula"], " produces eigenvalues spanning many orders of magnitude:"}], "ExampleText",
 CellID->1785589820, ExpressionUUID->"a72b3e03-be66-43fd-a01d-bb098de7fba9"],

Cell[CellGroupData[{

Cell[BoxData[RowBox[{RowBox[{"SeedRandom", "[", "1", "]"}], ";", " ", RowBox[{"Through", " ", "@", " ", RowBox[{RowBox[{"{", RowBox[{"Min", ",", " ", "Max"}], "}"}], " ", "@", " ", RowBox[{"Abs", " ", "@", " ", RowBox[{"Eigenvalues", " ", "@", " ", RowBox[{"RandomCurvedMetric", "[", RowBox[{"3", ",", " ", "3", ",", " ", "3"}], "]"}]}]}]}]}]}]], "Input",
 CellID->577380900, ExpressionUUID->"dff6adb7-f6ff-4b7d-a682-eddb45282ebb"],

Cell[BoxData[RowBox[{"{", RowBox[{"0.03798521095442467`", ",", "55.385703577919834`"}], "}"}]], "Output",
 CellID->1209562924, ExpressionUUID->"1326cd9a-7335-4c32-9d46-e1b9085e0e55"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

