 CellID->2024068628, ExpressionUUID->"2392385e-5d10-4b09-ae88-d31cad6158f9"],

Cell[CellGroupData[{

Cell[BoxData[{RowBox[{RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", RowBox[{RowBox[{"Table", "[", RowBox[{RowBox[{"Norm", "[", RowBox[{RowBox[{"RandomCurvedMetric", "[", RowBox[{"2", ",", " ", "2", ",", " ", "a", ",", " ", "1"}], "]"}], ",", " ", "\"Frobenius\""}], "]"}], ",", "\n", "  ", RowBox[{"{", RowBox[{"a", ",", " ", RowBox[{"{", RowBox[{"0.1", ",", " ", "0.5", ",", " ", "1.0", ",", " ", "2.0", ",", " ", "3.0"}], "}"}]}], "}"}]}], "]"}], " ", "//", " ", "N"}]}], "Input",
 CellID->686895645, ExpressionUUID->"ba53a5d9-99ad-4550-8ec1-42ca23ba19b2"],

Cell[BoxData[RowBox[{"{", RowBox[{"2.0358206934533483`", ",", "2.2610331113621953`", ",", "1.9655819688874894`", ",", "50.56871346116541`", ",", "7.270830827974268`"}], "}"}]], "Output",
 CellID->149098186, ExpressionUUID->"31cdcfbc-0ebc-421c-8e50-f8a50587652a"]
}, Open  ]]
