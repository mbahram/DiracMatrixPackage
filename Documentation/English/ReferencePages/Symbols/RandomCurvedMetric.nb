Notebook[{

Cell[CellGroupData[{
Cell["RandomCurvedMetric", "ObjectName",
 CellID->607397917, ExpressionUUID->"ce10fcaf-f89c-4c73-a71e-c4cd6d1b20fb"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"RandomCurvedMetric", "[", 
   RowBox[{"p", ",", " ", "q"}], "]"}]], "InlineFormula",ExpressionUUID->
  "f31fea03-a968-4225-99f0-bc4b9e2de056"],
 "\[LineSeparator]returns a random real symmetric non-diagonal metric of \
signature ",
 Cell[BoxData[
  FormBox[
   RowBox[{"(", "p", ",", "q", ")"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"8fd9d989-cbea-480e-8200-2dac9fc9ed1c"],
 " with default condition number spread ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Tilde]", " ", 
    SuperscriptBox["10", "4"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"28cd9655-8813-4699-bfbb-37a7fe70cc7f"],
 ".\n",
 Cell[BoxData[
  RowBox[{"RandomCurvedMetric", "[", 
   RowBox[{"p", ",", " ", "q", ",", " ", "a"}], "]"}]], "InlineFormula",
  ExpressionUUID->"81692da9-a18f-48f8-b6f4-488fba242e97"],
 "\[LineSeparator]uses ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "8d343b61-3e00-43a2-ad35-dcccf52e2f70"],
 " as the spread exponent \[LongDash] eigenvalues of the diagonal core ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]], "InlineFormula",
  ExpressionUUID->"eb31a6e3-8e3e-472e-86ad-eb0c7f7f2f3a"],
 " are drawn as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", " ", 
    SuperscriptBox["10", "r"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"2d64ad69-5b2a-4c68-ad53-239352e0dae5"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "\[Element]", "[", "-", "a", ",", "a", "]"}], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "1df80e15-a144-41ca-9510-f8c11564a32f"],
 " uniform.\n",
 Cell[BoxData[
  RowBox[{"RandomCurvedMetric", "[", 
   RowBox[{"p", ",", " ", "q", ",", " ", "a", ",", " ", "s"}], "]"}]], 
  "InlineFormula",ExpressionUUID->"8baf07d5-d2ac-48ce-8c96-99c76f324973"],
 "\[LineSeparator]additionally multiplies the diagonal core by ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["s", "2"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"7f392167-563e-4a81-8ea3-b8a9e236380e"],
 ", scaling typical metric components."
}], "Usage",
 CellChangeTimes->{{3.987525246660185*^9, 3.987525256549385*^9}},
 CellID->878503639,ExpressionUUID->"64d59d91-265f-4c75-a314-643c242ed54f"],

Cell[TextData[{"The construction is ", Cell[BoxData[FormBox[
  RowBox[{SuperscriptBox["Q", StyleBox["T", "MR"]], "\[CenterDot]", "\[CapitalLambda]", "\[CenterDot]", "Q"}],
  TraditionalForm
]], "InlineFormula"], " with ", Cell[BoxData[FormBox[
  RowBox[{"Q", "\[Element]", "O", "(", "n", ")"}],
  TraditionalForm
]], "InlineFormula"], " drawn from CircularRealMatrixDistribution and ", Cell[BoxData[FormBox[
  "\[CapitalLambda]",
  TraditionalForm
]], "InlineFormula"], " diagonal with ", Cell[BoxData[FormBox[
  "p",
  TraditionalForm
]], "InlineFormula"], " positive and ", Cell[BoxData[FormBox[
  "q",
  TraditionalForm
]], "InlineFormula"], " negative eigenvalues."}], "Notes",
 CellID->834793747, ExpressionUUID->"d9427f14-d339-4b25-a1e6-baab99145cbf"],

Cell[TextData[{"The condition number of the resulting metric is approximately ", Cell[BoxData[FormBox[
  RowBox[{"\[Kappa]", " ", "\[Tilde]", " ", SuperscriptBox["10", RowBox[{"2", " ", "a"}]]}],
  TraditionalForm
]], "InlineFormula"], ", so the default ", Cell[BoxData[FormBox[
  RowBox[{"a", "=", "2"}],
  TraditionalForm
]], "InlineFormula"], " gives ", Cell[BoxData[FormBox[
  RowBox[{"\[Kappa]", " ", "\[Tilde]", " ", SuperscriptBox["10", "4"]}],
  TraditionalForm
]], "InlineFormula"], "."}], "Notes",
 CellID->201273979, ExpressionUUID->"e99a343d-a9c9-49e6-bc0a-ead665dd00fb"],

Cell["Use SeedRandom before calling to obtain reproducible metrics.", "Notes",
 CellID->823365991, ExpressionUUID->"a3f4a5af-8fe9-449f-8339-cae4b0640d24"]
}, Open  ]],

