 CellID->2026291061, ExpressionUUID->"94de4f30-7186-462f-ba14-7936cc5b7ee0"],

Cell[CellGroupData[{

Cell[BoxData[RowBox[{"RandomCurvedMetric", "[", RowBox[{"0", ",", " ", "0"}], "]"}]], "Input",
 CellID->1571964830, ExpressionUUID->"70d8afa8-8b5c-4b56-9f0b-b13a0a53270f"],

Cell[BoxData[RowBox[{TemplateBox[{RowBox[{"RandomVariate", "[", RowBox[{"CircularRealMatrixDistribution", "[", "0", "]"}], "]"}]}, "Transpose", SyntaxForm -> SuperscriptBox], ".", RowBox[{"DiagonalMatrix", "[", RowBox[{"{", "}"}], "]"}], ".", RowBox[{"RandomVariate", "[", RowBox[{"CircularRealMatrixDistribution", "[", "0", "]"}], "]"}]}]], "Output",
 CellID->1950367522, ExpressionUUID->"e56fd675-5e65-4688-8b56-58e647385eb8"]
}, Open  ]]
}, Open  ]],

