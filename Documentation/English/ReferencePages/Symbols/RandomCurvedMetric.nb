Cell["Basic Examples", "PrimaryExamplesSection",
 CellID->1335333491, ExpressionUUID->"fa1d4aa8-0a03-4d9a-a21c-e59806896ac8"],

Cell["A random non-diagonal Minkowski-like metric, signature (1, 3):", "ExampleText",
 CellID->817253496, ExpressionUUID->"0496c614-d7a1-4172-9fcb-145333cfd6a3"],

Cell[CellGroupData[{

Cell[BoxData[RowBox[{RowBox[{"SeedRandom", "[", "42", "]"}], ";", " ", RowBox[{RowBox[{RowBox[{"RandomCurvedMetric", "[", RowBox[{"1", ",", " ", "3", ",", " ", "0.5", ",", " ", "1"}], "]"}], " ", "//", " ", "Chop"}], " ", "//", " ", "MatrixForm"}]}]], "Input",
 CellID->1025991231, ExpressionUUID->"05d92287-3baa-4da7-b7a6-58e2c6e5eaed"],

Cell[BoxData[TagBox[RowBox[{"(", "\[NoBreak]", GridBox[{{"0.033590449703034986`", RowBox[{"-", "0.414891625630682`"}], "1.0187619904096172`", RowBox[{"-", "0.32876809261954854`"}]}, {RowBox[{"-", "0.414891625630682`"}], RowBox[{"-", "0.33525948164285757`"}], RowBox[{"-", "0.3649620366339658`"}], "0.2254639102658956`"}, {"1.0187619904096172`", RowBox[{"-", "0.3649620366339658`"}], "0.7636380383725165`", RowBox[{"-", "0.301304837047568`"}]}, {RowBox[{"-", "0.32876809261954854`"}], "0.22546391026589557`", RowBox[{"-", "0.301304837047568`"}], RowBox[{"-", "0.4499974385025488`"}]}}, RowSpacings -> 1, ColumnSpacings -> 1, RowAlignments -> Baseline, ColumnAlignments -> Center], "\[NoBreak]", ")"}], Function[BoxForm`e$, MatrixForm[BoxForm`e$]]]], "Output",
 CellID->1600386237, ExpressionUUID->"0fb02859-e8d4-4e77-bc0b-9e3b677d4657"]
}, Open  ]],

Cell["Confirm the signature is preserved by checking the signs of the eigenvalues:", "ExampleText",
 CellID->1134990945, ExpressionUUID->"068295c0-e439-4deb-a1aa-e886b2be0a21"],

Cell[CellGroupData[{

Cell[BoxData[RowBox[{RowBox[{"SeedRandom", "[", "42", "]"}], ";", " ", RowBox[{"Sign", " ", "@", " ", RowBox[{"Eigenvalues", " ", "@", " ", RowBox[{"RandomCurvedMetric", "[", RowBox[{"1", ",", " ", "3", ",", " ", "0.5", ",", " ", "1"}], "]"}]}]}]}]], "Input",
 CellID->798932351, ExpressionUUID->"99bd24b8-17b6-4940-9202-c6f1d221e6cf"],

Cell[BoxData[RowBox[{"{", RowBox[{"1", ",", RowBox[{"-", "1"}], ",", RowBox[{"-", "1"}], ",", RowBox[{"-", "1"}]}], "}"}]], "Output",
 CellID->1151357124, ExpressionUUID->"43f383d0-ca93-4c83-ad5c-36da03e9f053"]
}, Open  ]]
}, Open  ]],

