 InterpretationBox[Cell[
  "Scope", "ExampleSection",ExpressionUUID->"3d708f0e-6f9b-4f49-ad80-68284fe205d3"],
  $Line = 0; Null]], "ExampleSection",
 CellID->114352688, ExpressionUUID->"d2d8f63e-b384-4217-9bc9-f0808bd22c25"],
Cell["Tensor inputs of any rank", "ExampleSubsection",
 CellID->97485627, ExpressionUUID->"29cdf1fc-a839-4611-b409-10c2f921a934"],
