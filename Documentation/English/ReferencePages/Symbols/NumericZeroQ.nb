 CellID->1174612441, ExpressionUUID->"ed879a46-1240-4e4b-9b7e-7af16f1447e0"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"NumericZeroQ", "[", RowBox[{"ConstantArray", "[", RowBox[{"1*^-12", ",", " ", RowBox[{"{", RowBox[{"3", ",", " ", "3", ",", " ", "3"}], "}"}]}], "]"}], "]"}]], "Input",
 CellID->1297480830, ExpressionUUID->"68411160-216e-42a2-8f02-7f81a9a95436"],
Cell[BoxData["False"], "Output",
 CellID->1051253852, ExpressionUUID->"ffdb377e-bf65-4716-b0d8-403214866d8d"]
}, Open]],
Cell["A scalar — flattened then normed:", "ExampleText",
 CellID->1546058847, ExpressionUUID->"41c44055-ab58-4844-ad9f-e21216ab9bc4"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"NumericZeroQ", "[", "1*^-15", "]"}]], "Input",
 CellID->1545123052, ExpressionUUID->"798e3669-ec22-499a-a170-d929e6f2a973"],
Cell[BoxData[RowBox[{TemplateBox[{RowBox[{"Flatten", "[", FractionBox["1", "1000000000000000"], "]"}], TemplateBox[{}, "Frobenius", InterpretationFunction -> ("\"Frobenius\"" & )]}, "Norm2"], "\[Equal]", "0"}]], "Output",
 CellID->1686166227, ExpressionUUID->"810cddad-c471-41ef-9df6-a837eee660be"]
}, Open]],
Cell["Custom tolerance", "ExampleSubsection",
 CellID->1380652195, ExpressionUUID->"d4afff09-68a8-420a-8164-83a45563c7af"],
Cell["A loose tolerance accepts larger residuals:", "ExampleText",
 CellID->155146164, ExpressionUUID->"179d739a-95b4-4d2d-a649-c26318360d38"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"NumericZeroQ", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"0.", ",", " ", "1*^-5"}], "}"}], ",", " ", RowBox[{"{", RowBox[{"0.", ",", " ", "0."}], "}"}]}], "}"}], ",", " ", "1*^-4"}], "]"}]], "Input",
 CellID->1674063357, ExpressionUUID->"c97e78f5-68f7-49d7-a916-ac81c66dfc82"],
Cell[BoxData["False"], "Output",
 CellID->1327164704, ExpressionUUID->"dee6dae7-8bbe-432a-925d-30e6cf880b22"]
}, Open]],
Cell["A strict tolerance rejects the same matrix:", "ExampleText",
 CellID->440113002, ExpressionUUID->"cb7a5276-48fc-4f92-9bf6-199b80f332ab"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"NumericZeroQ", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"0.", ",", " ", "1*^-5"}], "}"}], ",", " ", RowBox[{"{", RowBox[{"0.", ",", " ", "0."}], "}"}]}], "}"}], ",", " ", "1*^-6"}], "]"}]], "Input",
 CellID->1394624882, ExpressionUUID->"333766f7-e407-412d-8c9b-f636cc13a0f9"],
Cell[BoxData["False"], "Output",
 CellID->1579883167, ExpressionUUID->"9417e28c-102a-414a-9525-b5267d204862"]
