    RowBox[{"{", 
     RowBox[{"0.", ",", " ", "0."}], "}"}]}], "}"}], "]"}]], "Input",
 CellID->1947574629,ExpressionUUID->"2a2c6d12-a27f-4a7d-b8c5-4040c3ff3785"],

Cell[BoxData["False"], "Output",
