Notebook[{

Cell[CellGroupData[{
Cell["NumericZeroQ", "ObjectName",
 CellID->655617511,ExpressionUUID->"89abe783-1a54-40be-8c7d-5f92f6437adc"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"NumericZeroQ", "[", "a", "]"}]], "InlineFormula",ExpressionUUID->
  "3baf15e3-83c9-446f-906d-c1f8c68b6965"],
 "\[LineSeparator]returns True if every entry of ",
 Cell[BoxData[
  FormBox["a", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "cd1acb89-2557-42e5-8cf8-4b4542f8dbd6"],
 " is zero within tolerance ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "8"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "857c533a-7579-4117-b7f1-79d7ac6e2b18"],
 " after Chop.\n",
 Cell["   ", "ModInfo",ExpressionUUID->"6700cdae-43d9-4f49-87d7-790a0a3ca0c1"],
 Cell[BoxData[
  RowBox[{"NumericZeroQ", "[", 
   RowBox[{"a", ",", " ", "tol"}], "]"}]], "InlineFormula",ExpressionUUID->
  "7e2114af-aff3-4afc-a8a8-90b76beb65ce"],
 "\[LineSeparator]uses the supplied tolerance tol."
}], "Usage",
 CellID->633160521,ExpressionUUID->"db297879-460b-426c-b573-7f278383aff8"],

Cell[TextData[{
 "Implementation: ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["Norm", "MR"], "[", 
    StyleBox["Chop", "MR"], "[", 
    StyleBox["Flatten", "MR"], "[", "a", "]", ",", 
    StyleBox["tol", "MR"], "]", ",", 
    StyleBox["Frobenius", "MR"], "]", "=", "0"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"e9ab28af-84ec-47e8-a351-6d61f943cf72"],
 "."
}], "Notes",
 CellID->1579205565,ExpressionUUID->"b1bb5189-6cb6-41a9-987d-c1a7a831dfa2"],

Cell["\<\
Use this to assert that a numerically computed quantity is the zero matrix or \
zero tensor when exact equality (===) cannot be expected due to round-off.\
\>", "Notes",
 CellID->1036785780,ExpressionUUID->"2c3c8b1b-9fd4-4320-b219-21d3b7647326"],

Cell[TextData[{
 "The default tolerance ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "8"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "027c6994-5599-49b4-a24b-8cc58690f0d9"],
 " is appropriate for machine-precision computation; for arbitrary-precision \
use a stricter tolerance."
}], "Notes",
 CellID->38107112,ExpressionUUID->"44873987-5124-4bc6-add7-c8b90a77dfc7"]
}, Open  ]],

