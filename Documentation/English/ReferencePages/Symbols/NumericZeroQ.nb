Cell[BoxData[
 InterpretationBox[Cell[
  "Applications", "ExampleSection",ExpressionUUID->"3492c4df-7f03-45e7-a768-828363ebe60e"],
  $Line = 0; Null]], "ExampleSection",
 CellID->818952413, ExpressionUUID->"afda80e6-d775-44c7-91b1-32f7cb1ccc2d"],
Cell["Asserting the Clifford relation in numerical form", "ExampleSubsection",
 CellID->251067524, ExpressionUUID->"b9cbf45f-0e26-4312-94e6-da7cfb4098cc"],
Cell["For random curved metrics, exact equality between matrices is not appropriate; check the residual with NumericZeroQ:", "ExampleText",
 CellID->1679426826, ExpressionUUID->"b414fc3b-e904-4e6e-966f-2f2703e8865e"],
Cell[CellGroupData[{
Cell[BoxData[{RowBox[{RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", RowBox[{"Module", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"\[Eta]", " ", "=", " ", RowBox[{"RandomCurvedMetric", "[", RowBox[{"1", ",", " ", "3", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ",", " ", "\[Gamma]"}], "}"}], ",", "\n", "  ", RowBox[{RowBox[{"\[Gamma]", " ", "=", " ", RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", RowBox[{"NumericZeroQ", "[", "\n", "    ", RowBox[{RowBox[{"Outer", "[", RowBox[{RowBox[{RowBox[{RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "-", " ", "\n", "      ", RowBox[{"2", " ", RowBox[{"TensorProduct", "[", RowBox[{"\[Eta]", ",", " ", RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}], "]"}]}]}], "]"}]}], "Input",
 CellID->573659947, ExpressionUUID->"c4b2f61f-ad2f-4db8-bf29-56d3f3660e18"],
Cell[BoxData["True"], "Output",
 CellID->1744287783, ExpressionUUID->"191db675-f6a5-4758-b4f8-bee6bf8f7cb9"]
}, Open]],
Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->"02774163-93bf-4443-a785-b5554c51c8ff"],
  $Line = 0; Null]], "ExampleSection",
 CellID->1637562602, ExpressionUUID->"1bd216dd-a779-4249-afe9-1ec1fdeb9604"],
Cell["Non-numeric symbolic entries do not vanish under Chop and yield False:", "ExampleText",
 CellID->2009842043, ExpressionUUID->"4ad07661-6b68-43fb-ae11-2ab1bdb57717"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"NumericZeroQ", "[", RowBox[{"{", RowBox[{"a", ",", " ", "b"}], "}"}], "]"}]], "Input",
 CellID->823383991, ExpressionUUID->"86a0cc01-2318-44b8-9ed8-d32129572ea1"],
Cell[BoxData[RowBox[{SqrtBox[RowBox[{SuperscriptBox[RowBox[{"Abs", "[", "a", "]"}], "2"], "+", SuperscriptBox[RowBox[{"Abs", "[", "b", "]"}], "2"]}]], "\[Equal]", "0"}]], "Output",
 CellID->1918442355, ExpressionUUID->"9b066e0d-5e62-426c-ae77-6268e042c512"]
}, Open]],
Cell[BoxData[
 InterpretationBox[Cell[
  "Neat Examples", "ExampleSection",ExpressionUUID->"7fbf3784-af21-40b2-85dc-c2cd9db75d7e"],
  $Line = 0; Null]], "ExampleSection",
 CellID->1158724710, ExpressionUUID->"d7409fb1-b63e-493f-a541-8cfefb283779"],
Cell[TextData[{"The Clifford anticommutator residual decays as the spread parameter ", Cell[BoxData[FormBox[
  "a",
  TraditionalForm
]], "InlineFormula"], " in RandomCurvedMetric decreases:"}], "ExampleText",
 CellID->1824671308, ExpressionUUID->"c4b1443e-50cb-4b81-bfdd-8fe55310bbc1"],
Cell[CellGroupData[{
Cell[BoxData[{RowBox[{RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", RowBox[{"Module", "[", RowBox[{RowBox[{"{", RowBox[{"\[Eta]", ",", " ", "\[Gamma]", ",", " ", "r"}], "}"}], ",", "\n", "  ", RowBox[{RowBox[{"\[Eta]", " ", "=", " ", RowBox[{"RandomCurvedMetric", "[", RowBox[{"1", ",", " ", "3", ",", " ", "0.1", ",", " ", "1"}], "]"}]}], ";", "\n", "  ", RowBox[{"\[Gamma]", " ", "=", " ", RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", RowBox[{"r", " ", "=", " ", RowBox[{RowBox[{"Outer", "[", RowBox[{RowBox[{RowBox[{RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "-", " ", RowBox[{"2", " ", RowBox[{"TensorProduct", "[", RowBox[{"\[Eta]", ",", " ", RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}]}], ";", "\n", "  ", RowBox[{"NumericZeroQ", "[", "r", "]"}]}]}], "]"}]}], "Input",
 CellID->1186355109, ExpressionUUID->"6f0eec3e-263d-41a2-ac38-6472484d8d94"],
Cell[BoxData["True"], "Output",
 CellID->116043976, ExpressionUUID->"01356588-8074-45a8-b16a-74966b588bc7"]
}, Open]]
}, Open]],

