Cell["Zero matrix is reported as True:", "ExampleText",
 CellID->171950551,ExpressionUUID->"ed622685-3750-4bc3-877c-773b25c5ffb0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NumericZeroQ", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"0.", ",", " ", "0."}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"0.", ",", " ", "0."}], "}"}]}], "}"}], "]"}]], "Input",
 CellID->730611690,ExpressionUUID->"7d195d55-1d03-4cfd-b241-b761abd882e7"],

Cell[BoxData["True"], "Output",
 CellID->1570754360,ExpressionUUID->"194b7fda-ee85-4de5-af89-eaa4f6c24326"]
}, Open  ]],

Cell["\<\
A matrix with entries smaller than the default tolerance is also True:\
\>", "ExampleText",
 CellID->1951102605,ExpressionUUID->"d6dd2da3-64f2-4c3c-b2f3-daab8064becb"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"NumericZeroQ", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1*^-10", ",", " ", "0."}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"0.", ",", " ", "1*^-12"}], "}"}]}], "}"}], "]"}]], "Input",
 CellID->1584123062,ExpressionUUID->"752c0df5-09cd-490b-a660-fa452a3daf12"],

Cell[BoxData["False"], "Output",
 CellID->1336186205,ExpressionUUID->"63e34488-75ff-44a8-be38-9b82d8e5105d"]
}, Open  ]],

