Notebook[{

Cell[CellGroupData[{
Cell["MetricVielbein", "ObjectName",
 CellID->1392669626,ExpressionUUID->"05f40d89-e6fb-41d2-842a-75506e129f62"],

Cell[TextData[{
 Cell[BoxData[
  RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]], "InlineFormula",
  ExpressionUUID->"a61dde14-c128-4fb1-bfdc-0e89dc96f83e"],
 "\[LineSeparator]returns ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    StyleBox["signature", "MR"], ",", "\[ThinSpace]", " ", "e", " ", "}"}], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "91b9ac42-6715-4ecb-a5d3-95db4c41b51b"],
 " for the real symmetric metric ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "2251ef9c-d2ae-4618-9f7a-37867f577f13"],
 ", where signature is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["diag", "MR"], "(", 
    StyleBox["Sign", "MR"], "(", 
    StyleBox["eigenvalues", "MR"], ")", ")"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"80383ef0-0c23-45e4-8496-db5b749bf6c3"],
 " and the vielbein ",
 Cell[BoxData[
  FormBox["e", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "4343b086-a6e1-429d-aaaa-4ca397f63a67"],
 " satisfies ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[ExponentialE]", 
     StyleBox["T", "MR"]], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
    "\[NegativeThinSpace]", " ", 
    StyleBox["signature", "MR"], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
    "\[NegativeThinSpace]", " ", "e", "=", "\[Eta]"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"6fbf0e55-aa25-4d04-ae15-df2d3821a233"],
 "."
}], "Usage",
 CellID->1248846710,ExpressionUUID->"4114b3fd-7a18-4712-b5b4-a441b87e1221"],

Cell[TextData[{
 "The decomposition is constructed from the eigensystem of ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "9b359684-2b1e-4b63-91c9-8d469971289c"],
 ": with eigenvalues ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "i"], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"c384cf58-d037-4e83-811a-b39cb9c82178"],
 " and orthonormal eigenvectors ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "i"], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "426c54c2-307f-4724-a57d-0e4f53183ad7"],
 " stacked into rows of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "5e25e5c6-5ede-4428-a274-011f9b2a96f1"],
 ", signature is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["diag", "MR"], "(", 
    StyleBox["Sign", "MR"], "(", 
    SubscriptBox["\[Lambda]", "i"], ")", ")"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"4892630e-a657-4cf8-8877-6e8e1a389f42"],
 " and the vielbein is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"e", "=", 
    StyleBox["diag", "MR"], "(", 
    SqrtBox[
     RowBox[{"\[VerticalSeparator]", " ", 
      SubscriptBox["\[Lambda]", "i"], " ", "\[VerticalSeparator]"}]], ")", "\[CenterDot]",
     "V"}], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "94f055f6-5039-469e-8dbe-911c2a604600"],
 "."
}], "Notes",
 CellID->1010198616,ExpressionUUID->"0d20df53-72ca-430d-8330-c8c3d8e79ecf"],

Cell[TextData[{
 "MetricVielbein expects a metric that is symmetric within tolerance ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], TraditionalForm]], "InlineFormula",ExpressionUUID->
  "fb727886-5b31-47c2-ab03-c6cf095691b4"],
 "."
}], "Notes",
 CellID->1586794633,ExpressionUUID->"ffb71ccc-ee7a-41f0-9389-10f65b745835"],

Cell[TextData[{
 "The vielbein is not unique: any rotation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[Element]", "O", "(", "n", ")"}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"b588d365-7700-4af9-b5d7-d031e2e2c526"],
 " applied as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"e", "\[RightArrow]", "R", "\[CenterDot]", "e"}], 
   TraditionalForm]], "InlineFormula",ExpressionUUID->
  "adc48d0a-85b3-4535-b126-8d44dfb6169e"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["R", 
     StyleBox["T", "MR"]], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
    "\[NegativeThinSpace]", " ", 
    StyleBox["signature", "MR"], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
    "\[NegativeThinSpace]", " ", "R", "=", 
    StyleBox["signature", "MR"]}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"51513c2f-6243-4448-aa77-d05261a5cabe"],
 " yields another vielbein for the same metric. The form returned here is the \
eigenvector frame."
}], "Notes",
 CellID->2033824394,ExpressionUUID->"5c9f6f32-97f7-42b3-83db-11f2dd23e24a"]
}, Open  ]],

