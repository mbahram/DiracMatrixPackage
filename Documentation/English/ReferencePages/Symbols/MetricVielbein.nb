Cell["\<\
For a randomly generated curved metric, the signature returned by \
MetricVielbein always equals Sign[Eigenvalues[\[Eta]]] as a diagonal matrix:\
\>", "ExampleText",
 CellID->873141767,ExpressionUUID->"6304d2f9-0cd4-4dcc-835a-a56ab1ec7359"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"RandomCurvedMetric", "[", 
       RowBox[{"2", ",", " ", "3", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], 
     ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"sig", " ", "===", " ", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"Sign", " ", "@", " ", 
       RowBox[{"Eigenvalues", " ", "@", " ", "\[Eta]"}]}], "]"}]}]}]}], 
  "]"}]}], "Input",
 CellID->149050893,ExpressionUUID->"f74b5db0-0cb9-4b58-9c64-bef763fa8e2c"],

Cell[BoxData["True"], "Output",
 CellID->575251621,ExpressionUUID->"99cd837e-a905-4c11-8211-b3d18ca66a3c"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

