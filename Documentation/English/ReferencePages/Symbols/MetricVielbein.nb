Cell[CellGroupData[{
Cell["Basic Examples", "PrimaryExamplesSection",
 CellID->747872269, ExpressionUUID->"635ea52d-b487-4848-a446-a72e9ba1321c"],
Cell["The vielbein of FlatMetric returns the signature itself and an identity vielbein (up to ordering and signs):", "ExampleText",
 CellID->1478627665, ExpressionUUID->"736296b2-6737-44ea-8e5d-37a1438cba34"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"MetricVielbein", "[", RowBox[{"FlatMetric", "[", RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]], "Input",
 CellID->2146163404, ExpressionUUID->"c8f6eb5a-0c4e-4694-87e8-6e610d6b4375"],
Cell[BoxData[RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[{"-", "1"}], ",", "0", ",", "0", ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", RowBox[{"-", "1"}], ",", "0", ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", "0", ",", RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}]}], "}"}], ",", RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], "}"}]], "Output",
 CellID->1281628133, ExpressionUUID->"e5546a78-7294-48ef-8a59-e2f6922bfcf7"]
}, Open]],
Cell[TextData[{"Round-trip: reconstructing ", Cell[BoxData[FormBox[
  "\[Eta]",
  TraditionalForm
]], "InlineFormula"], " from the vielbein returns the original metric (House rule #3):"}], "ExampleText",
 CellID->482598423, ExpressionUUID->"9a08e7b9-326e-40bb-89ea-c70c86e3cc00"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"Module", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"\[Eta]", " ", "=", " ", RowBox[{"FlatMetric", "[", RowBox[{"1", ",", " ", "3"}], "]"}]}], ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", "  ", RowBox[{RowBox[{RowBox[{"{", RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", RowBox[{RowBox[{RowBox[{"Transpose", "[", "e", "]"}], " ", ".", " ", "sig", " ", ".", " ", "e"}], " ", "===", " ", "\[Eta]"}]}]}], "]"}]], "Input",
 CellID->55689599, ExpressionUUID->"55a41976-baaa-48cd-874f-d97db174ff3c"],
Cell[BoxData["True"], "Output",
 CellID->1404106484, ExpressionUUID->"2302c1c9-1cc7-4427-87f0-92dd6cda9f4d"]
}, Open]]
}, Open]],

Cell[CellGroupData[{
Cell["ExamplesSection", "ExtendedExamplesSection",
 CellID->558811412, ExpressionUUID->"2ad1b3ea-0214-4feb-9bab-4c057b860e08"],
Cell[BoxData[
 InterpretationBox[Cell[
  "Scope", "ExampleSection",ExpressionUUID->"b6600459-3ab7-4f3a-8e16-1c2770cfef40"],
  $Line = 0; Null]], "ExampleSection",
 CellID->581143422, ExpressionUUID->"be93db1d-356b-43b4-a52c-d4fd7294da78"],
Cell["Random curved metric", "ExampleSubsection",
 CellID->472713212, ExpressionUUID->"f22a032d-163b-4920-b33a-eb475ea7e05c"],
Cell["The vielbein of a random curved metric is a non-diagonal real matrix; the round-trip holds within tolerance:", "ExampleText",
 CellID->1524628193, ExpressionUUID->"82eb5df5-f85c-4fb9-a843-7db6c8461cfe"],
Cell[CellGroupData[{
Cell[BoxData[{RowBox[{RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", RowBox[{"Module", "[", RowBox[{RowBox[{"{", RowBox[{"\[Eta]", ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", "  ", RowBox[{RowBox[{"\[Eta]", " ", "=", " ", RowBox[{"RandomCurvedMetric", "[", RowBox[{"2", ",", " ", "2", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ";", "\n", "  ", RowBox[{RowBox[{"{", RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", RowBox[{"NumericZeroQ", "[", RowBox[{RowBox[{RowBox[{"Transpose", "[", "e", "]"}], " ", ".", " ", "sig", " ", ".", " ", "e"}], " ", "-", " ", "\[Eta]"}], "]"}]}]}], "]"}]}], "Input",
 CellID->690169732, ExpressionUUID->"47663c51-625d-4ff8-a06b-a26954ff553b"],
Cell[BoxData["True"], "Output",
 CellID->1744370015, ExpressionUUID->"fcd4afe4-cfdb-4e3f-8612-958582cde785"]
}, Open]],
Cell["Diagonal but non-flat metric", "ExampleSubsection",
 CellID->1424797520, ExpressionUUID->"f61fb290-91f2-4e2b-bfc8-fab8b13172d1"],
Cell[TextData[{"The Schwarzschild components on the equatorial plane at ", Cell[BoxData[FormBox[
  RowBox[{"r", "=", "3", " ", "M"}],
  TraditionalForm
]], "InlineFormula"], " are diagonal but not ", Cell[BoxData[FormBox[
  RowBox[{"\[PlusMinus]", " ", "1"}],
  TraditionalForm
]], "InlineFormula"], " — the vielbein is the diagonal matrix of square roots:"}], "ExampleText",
 CellID->1266067729, ExpressionUUID->"c55c83b5-e14f-4a72-a43e-8f1ba57530b9"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"MetricVielbein", "[", "\n", "  ", RowBox[{"DiagonalMatrix", "[", RowBox[{"{", RowBox[{RowBox[{RowBox[{"-", "1"}], "/", "3"}], ",", " ", "3", ",", " ", "9", ",", " ", "9"}], "}"}], "]"}], "]"}]], "Input",
 CellID->677118906, ExpressionUUID->"21aa29a5-8b42-46bf-94f0-44664f515b57"],
Cell[BoxData[RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", "0", ",", "0", ",", RowBox[{"-", "1"}]}], "}"}]}], "}"}], ",", RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"0", ",", "0", ",", "0", ",", "3"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", "0", ",", "3", ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{"0", ",", SqrtBox["3"], ",", "0", ",", "0"}], "}"}], ",", RowBox[{"{", RowBox[{FractionBox["1", SqrtBox["3"]], ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], "}"}]], "Output",
 CellID->899676625, ExpressionUUID->"a274b632-72a0-4dc6-bd76-3cc3f04323be"]
}, Open]],
Cell[BoxData[
 InterpretationBox[Cell[
  "Applications", "ExampleSection",ExpressionUUID->"55cd6daa-664d-4d1e-ad1a-587b71ed1d05"],
  $Line = 0; Null]], "ExampleSection",
 CellID->203161823, ExpressionUUID->"b9779cb6-c2ac-402a-9109-8150699cbd52"],
Cell["Pulling back GammaMatrices through the vielbein", "ExampleSubsection",
 CellID->547925727, ExpressionUUID->"bee9d0ce-bbb9-4ba2-a216-c504ffa199cd"],
Cell[TextData[{"GammaMatrices uses MetricVielbein internally: the flat-space γ matrices on the signature are pulled back to the curved frame via ", Cell[BoxData[FormBox[
  RowBox[{SuperscriptBox["\[Gamma]", "\[Mu]"], "=", SubsuperscriptBox["e", RowBox[{" ", "a"}], "\[Mu]"], " ", "\[ThinSpace]", " ", SuperscriptBox["\[CapitalGamma]", "a"]}],
  TraditionalForm
]], "InlineFormula"], ". Verify this gives the same matrices:"}], "ExampleText",
 CellID->106696808, ExpressionUUID->"5a9b24c0-82a7-43d6-98ec-3c741ab60719"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"Module", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"\[Eta]", " ", "=", " ", RowBox[{"DiagonalMatrix", "[", RowBox[{"{", RowBox[{RowBox[{RowBox[{"-", "1"}], "/", "3"}], ",", " ", "3", ",", " ", "9", ",", " ", "9"}], "}"}], "]"}]}], ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", "  ", RowBox[{RowBox[{RowBox[{"{", RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", RowBox[{RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}], " ", "===", " ", "\n", "    ", RowBox[{"TensorContract", "[", RowBox[{RowBox[{"TensorProduct", "[", RowBox[{"e", ",", " ", RowBox[{"GammaMatrices", "[", "sig", "]"}]}], "]"}], ",", " ", RowBox[{"{", RowBox[{"{", RowBox[{"1", ",", " ", "3"}], "}"}], "}"}]}], "]"}]}]}]}], "]"}]], "Input",
 CellID->1616383369, ExpressionUUID->"47c756ff-0465-4c3a-b939-ef8294fca361"],
Cell[BoxData["True"], "Output",
 CellID->1563040730, ExpressionUUID->"27145cbe-e24d-4f7a-a303-42b6c6def46a"]
}, Open]],
Cell[BoxData[
 InterpretationBox[Cell[
  "Possible Issues", "ExampleSection",ExpressionUUID->"e6a953ec-9cfd-474b-baad-411491af5b42"],
  $Line = 0; Null]], "ExampleSection",
 CellID->1894957766, ExpressionUUID->"9406ee46-0c85-48b7-854d-86f7f9ac1388"],
Cell["A non-symmetric matrix does not match the guard pattern and the call remains unevaluated:", "ExampleText",
 CellID->1575455801, ExpressionUUID->"c5d8acc5-a648-4933-b03b-f54fad8cdf38"],
Cell[CellGroupData[{
Cell[BoxData[RowBox[{"MetricVielbein", "[", RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", RowBox[{"{", RowBox[{"3", ",", " ", "4"}], "}"}]}], "}"}], "]"}]], "Input",
 CellID->1993966114, ExpressionUUID->"77037fa4-7197-4c7c-9829-676aa259bc5c"],
Cell[BoxData[RowBox[{"MetricVielbein", "[", RowBox[{"{", RowBox[{RowBox[{"{", RowBox[{"1", ",", "2"}], "}"}], ",", RowBox[{"{", RowBox[{"3", ",", "4"}], "}"}]}], "}"}], "]"}]], "Output",
 CellID->1611215417, ExpressionUUID->"586d03f2-3d1c-4ebf-8e8c-021ebdff1115"]
}, Open]],
Cell[BoxData[
 InterpretationBox[Cell[
  "Neat Examples", "ExampleSection",ExpressionUUID->"7dd3971d-f470-4cfa-8ce6-4a6433558b52"],
  $Line = 0; Null]], "ExampleSection",
 CellID->1474375575, ExpressionUUID->"e4b3131b-4525-40df-b87e-c2c0bde0e295"],
Cell["For a randomly generated curved metric, the signature returned by MetricVielbein always equals Sign[Eigenvalues[\[Eta]]] as a diagonal matrix:", "ExampleText",
 CellID->873141767, ExpressionUUID->"6304d2f9-0cd4-4dcc-835a-a56ab1ec7359"],
Cell[CellGroupData[{
Cell[BoxData[{RowBox[{RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", RowBox[{"Module", "[", RowBox[{RowBox[{"{", RowBox[{RowBox[{"\[Eta]", " ", "=", " ", RowBox[{"RandomCurvedMetric", "[", RowBox[{"2", ",", " ", "3", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", "  ", RowBox[{RowBox[{RowBox[{"{", RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", RowBox[{"sig", " ", "===", " ", RowBox[{"DiagonalMatrix", "[", RowBox[{"Sign", " ", "@", " ", RowBox[{"Eigenvalues", " ", "@", " ", "\[Eta]"}]}], "]"}]}]}]}], "]"}]}], "Input",
 CellID->149050893, ExpressionUUID->"f74b5db0-0cb9-4b58-9c64-bef763fa8e2c"],
Cell[BoxData["True"], "Output",
 CellID->575251621, ExpressionUUID->"99cd837e-a905-4c11-8211-b3d18ca66a3c"]
}, Open]]
}, Open]],

