Cell["\<\
The vielbein of FlatMetric returns the signature itself and an identity \
vielbein (up to ordering and signs):\
\>", "ExampleText",
 CellID->1478627665,ExpressionUUID->"736296b2-6737-44ea-8e5d-37a1438cba34"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MetricVielbein", "[", 
  RowBox[{"FlatMetric", "[", 
   RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]], "Input",
 CellID->2146163404,ExpressionUUID->"c8f6eb5a-0c4e-4694-87e8-6e610d6b4375"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{
       RowBox[{"-", "1"}], ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       RowBox[{"-", "1"}], ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", 
       RowBox[{"-", "1"}], ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "1"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], 
  "}"}]], "Output",
 CellID->1281628133,ExpressionUUID->"e5546a78-7294-48ef-8a59-e2f6922bfcf7"]
}, Open  ]],

Cell[TextData[{
 "Round-trip: reconstructing ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]], "InlineFormula",ExpressionUUID->
  "a13b2adb-d49b-43e5-857f-b88e7dcce1ed"],
 " from the vielbein returns the original metric (House rule #3):"
}], "ExampleText",
 CellID->482598423,ExpressionUUID->"9a08e7b9-326e-40bb-89ea-c70c86e3cc00"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"1", ",", " ", "3"}], "]"}]}], ",", " ", "sig", ",", " ", 
     "e"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"Transpose", "[", "e", "]"}], " ", ".", " ", "sig", " ", ".", 
      " ", "e"}], " ", "===", " ", "\[Eta]"}]}]}], "]"}]], "Input",
 CellID->55689599,ExpressionUUID->"55a41976-baaa-48cd-874f-d97db174ff3c"],

Cell[BoxData["True"], "Output",
 CellID->1404106484,ExpressionUUID->"2302c1c9-1cc7-4427-87f0-92dd6cda9f4d"]
