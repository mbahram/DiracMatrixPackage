Cell["Random curved metric", "ExampleSubsection",
 CellID->472713212,ExpressionUUID->"f22a032d-163b-4920-b33a-eb475ea7e05c"],

Cell["\<\
The vielbein of a random curved metric is a non-diagonal real matrix; the \
round-trip holds within tolerance:\
\>", "ExampleText",
 CellID->1524628193,ExpressionUUID->"82eb5df5-f85c-4fb9-a843-7db6c8461cfe"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"2", ",", " ", "2", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ";",
     "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"NumericZeroQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "[", "e", "]"}], " ", ".", " ", "sig", " ", ".", 
       " ", "e"}], " ", "-", " ", "\[Eta]"}], "]"}]}]}], "]"}]}], "Input",
 CellID->690169732,ExpressionUUID->"47663c51-625d-4ff8-a06b-a26954ff553b"],

Cell[BoxData["True"], "Output",
 CellID->1744370015,ExpressionUUID->"fcd4afe4-cfdb-4e3f-8612-958582cde785"]
}, Open  ]]
}, Open  ]],

Cell[CellGroupData[{

Cell["Diagonal but non-flat metric", "ExampleSubsection",
 CellID->1424797520,ExpressionUUID->"f61fb290-91f2-4e2b-bfc8-fab8b13172d1"],

Cell[TextData[{
 "The Schwarzschild components on the equatorial plane at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "=", "3", " ", "M"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"40891a46-866d-48b5-b302-6a25820439ea"],
 " are diagonal but not ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", " ", "1"}], TraditionalForm]], "InlineFormula",
  ExpressionUUID->"53d395db-0b83-4574-9c64-407b71f572c0"],
 " \[LongDash] the vielbein is the diagonal matrix of square roots:"
}], "ExampleText",
 CellID->1266067729,ExpressionUUID->"c55c83b5-e14f-4a72-a43e-8f1ba57530b9"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MetricVielbein", "[", "\n", "  ", 
  RowBox[{"DiagonalMatrix", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", "3"}], ",", " ", "3", ",", " ", "9", ",", " ", 
     "9"}], "}"}], "]"}], "]"}]], "Input",
 CellID->677118906,ExpressionUUID->"21aa29a5-8b42-46bf-94f0-44664f515b57"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", 
       RowBox[{"-", "1"}]}], "}"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "3", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       SqrtBox["3"], ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       FractionBox["1", 
        SqrtBox["3"]], ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], 
  "}"}]], "Output",
 CellID->899676625,ExpressionUUID->"a274b632-72a0-4dc6-bd76-3cc3f04323be"]
