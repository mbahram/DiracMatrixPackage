Notebook[{

Cell[CellGroupData[{
Cell["MetricVielbein", "ObjectName",
 CellID->1392669626, ExpressionUUID->"05f40d89-e6fb-41d2-842a-75506e129f62"],
Cell[TextData[{
Cell[BoxData[RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]], "InlineFormula",
 ExpressionUUID->"a61dde14-c128-4fb1-bfdc-0e89dc96f83e"], "\[LineSeparator]returns ", Cell[BoxData[FormBox[
  RowBox[{"{", " ", StyleBox["signature", "MR"], ",", "\[ThinSpace]", " ", "e", " ", "}"}],
  TraditionalForm
]], "InlineFormula"], " for the real symmetric metric ", Cell[BoxData[FormBox[
  "\[Eta]",
  TraditionalForm
]], "InlineFormula"], ", where signature is ", Cell[BoxData[FormBox[
  RowBox[{StyleBox["diag", "MR"], "(", StyleBox["Sign", "MR"], "(", StyleBox["eigenvalues", "MR"], ")", ")"}],
  TraditionalForm
]], "InlineFormula"], " and the vielbein ", Cell[BoxData[FormBox[
  "e",
  TraditionalForm
]], "InlineFormula"], " satisfies ", Cell[BoxData[FormBox[
  RowBox[{SuperscriptBox["\[ExponentialE]", StyleBox["T", "MR"]], " ", "\[NegativeThinSpace]", "\[CenterDot]", "\[NegativeThinSpace]", " ", StyleBox["signature", "MR"], " ", "\[NegativeThinSpace]", "\[CenterDot]", "\[NegativeThinSpace]", " ", "e", "=", "\[Eta]"}],
  TraditionalForm
]], "InlineFormula"], "."
}], "Usage",
 CellID->1248846710, ExpressionUUID->"4114b3fd-7a18-4712-b5b4-a441b87e1221"],
Cell[TextData[{"The decomposition is constructed from the eigensystem of ", Cell[BoxData[FormBox[
  "\[Eta]",
  TraditionalForm
]], "InlineFormula"], ": with eigenvalues ", Cell[BoxData[FormBox[
  SubscriptBox["\[Lambda]", "i"],
  TraditionalForm
]], "InlineFormula"], " and orthonormal eigenvectors ", Cell[BoxData[FormBox[
  SubscriptBox["v", "i"],
  TraditionalForm
]], "InlineFormula"], " stacked into rows of ", Cell[BoxData[FormBox[
  "V",
  TraditionalForm
]], "InlineFormula"], ", signature is ", Cell[BoxData[FormBox[
  RowBox[{StyleBox["diag", "MR"], "(", StyleBox["Sign", "MR"], "(", SubscriptBox["\[Lambda]", "i"], ")", ")"}],
  TraditionalForm
]], "InlineFormula"], " and the vielbein is ", Cell[BoxData[FormBox[
  RowBox[{"e", "=", StyleBox["diag", "MR"], "(", SqrtBox[RowBox[{"\[VerticalSeparator]", " ", SubscriptBox["\[Lambda]", "i"], " ", "\[VerticalSeparator]"}]], ")", "\[CenterDot]", "V"}],
  TraditionalForm
]], "InlineFormula"], "."}], "Notes",
 CellID->1010198616, ExpressionUUID->"0d20df53-72ca-430d-8330-c8c3d8e79ecf"],
Cell[TextData[{"MetricVielbein expects a metric that is symmetric within tolerance ", Cell[BoxData[FormBox[
  SuperscriptBox["10", RowBox[{"-", "12"}]],
  TraditionalForm
]], "InlineFormula"], "."}], "Notes",
 CellID->1586794633, ExpressionUUID->"ffb71ccc-ee7a-41f0-9389-10f65b745835"],
Cell[TextData[{"The vielbein is not unique: any rotation ", Cell[BoxData[FormBox[
  RowBox[{"R", "\[Element]", "O", "(", "n", ")"}],
  TraditionalForm
]], "InlineFormula"], " applied as ", Cell[BoxData[FormBox[
  RowBox[{"e", "\[RightArrow]", "R", "\[CenterDot]", "e"}],
  TraditionalForm
]], "InlineFormula"], " with ", Cell[BoxData[FormBox[
  RowBox[{SuperscriptBox["R", StyleBox["T", "MR"]], " ", "\[NegativeThinSpace]", "\[CenterDot]", "\[NegativeThinSpace]", " ", StyleBox["signature", "MR"], " ", "\[NegativeThinSpace]", "\[CenterDot]", "\[NegativeThinSpace]", " ", "R", "=", StyleBox["signature", "MR"]}],
  TraditionalForm
]], "InlineFormula"], " yields another vielbein for the same metric. The form returned here is the eigenvector frame."}], "Notes",
 CellID->2033824394, ExpressionUUID->"5c9f6f32-97f7-42b3-83db-11f2dd23e24a"]
}, Open]],

