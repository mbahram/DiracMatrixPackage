Cell[CellGroupData[{

Cell["Pulling back GammaMatrices through the vielbein", "ExampleSubsection",
 CellID->547925727,ExpressionUUID->"bee9d0ce-bbb9-4ba2-a216-c504ffa199cd"],

Cell[TextData[{
 "GammaMatrices uses MetricVielbein internally: the flat-space \[Gamma] \
matrices on the signature are pulled back to the curved frame via ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Gamma]", "\[Mu]"], "=", 
    RowBox[{
     SubsuperscriptBox["e", 
      RowBox[{" ", "a"}], "\[Mu]"], " ", "\[ThinSpace]", " ", 
     SuperscriptBox["\[CapitalGamma]", "a"]}]}], TraditionalForm]], 
  "InlineFormula",ExpressionUUID->"c261cacf-5ffa-46e2-958e-cb3e00222fb0"],
 ". Verify this gives the same matrices:"
}], "ExampleText",
 CellID->106696808,ExpressionUUID->"5a9b24c0-82a7-43d6-98ec-3c741ab60719"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"DiagonalMatrix", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "/", "3"}], ",", " ", "3", ",", " ", "9", ",", 
         " ", "9"}], "}"}], "]"}]}], ",", " ", "sig", ",", " ", "e"}], "}"}], 
   ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}], " ", "===", " ", "\n", 
     "    ", 
     RowBox[{"TensorContract", "[", 
      RowBox[{
       RowBox[{"TensorProduct", "[", 
        RowBox[{"e", ",", " ", 
         RowBox[{"GammaMatrices", "[", "sig", "]"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}], "}"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellID->1616383369,ExpressionUUID->"47c756ff-0465-4c3a-b939-ef8294fca361"],

Cell[BoxData["True"], "Output",
 CellID->1563040730,ExpressionUUID->"27145cbe-e24d-4f7a-a303-42b6c6def46a"]
}, Open  ]]
}, Open  ]]
}, Open  ]],

