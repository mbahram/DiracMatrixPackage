Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "9fea42ee-92b9-42ff-8647-8494cbb350a6"],
     "\[LineSeparator]returns the canonical graded operator basis of the \
Clifford algebra ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        StyleBox["Cl", "MR"], "(", "\[Eta]", ")"}], TraditionalForm]], 
      "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "c5bbc9c6-c9f9-4f00-a2f5-6c1f95c20534"],
     " as a list grouped by grade ",
     Cell[BoxData[
      FormBox[
       RowBox[{"{", " ", 
        SubscriptBox["\[CapitalGamma]", 
         RowBox[{"(", "0", ")"}]], ",", 
        SubscriptBox["\[CapitalGamma]", 
         RowBox[{"(", "1", ")"}]], ",", "\[Ellipsis]", ",", 
        SubscriptBox["\[CapitalGamma]", 
         RowBox[{"(", "n", ")"}]], " ", "}"}], TraditionalForm]], 
      "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "9ae56a0a-01cd-4aec-b968-a9005dc99ccc"],
     " via explicit antisymmetrisation."
    }],ExpressionUUID->"36f4badb-08e1-4dd9-97e8-0fd4ba90cf87"]}
  }]], "Usage",
 CellID->1323187828,ExpressionUUID->"6b559f04-5d65-4ac3-a98f-fddc023e5527"]
}, Open  ]],

