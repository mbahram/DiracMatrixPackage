Cell["\<\
On any flat signature the two implementations produce the same basis at every \
grade:\
\>", "ExampleText",
 CellID->322972638,ExpressionUUID->"3dd5fdbc-673c-495a-8ec0-08ea1c07f9d0"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"CliffordCanonicalBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}], " ", "===", " ", 
      "\n", "    ", 
      RowBox[{"CliffordBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "5"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[4]:=",
 CellID->1828388548,ExpressionUUID->"fda361d2-0d1e-43a4-9325-fc0df65cfd61"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[4]=",
 CellID->2082447997,ExpressionUUID->"c4503e3c-79b1-4ba9-bf77-36228bb13157"]
}, Open  ]],

Cell["\<\
Higher grade on a random curved metric loses precision due to cancellations \
in the explicit sum \[LongDash] prefer CliffordBasis (production-ready \
alternative):\
\>", "ExampleText",
 CellID->1700122579,ExpressionUUID->"7ce17fea-c957-4f65-ae8f-5377abdc6c80"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"3", ",", " ", "3"}], "]"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"NumericZeroQ", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"Last", " ", "@", " ", 
      RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}]}], " ", "-", " ",
      "\n", "    ", 
     RowBox[{"Last", " ", "@", " ", 
      RowBox[{"CliffordBasis", "[", "\[Eta]", "]"}]}]}], "]"}]}], 
  "]"}]}], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[5]:=",
 CellID->268660303,ExpressionUUID->"8a423159-9a18-468b-ad06-5f829d249e7c"],

Cell[BoxData["False"], "Output",
 CellLabel->"Out[5]=",
 CellID->1308855079,ExpressionUUID->"97362e81-5f25-4565-aba1-ba2f179a2e35"]
}, Open  ]],

Cell["\<\
Non-symmetric input does not match the guard pattern; the call remains \
unevaluated:\
\>", "ExampleText",
 CellID->1798491730,ExpressionUUID->"e38cca29-a7e1-4ab0-b016-e4c665937466"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"CliffordCanonicalBasis", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", " ", "2"}], "}"}], ",", " ", 
    RowBox[{"{", 
     RowBox[{"3", ",", " ", "4"}], "}"}]}], "}"}], "]"}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[6]:=",
 CellID->774388238,ExpressionUUID->"1bd1f1b3-11b2-4202-a019-87b2ef5a6043"],

Cell[BoxData[
 RowBox[{"CliffordCanonicalBasis", "[", 
  RowBox[{"{", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"1", ",", "2"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"3", ",", "4"}], "}"}]}], "}"}], "]"}]], "Output",
 CellLabel->"Out[6]=",
 CellID->794651532,ExpressionUUID->"8c5c2f21-8679-4db7-8ac1-61663b2fd1ff"]
}, Open  ]],

Cell[TextData[{
 "The total basis dimension is ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e143687b-64e8-401a-84be-1825835650c9"],
 " for an n-dimensional metric:"
}], "ExampleText",
 CellID->358099613,ExpressionUUID->"727d0af7-f48e-40dd-8cf7-b170a039c8ac"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"Total", " ", "@", " ", 
       RowBox[{"Map", "[", 
        RowBox[{"Length", ",", " ", 
         RowBox[{"CliffordCanonicalBasis", "[", 
          RowBox[{"FlatMetric", "[", 
           RowBox[{"p", ",", " ", 
            RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], "]"}]}], " ",
       "==", " ", 
      RowBox[{"2", "^", "n"}]}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "5"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
