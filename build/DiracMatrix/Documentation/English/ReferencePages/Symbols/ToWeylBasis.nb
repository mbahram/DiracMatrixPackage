Cell[TextData[{
 "In the Weyl basis the chirality operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Gamma]", "5"], "=", 
    StyleBox["i", "MR"], " ", "\[ThinSpace]", " ", 
    SuperscriptBox["\[Gamma]", "0"], " ", 
    SuperscriptBox["\[Gamma]", "1"], " ", 
    SuperscriptBox["\[Gamma]", "2"], " ", 
    SuperscriptBox["\[Gamma]", "3"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "48d3cc7b-54a8-4e1b-872b-d8685c940727"],
 " is diagonal with eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", " ", "1"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "75aa5987-a7e7-4466-84ce-30a9ad0abca9"],
 ":"
}], "ExampleText",
 CellID->1713275638,ExpressionUUID->"a03a6ebd-d86f-473e-bd8c-531c3cad7228"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"ToWeylBasis", " ", "@", " ", 
      RowBox[{"GammaMatrices", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}]}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"Diagonal", "[", 
    RowBox[{"I", " ", 
     RowBox[{"Dot", " ", "@@", " ", "\[Gamma]"}]}], "]"}]}], "]"}]], "Input",
