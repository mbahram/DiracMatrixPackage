  RowBox[{"GammaMatrices", "[", 
   RowBox[{"FlatMetric", "[", 
    RowBox[{"1", ",", " ", "4"}], "]"}], "]"}], "]"}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[4]:=",
 CellID->61807093,ExpressionUUID->"edbc2dbb-6b77-4e08-b8d9-1452b02f8f1e"],

