Cell[TextData[{
 "Six-dimensional Euclidean: \[Gamma]_7 = ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox[
     StyleBox["i", "MR"], "3"], " ", "\[ThinSpace]", " ", 
    SuperscriptBox["\[CapitalGamma]", "1"], " ", "\[CenterEllipsis]", " ", 
    SuperscriptBox["\[CapitalGamma]", "6"]}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4118f874-9de6-4514-8d73-1c0c534c6e64"],
 " is diagonal in the Weyl basis:"
}], "ExampleText",
