Cell[TextData[{
 "The Weyl/chiral basis is produced by first applying ToDiracBasis and then a \
final block-rotation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"T", "=", 
    FractionBox["1", 
     SqrtBox["2"]], " ", "\[ThinSpace]", "(", 
    SubscriptBox["\[Sigma]", "x"], " ", "\[CircleTimes]", " ", 
    SubscriptBox[
     StyleBox["I",
      FontFamily->"DoubleStruck"], 
     RowBox[{"n", "/", "2"}]], ")"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "260aa5d1-0560-4dbe-84a3-71fbf9e7f78f"],
 " that pairs the upper and lower components."
}], "Notes",
 CellID->2086077606,ExpressionUUID->"863adfd7-41f9-4e5f-815d-08ea0e398509"],

Cell["\<\
All Clifford-algebra identities are preserved under the basis change.\
\>", "Notes",
 CellID->93979076,ExpressionUUID->"875769a8-ab46-4cf0-b00f-eb31cc3c1d81"],

Cell["\<\
For odd dimension the function emits ToWeylBasis::oddDim and falls back to \
the Dirac basis \[LongDash] there is no genuine Weyl decomposition in odd \
dimension.\
\>", "Notes",
 CellID->2050109612,ExpressionUUID->"7b9b5a32-0c3a-4705-99fb-0d0daf1d3dec"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

