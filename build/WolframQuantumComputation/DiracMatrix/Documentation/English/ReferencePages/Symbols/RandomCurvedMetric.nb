Cell[TextData[{
 "The construction is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["Q", 
     StyleBox["T", "MR"]], "\[CenterDot]", "\[CapitalLambda]", "\[CenterDot]",
     "Q"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "12b70141-610d-4222-bca6-107a59262378"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "\[Element]", "O", "(", "n", ")"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3ef95b6b-0292-4355-99c8-94abd3c71b2f"],
 " drawn from CircularRealMatrixDistribution and ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "54d69c60-ddd4-4b4c-9d7b-c5923e39aae5"],
 " diagonal with ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f5f054aa-a452-46d9-9697-84a93d5a054e"],
 " positive and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "70c5a781-783f-4658-8f62-4d636d940054"],
 " negative eigenvalues."
}], "Notes",
 CellID->834793747,ExpressionUUID->"d6616bb0-7efc-45ba-a594-b841dc034ef5"],

Cell[TextData[{
 "The condition number of the resulting metric is approximately ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", " ", "\[Tilde]", " ", 
    SuperscriptBox["10", 
     RowBox[{"2", " ", "a"}]]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "da6b0407-ec65-4d3f-a09e-7ec24c73c8b4"],
 ", so the default ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", "2"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cccaf58c-5586-48f0-8df6-d40145890ce1"],
 " gives ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", " ", "\[Tilde]", " ", 
    SuperscriptBox["10", "4"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fbbe509f-47bf-4634-ba90-163234754f10"],
 "."
}], "Notes",
 CellID->201273979,ExpressionUUID->"31b0004d-d537-4ce9-8740-d079a42e0104"],

