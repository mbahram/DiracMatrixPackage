Cell["\<\
The vielbein construction in GammaMatrices handles arbitrary symmetric \
metrics; the Clifford relation still holds within numerical tolerance:\
\>", "ExampleText",
 CellID->367015316,ExpressionUUID->"89fc6f7b-4d47-41c8-a9e4-d9b9dfc35a55"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", ",", " ", "\[Gamma]"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"2", ",", " ", "2", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ";",
     "\n", "  ", 
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"NumericZeroQ", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Outer", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
          RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
        "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "-", 
      " ", "\n", "      ", 
      RowBox[{"2", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"\[Eta]", ",", " ", 
         RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}], "]"}]}]}], 
  "]"}]}], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->1136776274,ExpressionUUID->"c3e545f5-caf7-4e5a-9fd3-c7207e2d0b74"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[1]=",
 CellID->1265801863,ExpressionUUID->"4c761b42-0a89-4573-bcac-fd5009875f5f"]
}, Open  ]]
