Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"2", ",", " ", "2", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ";",
     "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"NumericZeroQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "[", "e", "]"}], " ", ".", " ", "sig", " ", ".", 
       " ", "e"}], " ", "-", " ", "\[Eta]"}], "]"}]}]}], "]"}]}], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[2]:=",
 CellID->690169732,ExpressionUUID->"ad449a9d-1cf9-4ba2-a927-13646a6965e5"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[2]=",
 CellID->1744370015,ExpressionUUID->"f200ed8d-825d-49ae-ab3f-f705d7d9d907"]
}, Open  ]],

Cell[TextData[{
 "The Schwarzschild components on the equatorial plane at ",
 Cell[BoxData[
  FormBox[
   RowBox[{"r", "=", "3", " ", "M"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "101ccb06-b326-4a75-a6a0-7c2061f0159a"],
 " are diagonal but not ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", " ", "1"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "669eadb7-0a7c-428f-874a-72018acd22bf"],
 " \[LongDash] the vielbein is the diagonal matrix of square roots:"
}], "ExampleText",
 CellID->1266067729,ExpressionUUID->"3e9a6027-eceb-44ba-a330-452e69afcea1"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"MetricVielbein", "[", "\n", "  ", 
  RowBox[{"DiagonalMatrix", "[", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"-", "1"}], "/", "3"}], ",", " ", "3", ",", " ", "9", ",", " ", 
     "9"}], "}"}], "]"}], "]"}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[3]:=",
 CellID->677118906,ExpressionUUID->"3029b228-df2f-4671-b1e6-90f70fc20fb2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"1", ",", "0", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "1", ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "1", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", 
       RowBox[{"-", "1"}]}], "}"}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "0", ",", "3"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", "0", ",", "3", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{"0", ",", 
       SqrtBox["3"], ",", "0", ",", "0"}], "}"}], ",", 
     RowBox[{"{", 
      RowBox[{
       FractionBox["1", 
        SqrtBox["3"]], ",", "0", ",", "0", ",", "0"}], "}"}]}], "}"}]}], 
  "}"}]], "Output",
 CellLabel->"Out[3]=",
 CellID->899676625,ExpressionUUID->"dfe6fb27-76e6-4c67-94e9-3c52695bc065"]
}, Open  ]],

Cell[TextData[{
 "GammaMatrices uses MetricVielbein internally: the flat-space \[Gamma] \
matrices on the signature are pulled back to the curved frame via ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Gamma]", "\[Mu]"], "=", 
    RowBox[{
     SubsuperscriptBox["e", 
      RowBox[{" ", "a"}], "\[Mu]"], " ", "\[ThinSpace]", " ", 
     SuperscriptBox["\[CapitalGamma]", "a"]}]}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "44d86f5d-424b-4dd7-9308-4f9a84a7a068"],
 ". Verify this gives the same matrices:"
}], "ExampleText",
 CellID->106696808,ExpressionUUID->"ee736c6c-0966-4d19-89e5-13e7f62df0ef"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"DiagonalMatrix", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "/", "3"}], ",", " ", "3", ",", " ", "9", ",", 
         " ", "9"}], "}"}], "]"}]}], ",", " ", "sig", ",", " ", "e"}], "}"}], 
   ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}], " ", "===", " ", "\n", 
     "    ", 
     RowBox[{"TensorContract", "[", 
      RowBox[{
       RowBox[{"TensorProduct", "[", 
        RowBox[{"e", ",", " ", 
         RowBox[{"GammaMatrices", "[", "sig", "]"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}], "}"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[4]:=",
 CellID->1616383369,ExpressionUUID->"52a7dd11-bc43-4221-a72b-6244ff381074"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[4]=",
 CellID->1563040730,ExpressionUUID->"1deecf4a-a3af-4386-8cd4-64bfec75011f"]
}, Open  ]],

