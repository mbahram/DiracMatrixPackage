Cell[TextData[{
 "The decomposition is constructed from the eigensystem of ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4c1eceb1-9a5a-4b25-ac84-467ea346c8a2"],
 ": with eigenvalues ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "i"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4f22409d-cb2d-4f48-8255-c3f8afac2d52"],
 " and orthonormal eigenvectors ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "i"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "60fa3a2e-32ba-44b7-a840-4d4d9e987491"],
 " stacked into rows of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "41eae6fc-03e2-4a0d-adaa-14d93080dc48"],
 ", signature is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["diag", "MR"], "(", 
    StyleBox["Sign", "MR"], "(", 
    SubscriptBox["\[Lambda]", "i"], ")", ")"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "715be2c6-8c61-4eeb-bf98-733412ee03cc"],
 " and the vielbein is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"e", "=", 
    StyleBox["diag", "MR"], "(", 
    SqrtBox[
     RowBox[{"\[VerticalSeparator]", " ", 
      SubscriptBox["\[Lambda]", "i"], " ", "\[VerticalSeparator]"}]], ")", "\[CenterDot]",
     "V"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1c53b85b-3733-4d79-97f9-17db157d13d0"],
 "."
}], "Notes",
 CellID->1010198616,ExpressionUUID->"213cd383-d090-48ac-a628-980520fa51d7"],

Cell[TextData[{
 "MetricVielbein expects a metric that is symmetric within tolerance ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "926dbbfa-06c2-46c8-9604-285b2772c903"],
 "."
}], "Notes",
 CellID->1586794633,ExpressionUUID->"e780f20a-8b70-45ca-9cd0-16771de1e6fb"],

Cell[TextData[{
 "The vielbein is not unique: any rotation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[Element]", "O", "(", "n", ")"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "bb4cbfb5-9511-455c-a907-a902e3a80a3e"],
 " applied as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"e", "\[RightArrow]", "R", "\[CenterDot]", "e"}], 
   TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "73f0efa2-5219-4742-95bb-a00dbe60756a"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["R", 
     StyleBox["T", "MR"]], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
    "\[NegativeThinSpace]", " ", 
    StyleBox["signature", "MR"], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
    "\[NegativeThinSpace]", " ", "R", "=", 
    StyleBox["signature", "MR"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c9498396-ae39-4573-8b4d-f48e4bcad42a"],
 " yields another vielbein for the same metric. The form returned here is the \
eigenvector frame."
}], "Notes",
 CellID->2033824394,ExpressionUUID->"f27768e2-7c3a-4850-8680-97c5672db9aa"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

