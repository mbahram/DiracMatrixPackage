}, Open  ]],

Cell["\<\
For a randomly generated curved metric, the signature returned by \
MetricVielbein always equals Sign[Eigenvalues[\[Eta]]] as a diagonal matrix:\
\>", "ExampleText",
 CellID->873141767,ExpressionUUID->"faf5f5b9-c753-464d-86bc-90c6466d392f"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"RandomCurvedMetric", "[", 
       RowBox[{"2", ",", " ", "3", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], 
     ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"sig", " ", "===", " ", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"Sign", " ", "@", " ", 
       RowBox[{"Eigenvalues", " ", "@", " ", "\[Eta]"}]}], "]"}]}]}]}], 
  "]"}]}], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[6]:=",
 CellID->149050893,ExpressionUUID->"20680fa8-953c-40ac-8f7a-d154f095b743"],

