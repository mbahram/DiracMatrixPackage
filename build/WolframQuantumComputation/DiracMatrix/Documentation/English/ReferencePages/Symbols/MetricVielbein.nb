Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "2fa37c6c-1ef3-4a23-a74a-d1526b5724fe"],
     "\[LineSeparator]returns ",
     Cell[BoxData[
      FormBox[
       RowBox[{"{", " ", 
        StyleBox["signature", "MR"], ",", "\[ThinSpace]", " ", "e", " ", 
        "}"}], TraditionalForm]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a1561ef9-1b8f-44d9-a1ff-237ec59bb632"],
     " for the real symmetric metric ",
     Cell[BoxData[
      FormBox["\[Eta]", TraditionalForm]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "1002a279-f919-4718-8eec-304e0b9ed1b5"],
     ", where signature is ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        StyleBox["diag", "MR"], "(", 
        StyleBox["Sign", "MR"], "(", 
        StyleBox["eigenvalues", "MR"], ")", ")"}], TraditionalForm]], 
      "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "27a04dd2-9394-49d4-aba5-a6f6bc20d9b4"],
     " and the vielbein ",
     Cell[BoxData[
      FormBox["e", TraditionalForm]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a9aac70d-c722-4c01-aad9-0e7e109ec3ac"],
     " satisfies ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         StyleBox["T", "MR"]], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
        "\[NegativeThinSpace]", " ", 
        StyleBox["signature", "MR"], " ", "\[NegativeThinSpace]", "\[CenterDot]",
         "\[NegativeThinSpace]", " ", "e", "=", "\[Eta]"}], TraditionalForm]],
       "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8a4c55c5-2a61-4ede-8662-157bab812107"],
     "."
    }],ExpressionUUID->"c7baae0d-29bf-4c67-bd67-d425e502af57"]}
