Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"1", ",", " ", "3"}], "]"}]}], ",", " ", "sig", ",", " ", 
     "e"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"Transpose", "[", "e", "]"}], " ", ".", " ", "sig", " ", ".", 
      " ", "e"}], " ", "===", " ", "\[Eta]"}]}]}], "]"}]], "Input",
