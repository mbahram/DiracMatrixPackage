Cell[TextData[{
 "The dimension count follows the rule ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", 
    RowBox[{"\[LeftFloor]", " ", "n", "/", "2", " ", "\[RightFloor]"}]], 
   TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5db83b1d-f641-4491-b639-67bbb5e49870"],
 " for any n:"
}], "ExampleText",
 CellID->111237719,ExpressionUUID->"11d51944-65b6-4046-9ce9-80c2fece5960"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Length", " ", "@", " ", 
       RowBox[{"EuclideanGammaMatrices", "[", "n", "]"}]}], " ", "==", " ", 
      "n"}], " ", "&&", " ", 
     RowBox[{
      RowBox[{"First", " ", "@", " ", 
       RowBox[{"Dimensions", " ", "@", " ", 
        RowBox[{"First", " ", "@", " ", 
         RowBox[{"EuclideanGammaMatrices", "[", "n", "]"}]}]}]}], " ", "==", 
      " ", 
      RowBox[{"2", "^", 
       RowBox[{"Floor", "[", 
        RowBox[{"n", "/", "2"}], "]"}]}]}]}], ",", "\n", "  ", 
    RowBox[{"{", 
     RowBox[{"n", ",", " ", "1", ",", " ", "8"}], "}"}]}], "]"}], " ", "//", 
  " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[6]:=",
 CellID->1525505484,ExpressionUUID->"510ccd93-91d0-4656-ba70-dbaa5f965416"],

