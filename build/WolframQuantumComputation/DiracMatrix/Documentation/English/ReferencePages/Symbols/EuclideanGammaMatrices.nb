Cell[TextData[{
 "For even ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "2", " ", "m"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e7a8b40e-6b88-4ab0-80cf-c197ba9db783"],
 ", the construction is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "k", "-", "1"}]], "=", 
    SuperscriptBox[
     StyleBox["I",
      FontFamily->"DoubleStruck"], 
     RowBox[{"\[CircleTimes]", "(", "k", "-", "1", ")"}]], " ", "\[CircleTimes]",
     " ", 
    SubscriptBox["\[Sigma]", "1"], " ", "\[CircleTimes]", " ", 
    SubsuperscriptBox["\[Sigma]", "3", 
     RowBox[{"\[CircleTimes]", "(", "m", "-", "k", ")"}]]}], 
   TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "555b085b-2f36-4bd3-bd18-078a4d4c6f37"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "k"}]], "=", 
    SuperscriptBox[
     StyleBox["I",
      FontFamily->"DoubleStruck"], 
     RowBox[{"\[CircleTimes]", "(", "k", "-", "1", ")"}]], " ", "\[CircleTimes]",
     " ", 
    SubscriptBox["\[Sigma]", "2"], " ", "\[CircleTimes]", " ", 
    SubsuperscriptBox["\[Sigma]", "3", 
     RowBox[{"\[CircleTimes]", "(", "m", "-", "k", ")"}]]}], 
   TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "115b3186-bcde-4fb4-a939-780028cd9dc1"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "=", "1", ",", "\[Ellipsis]", ",", "m"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "4e9eb950-0ce7-4ab1-b02c-b046502f72a2"],
 ". For odd ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "2", " ", "m", "+", "1"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e7849351-fb19-470d-a795-0a6a9315239c"],
 ", an additional ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "m", "+", "1"}]], "=", 
    SubsuperscriptBox["\[Sigma]", "3", 
     RowBox[{"\[CircleTimes]", " ", "m"}]]}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e78065a2-2e70-4bd3-844d-3addc1a79b41"],
 " is appended."
}], "Notes",
 CellID->302387906,ExpressionUUID->"5249c31f-f0a1-4702-9b01-9279576daea4"],

Cell[TextData[{
 "The returned matrices satisfy the Euclidean Clifford relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[CapitalGamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[CapitalGamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Delta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3d5e1567-3335-4f33-ae60-df9fd037da2a"],
 ". For other signatures use GammaMatrices."
}], "Notes",
 CellID->400310068,ExpressionUUID->"709e8c50-881c-490d-8b3f-832b99d8be68"],

