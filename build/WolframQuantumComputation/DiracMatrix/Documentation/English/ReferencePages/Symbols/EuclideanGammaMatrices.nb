Cell[TextData[{
 "The chirality operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "m", "+", "1"}]], "=", 
    SuperscriptBox["\[CapitalGamma]", "1"], " ", 
    SuperscriptBox["\[CapitalGamma]", "2"], " ", "\[CenterEllipsis]", " ", 
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "m"}]]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "3c2ca204-63ed-4eaf-bda1-0c89192628b9"],
 " in even dimension equals the last basis element of the odd-dimensional \
construction:"
}], "ExampleText",
 CellID->1899443217,ExpressionUUID->"4d7210a6-ffc6-48e2-aa8e-fc5d94ed4047"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", " ", "=", " ", "3"}], ",", " ", "even", ",", " ", "odd"}], 
    "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"even", " ", "=", " ", 
     RowBox[{"EuclideanGammaMatrices", "[", 
      RowBox[{"2", " ", "m"}], "]"}]}], ";", "\n", "  ", 
    RowBox[{"odd", "  ", "=", " ", 
     RowBox[{"EuclideanGammaMatrices", "[", 
      RowBox[{
       RowBox[{"2", " ", "m"}], " ", "+", " ", "1"}], "]"}]}], ";", "\n", 
    "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"I", "^", "m"}], " ", 
      RowBox[{"Dot", " ", "@@", " ", "even"}]}], " ", "==", " ", 
     RowBox[{"Last", "[", "odd", "]"}]}]}]}], "]"}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[9]:=",
 CellID->755355542,ExpressionUUID->"922ca98f-afa3-4605-8544-84cb73d98cb9"],

Cell[BoxData["False"], "Output",
 CellLabel->"Out[9]=",
 CellID->537703543,ExpressionUUID->"d079332b-3e53-4d67-9b21-238cade8a478"]
}, Open  ]]
