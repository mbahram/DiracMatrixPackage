Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[CapitalGamma]", " ", "=", " ", 
     RowBox[{"EuclideanGammaMatrices", "[", "4", "]"}]}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{
    RowBox[{"Outer", "[", 
     RowBox[{
      RowBox[{
       RowBox[{
        RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
        RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
      "\[CapitalGamma]", ",", " ", "\[CapitalGamma]", ",", " ", "1"}], "]"}], 
    " ", "==", " ", "\n", "    ", 
    RowBox[{"2", " ", 
     RowBox[{"TensorProduct", "[", 
      RowBox[{
       RowBox[{"IdentityMatrix", "[", "4", "]"}], ",", " ", 
       RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[2]:=",
 CellID->656532056,ExpressionUUID->"61757d22-43a6-458c-95b3-4a2b330a24d8"],

