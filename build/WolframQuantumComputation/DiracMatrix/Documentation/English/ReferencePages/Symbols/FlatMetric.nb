Cell[TextData[{
 "Verify the Clifford relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[Gamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Eta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d87eab05-ee94-4868-b920-0fbfe7ddc52c"],
 " in dimension 4:"
}], "ExampleText",
 CellID->251209475,ExpressionUUID->"738fa881-c098-4a76-9bd9-abe16b23adc3"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"1", ",", " ", "3"}], "]"}]}], ",", " ", "\[Gamma]"}], "}"}], ",",
    "\n", "  ", 
   RowBox[{
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
         RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
       "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "==", 
     " ", 
     RowBox[{"2", " ", 
      RowBox[{"TensorProduct", "[", 
       RowBox[{"\[Eta]", ",", " ", 
        RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[6]:=",
 CellID->684525596,ExpressionUUID->"ac52dcb1-b6ca-4045-a674-0b77b7780dac"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[6]=",
 CellID->1207934848,ExpressionUUID->"f675285e-7cd6-4349-85af-3fff2fd79686"]
}, Open  ]],

