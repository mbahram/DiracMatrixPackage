Cell["\<\
Verify that FlatMetric is its own inverse for any signature, since its \
diagonal entries square to 1:\
\>", "ExampleText",
 CellID->1976506792,ExpressionUUID->"797878c2-1a18-439b-8b36-f70284387c40"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], " ", ".", " ", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], " ", "==", " ", 
      RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[8]:=",
 CellID->1197772505,ExpressionUUID->"a77b81a2-7fe8-4eec-8c4e-6097def9d950"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[8]=",
 CellID->1352556635,ExpressionUUID->"10572a9b-bb95-4be3-ac6a-c4be1840adf6"]
}, Open  ]]
}, Dynamic[CurrentValue[
