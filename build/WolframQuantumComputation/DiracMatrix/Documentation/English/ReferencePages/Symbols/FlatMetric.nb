Cell["\<\
Pass FlatMetric directly into GammaMatrices to produce the corresponding \
gamma matrices:\
\>", "ExampleText",
 CellID->1702970596,ExpressionUUID->"f072feda-6eb1-46fb-8a71-9a262f28e53e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"GammaMatrices", "[", 
   RowBox[{"FlatMetric", "[", 
    RowBox[{"1", ",", " ", "3"}], "]"}], "]"}], " ", "//", " ", 
  RowBox[{"Map", "[", "MatrixForm", "]"}]}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[5]:=",
 CellID->357531509,ExpressionUUID->"8dd3d600-8049-4d90-bcf6-737336e03da2"],

Cell[BoxData[
 RowBox[{"{", 
  RowBox[{
   TagBox[
    RowBox[{"(", "\[NoBreak]", GridBox[{
       {"0", "0", "1", "0"},
       {"0", "0", "0", 
        RowBox[{"-", "1"}]},
       {"1", "0", "0", "0"},
