Cell["The Clifford relation is preserved by the basis change:", "ExampleText",
 CellID->1907032240,ExpressionUUID->"2bd97e1d-ae2a-4b1c-aa56-542370d5075f"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"1", ",", " ", "3"}], "]"}]}], ",", " ", "\[Gamma]"}], "}"}], ",",
    "\n", "  ", 
   RowBox[{
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"ToDiracBasis", " ", "@", " ", 
      RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
         RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
       "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "==", 
     " ", "\n", "    ", 
     RowBox[{"2", " ", 
      RowBox[{"TensorProduct", "[", 
       RowBox[{"\[Eta]", ",", " ", 
        RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[2]:=",
 CellID->419543837,ExpressionUUID->"4d52aadf-9d86-402d-8a0b-1e4bc2b2d574"],

