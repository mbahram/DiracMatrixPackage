Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Gamma]", "c"], "=", 
    SuperscriptBox[
     StyleBox["i", "MR"], 
     RowBox[{"(", "n", "-", "2", " ", "p", ")", "/", "2"}]], " ", 
    "\[ThinSpace]", " ", 
    SuperscriptBox["\[Gamma]", "0"], " ", 
    SuperscriptBox["\[Gamma]", "1"], " ", "\[CenterEllipsis]", " ", 
    SuperscriptBox["\[Gamma]", 
     RowBox[{"n", "-", "1"}]]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1d8fb625-ec5e-445c-a7ae-962465b1959f"],
 " is Hermitian, squares to the identity, and anticommutes with every \
\[Gamma]:"
}], "ExampleText",
 CellID->405330878,ExpressionUUID->"d1e2706d-e6b8-45c1-a8e6-3b87497bb99c"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", " ", "=", " ", "4"}], ",", " ", 
     RowBox[{"p", " ", "=", " ", "1"}], ",", " ", "\[CapitalGamma]", ",", " ",
      "\[CapitalGamma]c"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"\[CapitalGamma]", "  ", "=", " ", 
     RowBox[{"GammaMatrices", "[", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"p", ",", " ", 
        RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ";", "\n", "  ", 
    
    RowBox[{"\[CapitalGamma]c", " ", "=", " ", 
     RowBox[{
      RowBox[{"I", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", " ", "-", " ", 
           RowBox[{"2", " ", "p"}]}], ")"}], "/", "2"}], ")"}]}], " ", 
      RowBox[{"Dot", " ", "@@", " ", "\[CapitalGamma]"}]}]}], ";", "\n", "  ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"HermitianMatrixQ", "[", "\[CapitalGamma]c", "]"}], ",", "\n", 
      "   ", 
      RowBox[{
       RowBox[{"\[CapitalGamma]c", " ", ".", " ", "\[CapitalGamma]c"}], " ", "==",
        " ", 
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"2", "^", 
         RowBox[{"Floor", "[", 
          RowBox[{"n", "/", "2"}], "]"}]}], "]"}]}]}], "}"}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->142328987,ExpressionUUID->"0ccc350d-3d88-41b0-8c88-31c495265191"],

