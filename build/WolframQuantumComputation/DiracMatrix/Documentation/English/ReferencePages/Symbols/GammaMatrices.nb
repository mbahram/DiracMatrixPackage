Cell["\<\
The Clifford relation holds across a sweep of signatures and dimensions:\
\>", "ExampleText",
 CellID->784600820,ExpressionUUID->"cffcb0da-24f6-4840-b673-523d0fd3ba52"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Eta]", " ", "=", " ", 
          RowBox[{"FlatMetric", "[", 
           RowBox[{"p", ",", " ", 
            RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], ",", " ", 
         "\[Gamma]"}], "}"}], ",", "\n", "    ", 
       RowBox[{
        RowBox[{"\[Gamma]", " ", "=", " ", 
         RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "    ", 
        RowBox[{
         RowBox[{"Outer", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
             RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
           "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "==",
          " ", "\n", "      ", 
         RowBox[{"2", " ", 
          RowBox[{"TensorProduct", "[", 
           RowBox[{"\[Eta]", ",", " ", 
            RowBox[{"IdentityMatrix", "[", 
             RowBox[{"2", "^", 
              RowBox[{"Floor", "[", 
               RowBox[{"n", "/", "2"}], "]"}]}], "]"}]}], "]"}]}]}]}]}], 
      "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->433906851,ExpressionUUID->"0f25c54f-7954-4481-aa0f-34706911c22a"],

