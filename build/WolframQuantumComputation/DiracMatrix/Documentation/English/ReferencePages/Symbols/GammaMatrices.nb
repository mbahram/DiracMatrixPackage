Cell[TextData[{
 "The Clifford anticommutation relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[Gamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Eta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "af0f8b97-ef08-4bbc-b3de-e7ba073ec7bf"],
 " is satisfied for any real symmetric metric ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0ab5013d-e1f6-49cc-98a4-db0c6e945594"],
 ", including non-flat curved metrics."
}], "Notes",
 CellID->753940963,ExpressionUUID->"38373ce3-3772-46bd-a23a-5e9cd5681da5"],

Cell[TextData[{
 "Three call signatures are recognised: an integer (Euclidean case), a \
signed-diagonal metric ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["diag", "MR"], "(", "\[PlusMinus]", " ", "1", ",", "\[Ellipsis]",
     ")"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2e9d2cf4-3bba-4a42-b17d-3f5c63d891ba"],
 " (flat case with explicit ",
 Cell[BoxData[
  FormBox[
   StyleBox["i", "MR"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "88e37d34-126f-45d0-8b15-dbe8a54b1863"],
 " on time-like indices), and a general real symmetric matrix (uses \
MetricVielbein to pull back the flat-space \[CapitalGamma] matrices into the \
curved frame)."
}], "Notes",
 CellID->738953165,ExpressionUUID->"dd197f52-2f5c-42cb-adf6-f45526df7dad"],

Cell["\<\
The result is in the Brauer-Weyl basis. Use ToDiracBasis or ToWeylBasis to \
transform to the Dirac or Weyl/chiral basis.\
\>", "Notes",
 CellID->1382496451,ExpressionUUID->"bc15cf5f-af41-4ad5-a6fb-40d25cf36a86"],

Cell[TextData[{
 "Inputs must satisfy SymmetricMatrixQ[\[Eta], Tolerance -> ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "34c80a12-8522-4441-bec9-28799dfa1440"],
 "]."
}], "Notes",
 CellID->1476303496,ExpressionUUID->"4173ca2a-37b1-426b-806c-5c6eeaee66b2"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

