Cell["\<\
The two implementations produce the same basis at every grade on flat metrics:\
\>", "ExampleText",
 CellID->439734258,ExpressionUUID->"9bc6a8bb-eba7-48ee-84b8-d76b790dab74"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"CliffordBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}], " ", "===", " ", 
      "\n", "    ", 
      RowBox[{"CliffordCanonicalBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "5"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellProlog:>Needs["DiracMatrix`"],
 CellLabel->"In[2]:=",
 CellID->1966108165,ExpressionUUID->"b98588bc-0295-43fb-9e2b-dbe254f816dd"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[2]=",
 CellID->218645348,ExpressionUUID->"c50e3d04-2474-418d-b490-efc877322124"]
}, Open  ]],

Cell["\<\
At low grade, CliffordBasis and CliffordCanonicalBasis agree on a random \
curved metric:\
\>", "ExampleText",
 CellID->463889840,ExpressionUUID->"1685a032-5dde-43f5-8935-65e83f30e691"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"3", ",", " ", "3"}], "]"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"NumericZeroQ", "[", "\n", "    ", 
    RowBox[{
     RowBox[{
      RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}], "[", 
      RowBox[{"[", 
       RowBox[{";;", " ", "3"}], "]"}], "]"}], " ", "-", " ", "\n", "    ", 
     RowBox[{
      RowBox[{"CliffordBasis", "[", "\[Eta]", "]"}], "[", 
      RowBox[{"[", 
       RowBox[{";;", " ", "3"}], "]"}], "]"}]}], "]"}]}], "]"}]}], "Input",
