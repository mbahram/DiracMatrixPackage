Cell[TextData[{
 "The grade-2 elements satisfy ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], "=", 
    FractionBox["1", "2"], "[", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[Gamma]", "\[Nu]"], "]"}], TraditionalForm]], 
  "InlineFormula",
