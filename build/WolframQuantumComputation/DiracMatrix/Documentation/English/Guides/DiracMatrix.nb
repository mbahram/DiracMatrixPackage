Cell[CellGroupData[{

Cell["DiracMatrix", "GuideTitle",
 CellID->799826245,ExpressionUUID->"43547b20-0ce6-4955-b77c-f03a371b2842"],

Cell[TextData[{
 "The DiracMatrix paclet constructs Dirac gamma matrices ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Gamma]", "\[Mu]"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "757fe8e9-e670-4334-ac5c-de93f0885338"],
 " that satisfy the Clifford anticommutation relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[Gamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Eta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "881175c0-7c7a-4f68-ad80-12571c35ccf7"],
 " for an arbitrary real symmetric metric ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "54188999-9764-4798-b11e-e52b87de0f92"],
 " in any dimension. The flat case uses the Brauer\[Dash]Weyl \
(Pauli\[Dash]Kronecker) construction; non-flat metrics are reached through a \
vielbein decomposition ",
 Cell[BoxData[
  FormBox[
   RowBox[{"g", "=", 
    SuperscriptBox["\[ExponentialE]", 
     StyleBox["T", "MR"]], "\[CenterDot]", "\[Eta]", "\[CenterDot]", "e"}], 
   TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5d29972b-a63e-46f1-9b1f-77eff497fd22"],
 ". The package also provides basis transformations into the Dirac and Weyl \
(chiral) representations, and two implementations of the canonical graded \
Clifford operator basis: an explicit antisymmetrisation sum (pedagogically \
transparent) and an antisymmetric recursion (numerically stable, \
production-ready)."
}], "GuideAbstract",
 CellID->2121490076,ExpressionUUID->"bebef625-74bc-4a77-bb95-ddcf96a5ba50"],

Cell["\t", "GuideDelimiterSubsection",ExpressionUUID->"bb400589-e510-4693-8272-cf46251c5980"],

