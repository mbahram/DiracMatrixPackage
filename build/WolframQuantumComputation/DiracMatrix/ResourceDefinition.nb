Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", "=", 
      RowBox[{"RandomCurvedMetric", "[", 
       RowBox[{"1", ",", "3"}], "]"}]}], ",", "\[CapitalGamma]"}], "}"}], ",",
    "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"\[CapitalGamma]", "=", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"NumericZeroQ", "@", 
     RowBox[{"Table", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"[", "\[Mu]", "]"}], "]"}], ".", 
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"[", "\[Nu]", "]"}], "]"}]}], "+", 
        RowBox[{
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"[", "\[Nu]", "]"}], "]"}], ".", 
         RowBox[{"\[CapitalGamma]", "[", 
          RowBox[{"[", "\[Mu]", "]"}], "]"}]}], "-", 
        RowBox[{"2", " ", 
         RowBox[{"\[Eta]", "[", 
          RowBox[{"[", 
           RowBox[{"\[Mu]", ",", "\[Nu]"}], "]"}], "]"}], " ", 
         RowBox[{"IdentityMatrix", "[", "4", "]"}]}]}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Mu]", ",", "4"}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"\[Nu]", ",", "4"}], "}"}]}], "]"}]}]}]}], "]"}]], "Input",
 TaggingRules->{},
 CellChangeTimes->{{3.987548134405229*^9, 3.987548144647512*^9}},
 CellLabel->"In[5]:=",
