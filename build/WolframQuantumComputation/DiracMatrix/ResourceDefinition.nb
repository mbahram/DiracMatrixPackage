 CellID->427099699,ExpressionUUID->"e949c479-dbee-41d5-8d77-a3cb9053e794"],

Cell[TextData[{
 "For flat metrics CliffordCanonicalBasis (explicit antisymmetrisation sum \
over the symmetric group) and CliffordBasis (antisymmetric recursion) agree \
at every grade. For non-flat metrics with widely scaled eigenvalues precision \
can degrade at high grades in CliffordCanonicalBasis; prefer CliffordBasis \
for production use. RandomCurvedMetric draws each eigenvalue log-uniformly \
with default range ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["10", 
     RowBox[{"-", "2"}]], "-", 
    SuperscriptBox["10", "2"]}], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "8b7b7017-0117-478f-adcb-c3135ab54b6d"],
 ", giving condition number around ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", "4"], TraditionalForm]],
  FormatType->TraditionalForm,ExpressionUUID->
  "164e7206-bd58-4b4b-8cfa-d3f047f1b121"],
 "; tune the third argument to adjust."
}], "Text",
 TaggingRules->{},
 CellChangeTimes->{{3.987548220912407*^9, 3.9875482334680367`*^9}},
 CellTags->"TabNext",
 CellID->3773185,ExpressionUUID->"a3230244-45bf-4da0-b8dc-f7d974513dd4"]
}, Open  ]]
}, Open  ]]
},
