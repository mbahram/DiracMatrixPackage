Cell[TextData[{
 "In the Weyl basis the chirality operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Gamma]", "5"], "=", 
    StyleBox["i", "MR"], " ", "\[ThinSpace]", " ", 
    SuperscriptBox["\[Gamma]", "0"], " ", 
    SuperscriptBox["\[Gamma]", "1"], " ", 
    SuperscriptBox["\[Gamma]", "2"], " ", 
    SuperscriptBox["\[Gamma]", "3"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "6512dc53-b348-45fe-9df9-912499c4efee"],
 " is diagonal with eigenvalues ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[PlusMinus]", " ", "1"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c13d7e9b-d732-4307-9342-a512cd953079"],
 ":"
}], "ExampleText",
 CellID->1713275638,ExpressionUUID->"e66a7a38-b359-4f1f-bb4f-31dc9b7cbf50"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"ToWeylBasis", " ", "@", " ", 
      RowBox[{"GammaMatrices", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}]}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{"Diagonal", "[", 
    RowBox[{"I", " ", 
     RowBox[{"Dot", " ", "@@", " ", "\[Gamma]"}]}], "]"}]}], "]"}]], "Input",
