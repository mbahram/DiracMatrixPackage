Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{"ToWeylBasis", "[", "\[Gamma]", "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "34967e0d-9544-466c-bcf9-7d86982b66ec"],
     "\[LineSeparator]takes a list of gamma matrices in the Brauer-Weyl basis \
and returns them in the Weyl/chiral basis, in which the chirality operator is \
block-diagonal. For odd dimension there is no chiral decomposition and the \
Dirac basis is returned along with a ToWeylBasis::oddDim message."
    }],ExpressionUUID->"83162606-719d-48c8-be67-c53a5d5e8286"]}
  }]], "Usage",
 CellID->1075869774,ExpressionUUID->"53e431b6-ecfb-449f-a2f3-a72159e9519c"]
}, Open  ]],

