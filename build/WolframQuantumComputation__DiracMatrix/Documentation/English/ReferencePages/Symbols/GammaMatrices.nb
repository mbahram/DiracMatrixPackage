Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{"GammaMatrices", "[", "n", "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "542c0278-87b3-407d-b505-d218521de839"],
     "\[LineSeparator]returns the n Euclidean gamma matrices of dimension ",
     Cell[BoxData[
      FormBox[
       SuperscriptBox["2", 
        RowBox[{"\[LeftFloor]", " ", "n", "/", "2", " ", "\[RightFloor]"}]], 
       TraditionalForm]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "f8adb667-e889-4480-bf71-5e6563a53487"],
     " (equivalent to EuclideanGammaMatrices[n])."
    }],ExpressionUUID->"b5d54f76-796a-478a-9c7d-53a8368f5328"]},
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6f8cb061-39c0-4cf6-91c3-dc79f6207fb4"],
     "\[LineSeparator]returns gamma matrices satisfying the Clifford relation \
",
     Cell[BoxData[
      FormBox[
       RowBox[{"{", " ", 
        SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
        SuperscriptBox["\[Gamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
        SuperscriptBox["\[Eta]", 
         RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
        StyleBox["I",
         FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "967d451e-a0eb-4811-bbb3-ab779773321b"],
     " for any real symmetric metric ",
     Cell[BoxData[
      FormBox["\[Eta]", TraditionalForm]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "eeee96b2-d63b-4900-a26d-bde88957bdff"],
     "; for a flat signed-diagonal metric the result is ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        StyleBox["i", "MR"], " ", "\[ThinSpace]", " ", 
        SuperscriptBox["\[CapitalGamma]", "\[Mu]"]}], TraditionalForm]], 
      "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "a3a8d882-3eb3-44c9-a096-2229e116dcbe"],
     " on time-like indices and ",
     Cell[BoxData[
      FormBox[
       SuperscriptBox["\[CapitalGamma]", "\[Mu]"], TraditionalForm]], 
      "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "25efde54-4900-4a33-ba6d-fc38ae7e137a"],
     " on space-like indices; for a general metric a vielbein decomposition \
is used."
    }],ExpressionUUID->"fa216742-2c18-49b9-8df8-ad2eedddfaa7"]}
  }]], "Usage",
 CellID->373034705,ExpressionUUID->"a6de6e09-1e0b-4b03-965d-1a92950010e6"]
}, Open  ]],

