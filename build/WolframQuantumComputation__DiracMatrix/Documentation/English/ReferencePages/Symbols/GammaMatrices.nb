Cell["\<\
A non-numeric symbolic 2x2 metric does not produce a usable Eigensystem and \
the construction hangs in recursive evaluation. Always provide a numeric (or \
exact rational) metric; if your metric is symbolic, substitute numeric values \
for the parameters before passing it to GammaMatrices. Below we show the safe \
approach by substituting a, b, c with concrete numerical values:\
\>", "ExampleText",
 CellID->1071719734,ExpressionUUID->"31bd12d0-0a8d-4f09-987f-d20a260ceb29"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"GammaMatrices", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"a", ",", " ", "b"}], "}"}], ",", " ", 
      RowBox[{"{", 
       RowBox[{"b", ",", " ", "c"}], "}"}]}], "}"}], " ", "/.", " ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"a", " ", "->", " ", "1"}], ",", " ", 
      RowBox[{"b", " ", "->", " ", "0"}], ",", " ", 
      RowBox[{"c", " ", "->", " ", 
       RowBox[{"-", "1"}]}]}], "}"}]}], "]"}], " ", "//", " ", 
  RowBox[{"Map", "[", "MatrixForm", "]"}]}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[2]:=",
 CellID->1413873461,ExpressionUUID->"44c8f31d-d8f1-408c-be97-3a76929d6f43"],

