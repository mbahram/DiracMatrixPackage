Cell["\<\
A random real symmetric metric is handled via the vielbein decomposition; the \
Clifford relation holds within numerical tolerance:\
\>", "ExampleText",
 CellID->1918602442,ExpressionUUID->"8fc40b07-2cc4-4113-b2cc-07e9f1709d5a"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "42", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", ",", " ", "\[Gamma]"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"2", ",", " ", "2", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ";",
     "\n", "  ", 
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"NumericZeroQ", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Outer", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
          RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
        "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "-", 
      " ", "\n", "      ", 
      RowBox[{"2", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"\[Eta]", ",", " ", 
         RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}], "]"}]}]}], 
  "]"}]}], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->135892483,ExpressionUUID->"4422f2cb-8328-4c70-a9fb-4e3eaafed840"],

