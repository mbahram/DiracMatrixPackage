Cell[TextData[{
 "A non-symmetric matrix is not in the domain and the call remains \
unevaluated (the guard pattern SymmetricMatrixQ[\[Ellipsis], Tolerance -> ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "26f3abf0-e0b6-4a12-9c20-d2c6b54ef9a0"],
 "] rejects it before the GammaMatrices::nonsym message fires):"
}], "ExampleText",
