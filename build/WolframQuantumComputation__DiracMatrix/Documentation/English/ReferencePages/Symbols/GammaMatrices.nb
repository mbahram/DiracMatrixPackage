Cell["\<\
The Clifford relation holds across a sweep of signatures and dimensions:\
\>", "ExampleText",
 CellID->784600820,ExpressionUUID->"1327c621-3bc8-4cd5-a315-91a6dc129806"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{
         RowBox[{"\[Eta]", " ", "=", " ", 
          RowBox[{"FlatMetric", "[", 
           RowBox[{"p", ",", " ", 
            RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], ",", " ", 
         "\[Gamma]"}], "}"}], ",", "\n", "    ", 
       RowBox[{
        RowBox[{"\[Gamma]", " ", "=", " ", 
         RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "    ", 
        RowBox[{
         RowBox[{"Outer", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
             RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
           "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "==",
          " ", "\n", "      ", 
         RowBox[{"2", " ", 
          RowBox[{"TensorProduct", "[", 
           RowBox[{"\[Eta]", ",", " ", 
            RowBox[{"IdentityMatrix", "[", 
             RowBox[{"2", "^", 
              RowBox[{"Floor", "[", 
               RowBox[{"n", "/", "2"}], "]"}]}], "]"}]}], "]"}]}]}]}]}], 
      "]"}], ",", "\n", "  ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->433906851,ExpressionUUID->"9356c54a-4d7e-4e4a-a832-ba241b3dabda"],

