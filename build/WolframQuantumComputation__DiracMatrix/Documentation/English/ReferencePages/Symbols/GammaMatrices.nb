Cell[TextData[{
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[Gamma]", "c"], "=", 
    SuperscriptBox[
     StyleBox["i", "MR"], 
     RowBox[{"(", "n", "-", "2", " ", "p", ")", "/", "2"}]], " ", 
    "\[ThinSpace]", " ", 
    SuperscriptBox["\[Gamma]", "0"], " ", 
    SuperscriptBox["\[Gamma]", "1"], " ", "\[CenterEllipsis]", " ", 
    SuperscriptBox["\[Gamma]", 
     RowBox[{"n", "-", "1"}]]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "2c4898b3-5684-4a84-be2b-9c2c9614321d"],
 " is Hermitian, squares to the identity, and anticommutes with every \
\[Gamma]:"
}], "ExampleText",
 CellID->405330878,ExpressionUUID->"c6c4eaf1-60cd-49c2-8fa2-b3911b737a54"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"n", " ", "=", " ", "4"}], ",", " ", 
     RowBox[{"p", " ", "=", " ", "1"}], ",", " ", "\[CapitalGamma]", ",", " ",
      "\[CapitalGamma]c"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"\[CapitalGamma]", "  ", "=", " ", 
     RowBox[{"GammaMatrices", "[", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"p", ",", " ", 
        RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ";", "\n", "  ", 
    
    RowBox[{"\[CapitalGamma]c", " ", "=", " ", 
     RowBox[{
      RowBox[{"I", "^", 
       RowBox[{"(", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"n", " ", "-", " ", 
           RowBox[{"2", " ", "p"}]}], ")"}], "/", "2"}], ")"}]}], " ", 
      RowBox[{"Dot", " ", "@@", " ", "\[CapitalGamma]"}]}]}], ";", "\n", "  ", 
    RowBox[{"{", 
     RowBox[{
      RowBox[{"HermitianMatrixQ", "[", "\[CapitalGamma]c", "]"}], ",", "\n", 
      "   ", 
      RowBox[{
       RowBox[{"\[CapitalGamma]c", " ", ".", " ", "\[CapitalGamma]c"}], " ", "==",
        " ", 
       RowBox[{"IdentityMatrix", "[", 
        RowBox[{"2", "^", 
         RowBox[{"Floor", "[", 
          RowBox[{"n", "/", "2"}], "]"}]}], "]"}]}]}], "}"}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->142328987,ExpressionUUID->"8961bfe2-b995-4a83-83e4-de623e7434b8"],

