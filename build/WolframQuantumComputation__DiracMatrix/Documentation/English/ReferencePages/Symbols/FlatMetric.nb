Cell["\<\
Verify that FlatMetric is its own inverse for any signature, since its \
diagonal entries square to 1:\
\>", "ExampleText",
 CellID->1976506792,ExpressionUUID->"08e3157d-a631-4394-b751-b55723ef6ea6"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", 
    RowBox[{
     RowBox[{
      RowBox[{
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], " ", ".", " ", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}]}], " ", "==", " ", 
      RowBox[{"IdentityMatrix", "[", "n", "]"}]}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"n", ",", " ", "2", ",", " ", "6"}], "}"}], ",", " ", 
     RowBox[{"{", 
      RowBox[{"p", ",", " ", "0", ",", " ", "n"}], "}"}]}], "]"}], " ", "//", 
   " ", "Flatten"}], " ", "//", " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->1197772505,ExpressionUUID->"e4270b82-ac29-439b-995e-f5a6fa7d5189"],

