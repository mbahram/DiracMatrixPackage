Cell[TextData[{
 "Verify the Clifford relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[Gamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Eta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fe79df80-5ea2-46bf-8bf8-16e00ae82217"],
 " in dimension 4:"
}], "ExampleText",
 CellID->251209475,ExpressionUUID->"98a2604a-352c-44ba-bce9-e2945884583e"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"1", ",", " ", "3"}], "]"}]}], ",", " ", "\[Gamma]"}], "}"}], ",",
    "\n", "  ", 
   RowBox[{
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
         RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
       "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "==", 
     " ", 
     RowBox[{"2", " ", 
      RowBox[{"TensorProduct", "[", 
       RowBox[{"\[Eta]", ",", " ", 
        RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[2]:=",
 CellID->684525596,ExpressionUUID->"9b28f853-a820-4cd0-b499-9491ad4287d3"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[2]=",
 CellID->1207934848,ExpressionUUID->"72c085c5-f67f-4952-9b2a-0415404cc5cb"]
}, Open  ]]
