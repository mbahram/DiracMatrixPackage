Cell[TextData[{
 "The recursion is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{
      StyleBox["I",
       FontFamily->"Script"], " ", "\[Union]", " ", "{", " ", "\[Mu]", " ", 
      "}"}]], "=", 
    SubscriptBox["\[CapitalGamma]", 
     StyleBox["I",
      FontFamily->"Script"]], "\[CenterDot]", 
    SubscriptBox["\[CapitalGamma]", "\[Mu]"], "-", 
    UnderoverscriptBox["\[Sum]", 
     RowBox[{"j", "=", "1"}], 
     RowBox[{"\[VerticalSeparator]", " ", 
      StyleBox["I",
       FontFamily->"Script"], " ", "\[VerticalSeparator]"}]], "(", "-", "1", " ", 
    SuperscriptBox[")", 
     RowBox[{"j", "-", "1"}]], " ", 
    SubscriptBox["\[Eta]", 
     RowBox[{"\[Mu]", ",", 
      SubscriptBox["i", "j"]}]], " ", "\[ThinSpace]", " ", 
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{
      StyleBox["I",
       FontFamily->"Script"], " ", "setminus", " ", "{", " ", 
      SubscriptBox["i", "j"], " ", "}"}]]}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0b684578-3050-4760-b5a3-f903ed17ffcd"],
 ", building each grade from the previous one without recomputing permutation \
sums."
}], "Notes",
 CellID->1604166617,ExpressionUUID->"44aefe19-cdc9-4eda-a7c4-d6cb6ceed0e4"],

Cell[TextData[{
 "CliffordBasis is the production-ready implementation: O(",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b209d38f-84b7-4dda-877f-f4d8fdcfacef"],
 " n\.b2) operations versus O(",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e91c8fa5-92b3-4a4f-82be-92ba6b503feb"],
 " n!) for CliffordCanonicalBasis, and numerically stable for curved metrics \
with widely scaled eigenvalues."
}], "Notes",
 CellID->717894389,ExpressionUUID->"65244547-1cbc-4c73-8b53-eea67065fa4e"],

Cell["\<\
On flat metrics it agrees with CliffordCanonicalBasis at every grade.\
\>", "Notes",
 CellID->1939221786,ExpressionUUID->"558f0989-c410-4489-af6c-8d633a5a5d32"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

