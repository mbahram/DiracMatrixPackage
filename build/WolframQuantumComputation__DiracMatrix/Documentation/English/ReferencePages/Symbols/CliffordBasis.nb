Cell["\<\
The two implementations produce the same basis at every grade on flat metrics:\
\>", "ExampleText",
 CellID->439734258,ExpressionUUID->"b9717292-ec79-4e75-a719-24d8272fc940"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Table", "[", "\n", "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"CliffordBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}], " ", "===", " ", 
      "\n", "    ", 
      RowBox[{"CliffordCanonicalBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"p", ",", " ", 
         RowBox[{"n", " ", "-", " ", "p"}]}], "]"}], "]"}]}], ",", "\n", "  ", 
     RowBox[{"{", 
