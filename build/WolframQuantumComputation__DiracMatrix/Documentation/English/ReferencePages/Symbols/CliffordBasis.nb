Cell[TextData[{
 "The grade-2 elements satisfy ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], "=", 
    FractionBox["1", "2"], "[", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[Gamma]", "\[Nu]"], "]"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c30e2252-ed57-4df9-89d6-cea1d154af10"],
 ":"
}], "ExampleText",
 CellID->791923102,ExpressionUUID->"1b05715a-2c2a-4e2c-aa33-b4ef3111ffb8"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Gamma]", " ", "=", " ", 
      RowBox[{"GammaMatrices", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"1", ",", " ", "3"}], "]"}], "]"}]}], ",", " ", 
     "\[CapitalGamma]2"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"\[CapitalGamma]2", " ", "=", " ", 
     RowBox[{
      RowBox[{"CliffordBasis", "[", 
       RowBox[{"FlatMetric", "[", 
        RowBox[{"1", ",", " ", "3"}], "]"}], "]"}], "[", 
      RowBox[{"[", "3", "]"}], "]"}]}], ";", "\n", "  ", 
    RowBox[{"\[CapitalGamma]2", " ", "===", " ", 
     RowBox[{"Table", "[", "\n", "    ", 
      RowBox[{
       RowBox[{
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Subsets", "[", 
               RowBox[{
                RowBox[{"Range", "[", "4", "]"}], ",", " ", 
                RowBox[{"{", "2", "}"}]}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", " ", "1"}], "]"}], "]"}], "]"}], "]"}], " ", 
           ".", " ", 
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Subsets", "[", 
               RowBox[{
                RowBox[{"Range", "[", "4", "]"}], ",", " ", 
                RowBox[{"{", "2", "}"}]}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", " ", "2"}], "]"}], "]"}], "]"}], "]"}]}], 
          " ", "-", " ", "\n", "     ", 
          RowBox[{
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Subsets", "[", 
               RowBox[{
                RowBox[{"Range", "[", "4", "]"}], ",", " ", 
                RowBox[{"{", "2", "}"}]}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", " ", "2"}], "]"}], "]"}], "]"}], "]"}], " ", 
           ".", " ", 
           RowBox[{"\[Gamma]", "[", 
            RowBox[{"[", 
             RowBox[{
              RowBox[{"Subsets", "[", 
               RowBox[{
                RowBox[{"Range", "[", "4", "]"}], ",", " ", 
                RowBox[{"{", "2", "}"}]}], "]"}], "[", 
              RowBox[{"[", 
               RowBox[{"i", ",", " ", "1"}], "]"}], "]"}], "]"}], "]"}]}]}], 
         ")"}], "/", "2"}], ",", "\n", "    ", 
       RowBox[{"{", 
        RowBox[{"i", ",", " ", 
         RowBox[{"Length", " ", "@", " ", 
          RowBox[{"Subsets", "[", 
           RowBox[{
            RowBox[{"Range", "[", "4", "]"}], ",", " ", 
            RowBox[{"{", "2", "}"}]}], "]"}]}]}], "}"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->749916917,ExpressionUUID->"55c8d333-62ca-438a-9977-7203f0d02648"],

