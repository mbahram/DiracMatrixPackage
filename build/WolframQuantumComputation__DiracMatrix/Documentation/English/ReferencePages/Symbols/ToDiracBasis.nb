Cell["\<\
The function is a similarity transform; applying another similarity that \
diagonalises the result's first matrix in the Brauer-Weyl-ordered eigensystem \
returns the original up to a unitary rotation. The simplest check is that \
both bases share the same anticommutator structure:\
\>", "ExampleText",
 CellID->1107934855,ExpressionUUID->"d543d71f-a335-42d4-aa46-f9ff19ddd775"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"bw", ",", " ", "dirac", ",", " ", 
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"FlatMetric", "[", 
       RowBox[{"1", ",", " ", "3"}], "]"}]}]}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"bw", " ", "=", " ", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"dirac", " ", "=", " ", 
     RowBox[{"ToDiracBasis", "[", "bw", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
         RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", "bw", ",",
        " ", "bw", ",", " ", "1"}], "]"}], " ", "===", " ", "\n", "    ", 
     RowBox[{"Outer", "[", 
      RowBox[{
       RowBox[{
        RowBox[{
         RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
         RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", "dirac",
        ",", " ", "dirac", ",", " ", "1"}], "]"}]}]}]}], "]"}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->975641058,ExpressionUUID->"0bf3110d-73eb-4765-8ef9-5b9a4c6d460a"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[1]=",
 CellID->172022029,ExpressionUUID->"1ed3bd1e-04fd-4661-bdd9-8876d3140cb2"]
}, Open  ]]
