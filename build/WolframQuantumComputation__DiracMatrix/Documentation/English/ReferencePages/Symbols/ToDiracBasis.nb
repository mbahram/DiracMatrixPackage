Cell[TextData[{
 "The transform is the similarity ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Gamma]", "\[Mu]"], "\[RightArrow]", 
    SuperscriptBox["S", 
     RowBox[{"-", "1"}]], " ", 
    SuperscriptBox["\[Gamma]", "\[Mu]"], " ", "S"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ae7a27ba-a140-4454-917b-2459dfe5cda4"],
 ", where ",
 Cell[BoxData[
  FormBox["S", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9005d512-8dac-4c97-b025-cb58a1839f03"],
 " is built from the eigenvectors of ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Gamma]", "0"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0671ed18-a95c-4115-8667-12769bb93a77"],
 " reordered so the imaginary eigenvalues with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["Im", "MR"], ">", "0"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "aa2f0d44-948e-49a1-a8b4-e5c12025dded"],
 " come first (mostly-plus convention)."
}], "Notes",
 CellID->606637287,ExpressionUUID->"0d5a2da9-41d7-4b63-b7fc-80f94f8ab81d"],

Cell["\<\
Since the transform is a similarity, all Clifford-algebra identities \
(anticommutator, traces, contractions) are preserved.\
\>", "Notes",
 CellID->332032168,ExpressionUUID->"4b512626-61a8-489d-ac83-e6ff2a5332cb"],

Cell[TextData[{
 "Use this for example to obtain the textbook Dirac matrices with diagonal ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["\[Gamma]", "0"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a76d0b45-b71c-4ef4-a917-c5b8a6b84ca9"],
 " on the (1, 3) signature."
}], "Notes",
 CellID->1968313742,ExpressionUUID->"54c49ef8-1a1e-4318-ab3f-9a178db03101"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

