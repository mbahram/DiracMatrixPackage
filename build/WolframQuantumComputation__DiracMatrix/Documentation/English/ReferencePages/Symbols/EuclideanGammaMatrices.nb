Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"Table", "[", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{
      RowBox[{"Length", " ", "@", " ", 
       RowBox[{"EuclideanGammaMatrices", "[", "n", "]"}]}], " ", "==", " ", 
      "n"}], " ", "&&", " ", 
     RowBox[{
      RowBox[{"First", " ", "@", " ", 
       RowBox[{"Dimensions", " ", "@", " ", 
        RowBox[{"First", " ", "@", " ", 
         RowBox[{"EuclideanGammaMatrices", "[", "n", "]"}]}]}]}], " ", "==", 
      " ", 
      RowBox[{"2", "^", 
       RowBox[{"Floor", "[", 
        RowBox[{"n", "/", "2"}], "]"}]}]}]}], ",", "\n", "  ", 
    RowBox[{"{", 
     RowBox[{"n", ",", " ", "1", ",", " ", "8"}], "}"}]}], "]"}], " ", "//", 
  " ", 
  RowBox[{"Apply", "[", "And", "]"}]}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
