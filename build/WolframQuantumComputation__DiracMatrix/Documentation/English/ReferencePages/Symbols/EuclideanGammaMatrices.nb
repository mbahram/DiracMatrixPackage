Cell[TextData[{
 "For even ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "2", " ", "m"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "82da19e8-f9af-4777-a8eb-f08c528eb46d"],
 ", the construction is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "k", "-", "1"}]], "=", 
    SuperscriptBox[
     StyleBox["I",
      FontFamily->"DoubleStruck"], 
     RowBox[{"\[CircleTimes]", "(", "k", "-", "1", ")"}]], " ", "\[CircleTimes]",
     " ", 
    SubscriptBox["\[Sigma]", "1"], " ", "\[CircleTimes]", " ", 
    SubsuperscriptBox["\[Sigma]", "3", 
     RowBox[{"\[CircleTimes]", "(", "m", "-", "k", ")"}]]}], 
   TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e569a836-b1c3-49a3-a674-b2dd9021a243"],
 " and ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "k"}]], "=", 
    SuperscriptBox[
     StyleBox["I",
      FontFamily->"DoubleStruck"], 
     RowBox[{"\[CircleTimes]", "(", "k", "-", "1", ")"}]], " ", "\[CircleTimes]",
     " ", 
    SubscriptBox["\[Sigma]", "2"], " ", "\[CircleTimes]", " ", 
    SubsuperscriptBox["\[Sigma]", "3", 
     RowBox[{"\[CircleTimes]", "(", "m", "-", "k", ")"}]]}], 
   TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "e7a0296f-5608-409a-ae60-fd7faa6dd3a9"],
 " for ",
 Cell[BoxData[
  FormBox[
   RowBox[{"k", "=", "1", ",", "\[Ellipsis]", ",", "m"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "98a48c42-d50b-416d-a35f-f8c3946e6aec"],
 ". For odd ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", "=", "2", " ", "m", "+", "1"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "80d48c05-fde8-4096-aeb4-4319c87c693d"],
 ", an additional ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "m", "+", "1"}]], "=", 
    SubsuperscriptBox["\[Sigma]", "3", 
     RowBox[{"\[CircleTimes]", " ", "m"}]]}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "b998012a-78d0-45dc-b667-633c37b1d142"],
 " is appended."
}], "Notes",
 CellID->302387906,ExpressionUUID->"00829b99-5988-4b10-bd81-201772535ca3"],

Cell[TextData[{
 "The returned matrices satisfy the Euclidean Clifford relation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"{", " ", 
    SuperscriptBox["\[CapitalGamma]", "\[Mu]"], ",", 
    SuperscriptBox["\[CapitalGamma]", "\[Nu]"], " ", "}", "=", "2", " ", 
    SuperscriptBox["\[Delta]", 
     RowBox[{"\[Mu]", " ", "\[Nu]"}]], " ", 
    StyleBox["I",
     FontFamily->"DoubleStruck"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "069de54d-f15c-41cf-9864-04d99d82031c"],
 ". For other signatures use GammaMatrices."
}], "Notes",
 CellID->400310068,ExpressionUUID->"314f895b-b0d9-4b21-87a0-28543a2d12d0"],

