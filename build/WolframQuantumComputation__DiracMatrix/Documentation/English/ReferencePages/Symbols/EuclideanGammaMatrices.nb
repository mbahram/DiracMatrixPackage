Cell[TextData[{
 "The chirality operator ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "m", "+", "1"}]], "=", 
    SuperscriptBox["\[CapitalGamma]", "1"], " ", 
    SuperscriptBox["\[CapitalGamma]", "2"], " ", "\[CenterEllipsis]", " ", 
    SuperscriptBox["\[CapitalGamma]", 
     RowBox[{"2", " ", "m"}]]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c5645081-77cf-4ff0-857a-dc3b01a1cb66"],
 " in even dimension equals the last basis element of the odd-dimensional \
construction:"
}], "ExampleText",
 CellID->1899443217,ExpressionUUID->"caaa6e0c-ed0b-434c-8d1a-6fddb118cd52"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"m", " ", "=", " ", "3"}], ",", " ", "even", ",", " ", "odd"}], 
    "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"even", " ", "=", " ", 
     RowBox[{"EuclideanGammaMatrices", "[", 
      RowBox[{"2", " ", "m"}], "]"}]}], ";", "\n", "  ", 
    RowBox[{"odd", "  ", "=", " ", 
     RowBox[{"EuclideanGammaMatrices", "[", 
      RowBox[{
       RowBox[{"2", " ", "m"}], " ", "+", " ", "1"}], "]"}]}], ";", "\n", 
    "  ", 
    RowBox[{
     RowBox[{
      RowBox[{"I", "^", "m"}], " ", 
      RowBox[{"Dot", " ", "@@", " ", "even"}]}], " ", "==", " ", 
     RowBox[{"Last", "[", "odd", "]"}]}]}]}], "]"}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->755355542,ExpressionUUID->"04dd2792-2d36-47a6-a625-7375b7764c51"],

