Cell[TextData[{
 "Each grade-k element on indices ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["i", "1"], "<", "\[CenterEllipsis]", "<", 
    SubscriptBox["i", "k"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f0e35ead-f5c7-4a70-88c9-818c3ced45a5"],
 " is the antisymmetrised product ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SubscriptBox["\[CapitalGamma]", 
     RowBox[{"[", 
      SubscriptBox["i", "1"], " ", "\[CenterEllipsis]", " ", 
      SubscriptBox["i", "k"], "]"}]], "=", 
    FractionBox["1", 
     RowBox[{"k", " ", "!"}]], " ", 
    UnderscriptBox["\[Sum]", 
     RowBox[{"\[Sigma]", "\[Element]", 
      SubscriptBox["S", "k"]}]], " ", 
    StyleBox["sgn", "MR"], "(", "\[Sigma]", ")", "\[ThinSpace]", " ", 
    SubscriptBox["\[CapitalGamma]", 
     SubscriptBox["i", 
      RowBox[{"\[Sigma]", "(", "1", ")"}]]], " ", "\[CenterEllipsis]", " ", 
    SubscriptBox["\[CapitalGamma]", 
     SubscriptBox["i", 
      RowBox[{"\[Sigma]", "(", "k", ")"}]]]}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c3468d30-40ee-4db9-b548-75d6bcb15eac"],
 "."
}], "Notes",
 CellID->662126735,ExpressionUUID->"78dffbfb-c155-407c-b185-4d8c56cbc35d"],

Cell[TextData[{
 "This is a literal transcription of the formula; it is pedagogically \
transparent but combinatorially expensive \[LongDash] for n indices it \
evaluates ",
 Cell[BoxData[
  FormBox[
   RowBox[{"n", " ", "!"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d3306f30-3cad-4ebd-8d55-cb31ce368250"],
 " permutations."
}], "Notes",
 CellID->1765949777,ExpressionUUID->"6994c64e-a533-4356-b3f3-c2263fd86938"],

Cell["\<\
For non-flat metrics with widely scaled eigenvalues, precision can degrade at \
high grade because of cancellations. Prefer CliffordBasis for production use; \
CliffordCanonicalBasis is best for pedagogy and as a flat-metric reference.\
\>", "Notes",
 CellID->1563894946,ExpressionUUID->"0a7b78d9-ad17-4811-894a-731b34689c6e"],

Cell[TextData[{
 "Number of grade-k elements is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"binom", " ", "n", " ", "k"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cff8c8c4-01fe-4c2b-a652-acaad683f710"],
 ", and the total basis size is ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["2", "n"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5ec37b59-3bb1-4804-a803-78f4112091e0"],
 "."
}], "Notes",
 CellID->2033432512,ExpressionUUID->"2637c1b6-1753-4ff6-9f6e-7a30380719c8"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

