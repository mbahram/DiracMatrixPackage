Cell["\<\
Higher grade on a random curved metric loses precision due to cancellations \
in the explicit sum \[LongDash] prefer CliffordBasis (production-ready \
alternative):\
\>", "ExampleText",
 CellID->1700122579,ExpressionUUID->"3e7507f0-3771-44a3-b779-66acb9e355ed"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "12345", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"3", ",", " ", "3"}], "]"}]}], "}"}], ",", "\n", "  ", 
   RowBox[{"NumericZeroQ", "[", "\n", "    ", 
    RowBox[{
     RowBox[{"Last", " ", "@", " ", 
      RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}]}], " ", "-", " ",
      "\n", "    ", 
     RowBox[{"Last", " ", "@", " ", 
      RowBox[{"CliffordBasis", "[", "\[Eta]", "]"}]}]}], "]"}]}], 
  "]"}]}], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
