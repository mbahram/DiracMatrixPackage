Cell[BoxData[GridBox[{
   {"", Cell[TextData[{
     Cell[BoxData[
      RowBox[{"CliffordCanonicalBasis", "[", "\[Eta]", "]"}]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "e3dcd1d9-f578-4b4f-9dc3-af672843f78a"],
     "\[LineSeparator]returns the canonical graded operator basis of the \
Clifford algebra ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        StyleBox["Cl", "MR"], "(", "\[Eta]", ")"}], TraditionalForm]], 
      "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "89007ca3-6040-4143-afcd-f5687e4c9a4a"],
     " as a list grouped by grade ",
     Cell[BoxData[
      FormBox[
       RowBox[{"{", " ", 
        SubscriptBox["\[CapitalGamma]", 
         RowBox[{"(", "0", ")"}]], ",", 
        SubscriptBox["\[CapitalGamma]", 
         RowBox[{"(", "1", ")"}]], ",", "\[Ellipsis]", ",", 
        SubscriptBox["\[CapitalGamma]", 
         RowBox[{"(", "n", ")"}]], " ", "}"}], TraditionalForm]], 
      "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "6236fa7d-3821-4591-addb-4760c9e625c9"],
     " via explicit antisymmetrisation."
    }],ExpressionUUID->"bf88512a-4839-4930-a0b4-a22891997554"]}
  }]], "Usage",
 CellID->1323187828,ExpressionUUID->"fa5e931c-4bed-4ee7-97f1-c506d191d2f9"]
}, Open  ]],

