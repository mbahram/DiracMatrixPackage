Cell[TextData[{
 "The construction is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["Q", 
     StyleBox["T", "MR"]], "\[CenterDot]", "\[CapitalLambda]", "\[CenterDot]",
     "Q"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "1cd04292-08b1-49c6-b215-ea67a83ddcb6"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{"Q", "\[Element]", "O", "(", "n", ")"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "910bf7f3-5421-43de-8e9c-cb85f6795a7a"],
 " drawn from CircularRealMatrixDistribution and ",
 Cell[BoxData[
  FormBox["\[CapitalLambda]", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0e20daf9-1fe5-45b6-9da0-1619226fd895"],
 " diagonal with ",
 Cell[BoxData[
  FormBox["p", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "58ed9919-6afd-427d-890d-a759008916e9"],
 " positive and ",
 Cell[BoxData[
  FormBox["q", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "cc4b5950-b547-4d89-8b76-2af7ad475c6c"],
 " negative eigenvalues."
}], "Notes",
 CellID->834793747,ExpressionUUID->"2eadfd9c-f0e5-4895-ba80-64500e3cba7a"],

Cell[TextData[{
 "The condition number of the resulting metric is approximately ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", " ", "\[Tilde]", " ", 
    SuperscriptBox["10", 
     RowBox[{"2", " ", "a"}]]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d6f971cc-6c71-4b32-bf7e-b788a2abddb7"],
 ", so the default ",
 Cell[BoxData[
  FormBox[
   RowBox[{"a", "=", "2"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0cd134ed-6d58-457f-a6ab-ee6dea800327"],
 " gives ",
 Cell[BoxData[
  FormBox[
   RowBox[{"\[Kappa]", " ", "\[Tilde]", " ", 
    SuperscriptBox["10", "4"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "0f2a195c-4920-4ed8-98e6-7133974f41d6"],
 "."
}], "Notes",
 CellID->201273979,ExpressionUUID->"ec1c3e4d-1b88-47e6-b9e7-9c3ac392d3df"],

