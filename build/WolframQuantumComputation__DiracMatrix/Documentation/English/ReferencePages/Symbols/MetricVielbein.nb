Cell["\<\
The vielbein of a random curved metric is a non-diagonal real matrix; the \
round-trip holds within tolerance:\
\>", "ExampleText",
 CellID->1524628193,ExpressionUUID->"9c4d2116-2f7f-41db-a24f-d3c5b5fd33ca"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{"\[Eta]", ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", 
   "  ", 
   RowBox[{
    RowBox[{"\[Eta]", " ", "=", " ", 
     RowBox[{"RandomCurvedMetric", "[", 
      RowBox[{"2", ",", " ", "2", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], ";",
     "\n", "  ", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"NumericZeroQ", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Transpose", "[", "e", "]"}], " ", ".", " ", "sig", " ", ".", 
       " ", "e"}], " ", "-", " ", "\[Eta]"}], "]"}]}]}], "]"}]}], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
