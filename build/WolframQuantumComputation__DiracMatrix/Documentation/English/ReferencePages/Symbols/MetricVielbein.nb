      "8499720d-bbf8-4943-a12a-834e669d9a2f"],
     "\[LineSeparator]returns ",
     Cell[BoxData[
      FormBox[
       RowBox[{"{", " ", 
        StyleBox["signature", "MR"], ",", "\[ThinSpace]", " ", "e", " ", 
        "}"}], TraditionalForm]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "8bced496-f5b9-419e-9149-a0b1d661baa3"],
     " for the real symmetric metric ",
     Cell[BoxData[
      FormBox["\[Eta]", TraditionalForm]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "52aeb16d-ad7b-4c9f-860c-8b2e6940e2c8"],
     ", where signature is ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        StyleBox["diag", "MR"], "(", 
        StyleBox["Sign", "MR"], "(", 
        StyleBox["eigenvalues", "MR"], ")", ")"}], TraditionalForm]], 
      "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "0c8846d9-8b5c-4658-8cfb-c4afd2a3749f"],
     " and the vielbein ",
     Cell[BoxData[
      FormBox["e", TraditionalForm]], "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "d088e727-d786-4932-a748-2b3e87618d06"],
     " satisfies ",
     Cell[BoxData[
      FormBox[
       RowBox[{
        SuperscriptBox["\[ExponentialE]", 
         StyleBox["T", "MR"]], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
        "\[NegativeThinSpace]", " ", 
        StyleBox["signature", "MR"], " ", "\[NegativeThinSpace]", "\[CenterDot]",
         "\[NegativeThinSpace]", " ", "e", "=", "\[Eta]"}], TraditionalForm]],
       "InlineFormula",
      FontFamily->"Source Sans Pro",ExpressionUUID->
      "3c06aeec-7a89-43b7-9235-cf43b1127a89"],
