Cell[TextData[{
 "The decomposition is constructed from the eigensystem of ",
 Cell[BoxData[
  FormBox["\[Eta]", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "92befd46-9290-478e-ae5b-423feddbab80"],
 ": with eigenvalues ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["\[Lambda]", "i"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f8a6076b-974e-4bd1-a79c-bf78b2ec4323"],
 " and orthonormal eigenvectors ",
 Cell[BoxData[
  FormBox[
   SubscriptBox["v", "i"], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "465856a4-1198-4a7e-aa52-96003e4e5343"],
 " stacked into rows of ",
 Cell[BoxData[
  FormBox["V", TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "5ab3796d-8a05-4057-961e-17f9d3aa0ac5"],
 ", signature is ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    StyleBox["diag", "MR"], "(", 
    StyleBox["Sign", "MR"], "(", 
    SubscriptBox["\[Lambda]", "i"], ")", ")"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "9d161ab3-0408-4ddb-8a05-010d7273cbd6"],
 " and the vielbein is ",
 Cell[BoxData[
  FormBox[
   RowBox[{"e", "=", 
    StyleBox["diag", "MR"], "(", 
    SqrtBox[
     RowBox[{"\[VerticalSeparator]", " ", 
      SubscriptBox["\[Lambda]", "i"], " ", "\[VerticalSeparator]"}]], ")", "\[CenterDot]",
     "V"}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "02e92cfb-d735-47a6-a6b0-d2952a58a9a9"],
 "."
}], "Notes",
 CellID->1010198616,ExpressionUUID->"9240e43b-3d22-4b42-9968-ff635eaa7c04"],

Cell[TextData[{
 "MetricVielbein expects a metric that is symmetric within tolerance ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "12"}]], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "d9d46a2e-415d-4022-a583-9b700d8292a3"],
 "."
}], "Notes",
 CellID->1586794633,ExpressionUUID->"b824dea6-f7c3-406a-9a8a-f14b198786e5"],

Cell[TextData[{
 "The vielbein is not unique: any rotation ",
 Cell[BoxData[
  FormBox[
   RowBox[{"R", "\[Element]", "O", "(", "n", ")"}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "a48e4e28-949e-4f58-8e69-648495c0c98f"],
 " applied as ",
 Cell[BoxData[
  FormBox[
   RowBox[{"e", "\[RightArrow]", "R", "\[CenterDot]", "e"}], 
   TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "fb593175-57ec-4b4c-8f62-52f04653cd84"],
 " with ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["R", 
     StyleBox["T", "MR"]], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
    "\[NegativeThinSpace]", " ", 
    StyleBox["signature", "MR"], " ", "\[NegativeThinSpace]", "\[CenterDot]", 
    "\[NegativeThinSpace]", " ", "R", "=", 
    StyleBox["signature", "MR"]}], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "c8487956-f885-404b-b402-1fe10ecb17af"],
 " yields another vielbein for the same metric. The form returned here is the \
eigenvector frame."
}], "Notes",
 CellID->2033824394,ExpressionUUID->"4d8e25f5-632f-4f15-8e6b-f3ed51f1ea24"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

