Cell[TextData[{
 "GammaMatrices uses MetricVielbein internally: the flat-space \[Gamma] \
matrices on the signature are pulled back to the curved frame via ",
 Cell[BoxData[
  FormBox[
   RowBox[{
    SuperscriptBox["\[Gamma]", "\[Mu]"], "=", 
    RowBox[{
     SubsuperscriptBox["e", 
      RowBox[{" ", "a"}], "\[Mu]"], " ", "\[ThinSpace]", " ", 
     SuperscriptBox["\[CapitalGamma]", "a"]}]}], TraditionalForm]], 
  "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "f3490294-0de9-40b2-9f79-dd4ef24e9fe5"],
 ". Verify this gives the same matrices:"
}], "ExampleText",
 CellID->106696808,ExpressionUUID->"795cd1b5-7d23-4418-8d64-228cc0d33f47"],

Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"DiagonalMatrix", "[", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{
          RowBox[{"-", "1"}], "/", "3"}], ",", " ", "3", ",", " ", "9", ",", 
         " ", "9"}], "}"}], "]"}]}], ",", " ", "sig", ",", " ", "e"}], "}"}], 
   ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}], " ", "===", " ", "\n", 
     "    ", 
     RowBox[{"TensorContract", "[", 
      RowBox[{
       RowBox[{"TensorProduct", "[", 
        RowBox[{"e", ",", " ", 
         RowBox[{"GammaMatrices", "[", "sig", "]"}]}], "]"}], ",", " ", 
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"1", ",", " ", "3"}], "}"}], "}"}]}], "]"}]}]}]}], 
  "]"}]], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->1616383369,ExpressionUUID->"7b5ab4a6-9fd5-45fa-9d46-5d588beeaf45"],

