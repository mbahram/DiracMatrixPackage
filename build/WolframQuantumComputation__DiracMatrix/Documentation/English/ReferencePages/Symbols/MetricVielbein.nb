Cell["\<\
For a randomly generated curved metric, the signature returned by \
MetricVielbein always equals Sign[Eigenvalues[\[Eta]]] as a diagonal matrix:\
\>", "ExampleText",
 CellID->873141767,ExpressionUUID->"a81747bf-b256-4bff-b7dc-356304efe3e0"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "7", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"RandomCurvedMetric", "[", 
       RowBox[{"2", ",", " ", "3", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], 
     ",", " ", "sig", ",", " ", "e"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"sig", ",", " ", "e"}], "}"}], " ", "=", " ", 
     RowBox[{"MetricVielbein", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"sig", " ", "===", " ", 
     RowBox[{"DiagonalMatrix", "[", 
      RowBox[{"Sign", " ", "@", " ", 
       RowBox[{"Eigenvalues", " ", "@", " ", "\[Eta]"}]}], "]"}]}]}]}], 
  "]"}]}], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
