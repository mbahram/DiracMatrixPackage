Cell["\<\
For random curved metrics, exact equality between matrices is not \
appropriate; check the residual with NumericZeroQ:\
\>", "ExampleText",
 CellID->1679426826,ExpressionUUID->"ba497fcf-7b82-4d65-9bb2-d411b4dde74e"],

Cell[CellGroupData[{

Cell[BoxData[{
 RowBox[{
  RowBox[{"SeedRandom", "[", "1", "]"}], ";"}], "\n", 
 RowBox[{"Module", "[", 
  RowBox[{
   RowBox[{"{", 
    RowBox[{
     RowBox[{"\[Eta]", " ", "=", " ", 
      RowBox[{"RandomCurvedMetric", "[", 
       RowBox[{"1", ",", " ", "3", ",", " ", "0.5", ",", " ", "1"}], "]"}]}], 
     ",", " ", "\[Gamma]"}], "}"}], ",", "\n", "  ", 
   RowBox[{
    RowBox[{"\[Gamma]", " ", "=", " ", 
     RowBox[{"GammaMatrices", "[", "\[Eta]", "]"}]}], ";", "\n", "  ", 
    RowBox[{"NumericZeroQ", "[", "\n", "    ", 
     RowBox[{
      RowBox[{"Outer", "[", 
       RowBox[{
        RowBox[{
         RowBox[{
          RowBox[{"#1", " ", ".", " ", "#2"}], " ", "+", " ", 
          RowBox[{"#2", " ", ".", " ", "#1"}]}], " ", "&"}], ",", " ", 
        "\[Gamma]", ",", " ", "\[Gamma]", ",", " ", "1"}], "]"}], " ", "-", 
      " ", "\n", "      ", 
      RowBox[{"2", " ", 
       RowBox[{"TensorProduct", "[", 
        RowBox[{"\[Eta]", ",", " ", 
         RowBox[{"IdentityMatrix", "[", "4", "]"}]}], "]"}]}]}], "]"}]}]}], 
  "]"}]}], "Input",
 CellProlog:>Needs["WolframQuantumComputation`DiracMatrix`"],
 CellLabel->"In[1]:=",
 CellID->573659947,ExpressionUUID->"6007a694-72e2-4ec4-950c-ed501bd3def5"],

Cell[BoxData["True"], "Output",
 CellLabel->"Out[1]=",
 CellID->1744287783,ExpressionUUID->"16f99d5d-d224-4a2d-87e1-7c197049b55e"]
}, Open  ]]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "ExampleSubsection", "2"}, 
  Closed]]]]
