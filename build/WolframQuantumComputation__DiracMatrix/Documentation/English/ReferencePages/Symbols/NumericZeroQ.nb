Cell["\<\
Use this to assert that a numerically computed quantity is the zero matrix or \
zero tensor when exact equality (===) cannot be expected due to round-off.\
\>", "Notes",
 CellID->1036785780,ExpressionUUID->"51fe08c5-0188-41d3-8997-4e445d757058"],

Cell[TextData[{
 "The default tolerance ",
 Cell[BoxData[
  FormBox[
   SuperscriptBox["10", 
    RowBox[{"-", "8"}]], TraditionalForm]], "InlineFormula",
  FontFamily->"Source Sans Pro",ExpressionUUID->
  "ef982ba3-4ba4-4d39-91b4-780d6d8a2484"],
 " is appropriate for machine-precision computation; for arbitrary-precision \
use a stricter tolerance."
}], "Notes",
 CellID->38107112,ExpressionUUID->"9ed083f1-73bc-4096-bf8a-f68334c7c127"]
}, Dynamic[CurrentValue[
 EvaluationNotebook[], {TaggingRules, "Openers", "NotesSection"}, Closed]]]],

